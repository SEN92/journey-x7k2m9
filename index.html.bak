<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
<title>رحلة المفتّش — HSE Journey</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700;900&family=Rajdhani:wght@500;700&display=swap" rel="stylesheet">
<link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>👷</text></svg>">
<style>
*{margin:0;padding:0;box-sizing:border-box;-webkit-tap-highlight-color:transparent}
body{background:#0a0e17;overflow:hidden;font-family:'Cairo',sans-serif;touch-action:manipulation}
canvas{display:block;position:absolute;top:0;left:0}

/* HUD */
.hud{position:fixed;top:0;left:0;right:0;display:flex;justify-content:space-between;align-items:center;padding:8px 16px;background:linear-gradient(180deg,rgba(10,14,23,0.97) 60%,transparent);z-index:100}
.hud-section{display:flex;align-items:center;gap:10px}
.hud-logo{font-family:'Rajdhani',sans-serif;font-size:18px;font-weight:700;color:#f0a500;text-shadow:0 0 12px rgba(240,165,0,0.4);letter-spacing:1px}
.hud-logo small{color:#a8b6c4;font-size:10px;font-weight:400;margin-left:6px}
.hud-rank{background:rgba(240,165,0,0.12);border:1px solid rgba(240,165,0,0.25);border-radius:20px;padding:3px 10px;color:#f0a500;font-size:11px;font-weight:700}
.hud-progress{display:flex;align-items:center;gap:6px;color:#a8b6c4;font-size:11px}
.hud-bar{width:100px;height:5px;background:rgba(255,255,255,0.08);border-radius:3px;overflow:hidden}
.hud-bar-fill{height:100%;background:linear-gradient(90deg,#f0a500,#2e7d32);transition:width .4s}
.hud-btn{background:rgba(255,255,255,0.06);border:1px solid rgba(255,255,255,0.1);color:#a8b6c4;width:32px;height:32px;border-radius:8px;font-size:14px;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:all .15s}
.hud-btn:hover,.hud-btn.on{background:rgba(240,165,0,0.15);border-color:#f0a500;color:#f0a500}

/* Env Tabs */
.env-bar{position:fixed;bottom:0;left:0;right:0;display:flex;justify-content:center;gap:8px;padding:8px 12px 12px;background:linear-gradient(0deg,rgba(10,14,23,0.97) 60%,transparent);z-index:100}
.env-tab{background:rgba(255,255,255,0.05);border:1.5px solid rgba(255,255,255,0.08);color:#8899aa;padding:7px 14px;border-radius:12px;font-family:'Cairo',sans-serif;font-size:11px;font-weight:700;cursor:pointer;transition:all .15s;display:flex;align-items:center;gap:5px;white-space:nowrap}
.env-tab:hover{border-color:rgba(240,165,0,0.4);color:#ddd}
.env-tab.on{background:rgba(240,165,0,0.12);border-color:#f0a500;color:#f5f3ee}
.env-tab .n{font-size:14px}
.env-tab .c{font-size:9px;opacity:.6}

/* Tooltip */
.tip{position:fixed;background:rgba(10,14,23,0.95);border:1px solid #f0a500;border-radius:8px;padding:6px 12px;color:#f5f3ee;font-size:11px;pointer-events:none;z-index:200;max-width:220px;box-shadow:0 4px 16px rgba(0,0,0,.5);display:none;line-height:1.4}

/* Character Info */
.char-info{position:fixed;bottom:56px;left:50%;transform:translateX(-50%);background:rgba(10,14,23,0.85);border:1px solid rgba(240,165,0,0.2);border-radius:10px;padding:5px 14px;color:#ddd;font-size:11px;z-index:100;display:flex;align-items:center;gap:6px;white-space:nowrap;transition:opacity .3s}

/* Speech */
.speech{position:fixed;bottom:90px;left:50%;transform:translateX(-50%);background:rgba(240,165,0,0.92);color:#0d1b2a;padding:10px 18px;border-radius:12px 12px 12px 0;font-size:12px;font-weight:600;z-index:150;max-width:320px;text-align:center;animation:sIn .25s;box-shadow:0 6px 24px rgba(240,165,0,0.25)}
@keyframes sIn{from{opacity:0;transform:translateX(-50%) translateY(8px)}to{opacity:1;transform:translateX(-50%) translateY(0)}}

/* Quiz */
.qz{position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(10,14,23,0.88);backdrop-filter:blur(10px);z-index:500;display:flex;align-items:center;justify-content:center;padding:16px;animation:fadeIn .2s}
@keyframes fadeIn{from{opacity:0}to{opacity:1}}
.qz-card{background:linear-gradient(145deg,#142535 0%,#1a3040 100%);border:2px solid rgba(240,165,0,0.2);border-radius:18px;max-width:560px;width:100%;max-height:88vh;overflow-y:auto;box-shadow:0 24px 80px rgba(0,0,0,.6);animation:cardIn .25s}
@keyframes cardIn{from{opacity:0;transform:scale(.95) translateY(10px)}to{opacity:1;transform:scale(1) translateY(0)}}
.qz-head{padding:14px 18px;border-bottom:1px solid rgba(255,255,255,0.06);display:flex;justify-content:space-between;align-items:center}
.qz-head h3{color:#f0a500;font-size:15px;font-weight:700;display:flex;align-items:center;gap:6px}
.qz-x{background:none;border:none;color:#667;font-size:18px;cursor:pointer;padding:2px 6px;border-radius:6px;transition:all .15s}
.qz-x:hover{color:#f0a500;background:rgba(240,165,0,0.1)}
.qz-body{padding:18px}
.qz-prog{display:flex;gap:4px;margin-bottom:14px}
.qz-prog span{flex:1;height:4px;background:rgba(255,255,255,0.06);border-radius:2px;transition:background .3s}
.qz-prog span.done{background:#f0a500}
.qz-prog span.current{background:#f0a500;animation:blink 1s infinite}
@keyframes blink{50%{opacity:.4}}
.qz-q{font-size:14px;line-height:1.9;margin-bottom:16px;color:#eee}
.qz-opts{display:flex;flex-direction:column;gap:7px}
.qz-opt{background:rgba(255,255,255,0.03);border:1.5px solid rgba(255,255,255,0.08);border-radius:10px;padding:11px 14px;color:#ddd;font-family:'Cairo',sans-serif;font-size:13px;cursor:pointer;transition:all .15s;text-align:right;display:flex;align-items:center;gap:8px}
.qz-opt:hover{border-color:rgba(240,165,0,0.5);background:rgba(240,165,0,0.06)}
.qz-opt .l{width:26px;height:26px;border-radius:50%;background:rgba(255,255,255,0.06);display:flex;align-items:center;justify-content:center;font-weight:700;font-size:11px;flex-shrink:0;transition:all .15s}
.qz-opt.ok{border-color:#2e7d32;background:rgba(46,125,50,0.12)}.qz-opt.ok .l{background:#2e7d32;color:#fff}
.qz-opt.no{border-color:#c62828;background:rgba(198,40,40,0.12)}.qz-opt.no .l{background:#c62828;color:#fff}
.qz-opt.dis{opacity:.5;cursor:default;pointer-events:none}
.qz-exp{margin-top:14px;padding:12px;border-radius:10px;font-size:12px;line-height:1.7;animation:fadeIn .2s}
.qz-exp.ok{background:rgba(46,125,50,0.1);border:1px solid rgba(46,125,50,0.25);color:#a5d6a7}
.qz-exp.no{background:rgba(198,40,40,0.1);border:1px solid rgba(198,40,40,0.25);color:#ef9a9a}
.qz-next{width:100%;margin-top:14px;padding:11px;background:linear-gradient(135deg,#f0a500,#d4940a);border:none;border-radius:10px;color:#0d1b2a;font-family:'Cairo',sans-serif;font-size:13px;font-weight:700;cursor:pointer;transition:all .15s}
.qz-next:hover{transform:translateY(-1px);box-shadow:0 6px 16px rgba(240,165,0,0.35)}

/* Results */
.res{text-align:center;padding:24px}
.res-icon{font-size:42px;margin-bottom:8px}
.res-title{font-size:20px;font-weight:900;color:#f0a500;margin-bottom:6px}
.res-score{font-size:44px;font-family:'Rajdhani',sans-serif;font-weight:700;margin-bottom:4px}
.res-msg{color:#8899aa;font-size:12px;margin-bottom:16px;line-height:1.5}

/* Toast */
.toast{position:fixed;top:50px;left:50%;transform:translateX(-50%);background:rgba(46,125,50,0.92);color:#fff;padding:8px 20px;border-radius:10px;font-size:12px;font-weight:600;z-index:600;animation:tIn .25s}
@keyframes tIn{from{opacity:0;transform:translateX(-50%) translateY(-8px)}to{opacity:1;transform:translateX(-50%) translateY(0)}}

/* Minimap */
.mmap{position:fixed;top:50px;right:12px;width:140px;height:80px;background:rgba(10,14,23,0.85);border:1px solid rgba(255,255,255,0.08);border-radius:8px;z-index:90;overflow:hidden;display:none}

/* Mobile D-Pad */
.dpad{position:fixed;bottom:70px;left:16px;z-index:110;display:none}
.dpad-btn{width:44px;height:44px;background:rgba(240,165,0,0.15);border:1.5px solid rgba(240,165,0,0.3);border-radius:10px;color:#f0a500;font-size:18px;display:flex;align-items:center;justify-content:center;position:absolute;cursor:pointer;user-select:none}
.dpad-btn:active{background:rgba(240,165,0,0.3)}
.dpad-u{bottom:90px;left:46px}.dpad-d{bottom:0;left:46px}.dpad-l{bottom:45px;left:0}.dpad-r{bottom:45px;left:92px}

@media(max-width:768px){
  .hud-logo small{display:none}
  .env-tab span:not(.n):not(.c){display:none}
  .dpad{display:block}
  .char-info{bottom:130px}
}

/* Scrollbar */
::-webkit-scrollbar{width:4px}::-webkit-scrollbar-track{background:transparent}::-webkit-scrollbar-thumb{background:rgba(240,165,0,0.3);border-radius:2px}

/* LTR overrides */
body.lang-en .qz-opt, body.lang-fr .qz-opt { text-align: left; }
body.lang-en .speech, body.lang-fr .speech { border-radius: 12px 12px 0 12px; }
body.lang-en .mmap, body.lang-fr .mmap { left: 12px; right: auto; }
body.lang-en .dpad { left: auto; right: 16px; }
body.lang-en .dpad-l { left: auto; right: 0; }
body.lang-en .dpad-r { left: auto; right: 92px; }

/* Fill-in-blank */
.qz-fill{margin-top:14px;display:flex;gap:8px;direction:ltr}
.qz-input{flex:1;padding:10px 14px;background:rgba(255,255,255,0.05);border:1.5px solid rgba(255,255,255,0.15);border-radius:10px;color:#eee;font-family:'Cairo',sans-serif;font-size:13px;outline:none;transition:border-color .15s}
.qz-input:focus{border-color:#f0a500}
.qz-input.correct{border-color:#2e7d32;background:rgba(46,125,50,0.12)}
.qz-input.wrong{border-color:#c62828;background:rgba(198,40,40,0.12)}
.qz-check{padding:10px 18px;background:linear-gradient(135deg,#f0a500,#d4940a);border:none;border-radius:10px;color:#0d1b2a;font-family:'Cairo',sans-serif;font-size:13px;font-weight:700;cursor:pointer;white-space:nowrap}
.qz-check:hover{transform:translateY(-1px);box-shadow:0 4px 12px rgba(240,165,0,0.3)}
</style>
</head>
<body>

<canvas id="gc"></canvas>

<div class="hud" id="hud">
  <div class="hud-section">
    <div class="hud-logo">HSE JOURNEY<small>v3.1</small></div>
    <div class="hud-rank" id="rank">🔰 متدرّب</div>
  </div>
  <div class="hud-section">
    <div class="hud-progress">
      <div class="hud-bar"><div class="hud-bar-fill" id="barFill" style="width:0%"></div></div>
      <span id="barTxt">0/67</span>
    </div>
  </div>
  <div class="hud-section">
    <button class="hud-btn" id="btnSave" title="حفظ">💾</button>
    <button class="hud-btn" id="btnMap" title="خريطة">🗺</button>
    <button class="hud-btn" id="btnSnd" title="صوت">🔊</button>
    <button class="hud-btn" id="btnLang" title="اللغة">🌐</button>
  </div>
</div>

<div class="env-bar" id="envBar">
  <button class="env-tab on" data-e="gas"><span class="n">🏭</span>مصنع الغاز<span class="c" id="cGas"></span></button>
  <button class="env-tab" data-e="oil"><span class="n">🛢</span>المصفاة<span class="c" id="cOil"></span></button>
  <button class="env-tab" data-e="sea"><span class="n">🌊</span>المنصة البحرية<span class="c" id="cSea"></span></button>
  <button class="env-tab" data-e="off"><span class="n">🏢</span>المبنى الإداري<span class="c" id="cOff"></span></button>
</div>

<div class="tip" id="tip"></div>
<div class="char-info" id="charInfo">👷 المفتّش — اضغط على محطة للتحرك</div>
<div class="speech" id="speech" style="display:none"></div>
<div class="toast" id="toast" style="display:none"></div>

<div class="dpad" id="dpad">
  <div class="dpad-btn dpad-u" data-dir="up">▲</div>
  <div class="dpad-btn dpad-d" data-dir="down">▼</div>
  <div class="dpad-btn dpad-l" data-dir="left">◀</div>
  <div class="dpad-btn dpad-r" data-dir="right">▶</div>
</div>

<script>
// ================================================================
// HSE JOURNEY v4.0 — Full 2D Game Engine
// ================================================================

const C = document.getElementById('gc');
const X = C.getContext('2d');
let W, H, GY; // width, height, ground Y

// --- i18n Dictionary ---
const UI = {
  ar: { dir:'rtl', lang:'ar',
    title: 'رحلة المفتّش — HSE Journey',
    hud: { save:'حفظ', map:'خريطة', sound:'صوت', lang:'اللغة' },
    ranks: [
      {min:0, icon:'🔰', name:'متدرّب'},
      {min:8, icon:'🥉', name:'مراقب سلامة'},
      {min:18, icon:'🥈', name:'مفتش عمليات'},
      {min:30, icon:'🥇', name:'محلل متقدم'},
      {min:45, icon:'🏆', name:'خبير معتمد'},
      {min:60, icon:'👑', name:'استشاري احترافي'}
    ],
    envs: { gas:'مصنع الغاز', oil:'المصفاة', sea:'المنصة البحرية', off:'المبنى الإداري' },
    envFull: { gas:'مصنع الغاز', oil:'مصفاة النفط', sea:'المنصة البحرية', off:'المبنى الإداري' },
    charInfo: '👷 المفتّش — اضغط على محطة للتحرك',
    quiz: {
      questionOf: (n,m) => `السؤال ${n} من ${m}`,
      letters: ['أ','ب','ج','د'],
      correct: '✓ إجابة صحيحة!',
      wrong: '✗ إجابة خاطئة',
      next: 'السؤال التالي →',
      results: '🏁 عرض النتائج',
      fillPlaceholder: 'اكتب إجابتك هنا...',
      fillCheck: 'تحقق'
    },
    speech: {
      locked: '🔒 هذه المحطة مقفلة! أكمل المحطة السابقة أولاً',
      excellent: '🎉 ممتاز! أكملت المحطة!',
      good: '👍 أحسنت! يمكنك المتابعة',
      retry: '📚 حاول مرة أخرى',
      welcome: '👷 مرحباً! أنا المفتّش. اضغط على محطة للتحرك والبدء!',
      envSwitch: (name) => `🏭 انتقلت إلى ${name}`
    },
    toast: { saved:'💾 تم حفظ التقدم' },
    tooltip: { done:'✓ مكتملة', avail:'🟢 متاحة', locked:'🔒 مقفلة' }
  },
  en: { dir:'ltr', lang:'en',
    title: "The Inspector's Journey — HSE Journey",
    hud: { save:'Save', map:'Map', sound:'Sound', lang:'Language' },
    ranks: [
      {min:0, icon:'🔰', name:'Trainee'},
      {min:8, icon:'🥉', name:'Safety Observer'},
      {min:18, icon:'🥈', name:'Operations Inspector'},
      {min:30, icon:'🥇', name:'Senior Analyst'},
      {min:45, icon:'🏆', name:'Certified Expert'},
      {min:60, icon:'👑', name:'Professional Consultant'}
    ],
    envs: { gas:'Gas Plant', oil:'Refinery', sea:'Offshore Platform', off:'Admin Building' },
    envFull: { gas:'Gas Plant', oil:'Oil Refinery', sea:'Offshore Platform', off:'Admin Building' },
    charInfo: '👷 The Inspector — Click a station to move',
    quiz: {
      questionOf: (n,m) => `Question ${n} of ${m}`,
      letters: ['A','B','C','D'],
      correct: '✓ Correct!',
      wrong: '✗ Incorrect',
      next: 'Next Question →',
      results: '🏁 View Results',
      fillPlaceholder: 'Type your answer here...',
      fillCheck: 'Check'
    },
    speech: {
      locked: '🔒 Station locked! Complete the previous station first',
      excellent: '🎉 Excellent! Station completed!',
      good: '👍 Well done! You can keep going',
      retry: '📚 Try again',
      welcome: "👷 Hello! I'm the Inspector. Click a station to begin!",
      envSwitch: (name) => `🏭 Moved to ${name}`
    },
    toast: { saved:'💾 Progress saved' },
    tooltip: { done:'✓ Completed', avail:'🟢 Available', locked:'🔒 Locked' }
  }
};

// --- Game State ---
const G = {
  lang: 'ar',
  env: 'gas',
  cx: 400, cy: 0, tx: 400,
  frame: 0, facing: 1, walking: false,
  completed: {}, score: 0,
  soundOn: true, showMap: false,
  particles: [], speechTimer: null,
  quiz: null, qIdx: 0, qAnswered: false, qSelected: null, qScore: 0,
  camX: 0, targetCam: 0,
  dayTime: 0,
  interactAnim: 0,
  perf: {} // adaptive performance tracking
};

// --- Translation Helper ---
function t(path) {
  const keys = path.split('.');
  let v = UI[G.lang];
  for (const k of keys) v = v[k];
  return v;
}
function L(stObj) { return stObj[G.lang] || stObj.ar; }

// --- Adaptive Selection Engine ---
function selectQuestions(station) {
  const pool = station.q;
  const perf = G.perf || {};
  const totalAttempts = Object.values(perf).reduce((s, p) => s + p.attempts, 0);
  const totalCorrect = Object.values(perf).reduce((s, p) => s + p.correct, 0);
  const playerAccuracy = totalAttempts > 0 ? totalCorrect / totalAttempts : 0.5;
  
  // Score each question
  const scored = pool.map((q, i) => {
    const key = station.id + '_q' + i;
    let weight = 1;
    
    if (!perf[key]) {
      weight = 3; // never seen = highest priority
    } else {
      const accuracy = perf[key].correct / perf[key].attempts;
      weight = (1 - accuracy) * 2; // 0-2 based on accuracy
    }
    
    // Difficulty bonus
    if (playerAccuracy > 0.8 && q.d >= 2) weight *= 1.5;
    if (playerAccuracy < 0.5 && q.d === 1) weight *= 1.5;
    
    return { q, weight, i };
  });
  
  // Sort by weight descending, pick top 2
  scored.sort((a, b) => b.weight - a.weight);
  return scored.slice(0, 2).map(s => s.q);
}

function recordAnswer(stationId, qIndex, correct) {
  const key = stationId + '_q' + qIndex;
  if (!G.perf[key]) G.perf[key] = { attempts: 0, correct: 0 };
  G.perf[key].attempts++;
  if (correct) G.perf[key].correct++;
}

// --- Audio Context ---
let actx;
function initAudio() {
  if (!actx) try { actx = new (window.AudioContext || window.webkitAudioContext)(); } catch(e) {}
}

function playTone(freq, dur, type = 'sine', vol = 0.15) {
  if (!G.soundOn || !actx) return;
  try {
    const o = actx.createOscillator();
    const g = actx.createGain();
    o.type = type;
    o.frequency.setValueAtTime(freq, actx.currentTime);
    g.gain.setValueAtTime(vol, actx.currentTime);
    g.gain.exponentialRampToValueAtTime(0.001, actx.currentTime + dur);
    o.connect(g); g.connect(actx.destination);
    o.start(); o.stop(actx.currentTime + dur);
  } catch(e) {}
}

function sfx(name) {
  initAudio();
  if (name === 'correct') { playTone(523, 0.12); setTimeout(() => playTone(659, 0.12), 80); setTimeout(() => playTone(784, 0.18), 160); }
  else if (name === 'wrong') { playTone(200, 0.15, 'sawtooth', 0.1); setTimeout(() => playTone(150, 0.15, 'sawtooth', 0.1), 100); }
  else if (name === 'complete') { [523,659,784,1047].forEach((f,i) => setTimeout(() => playTone(f, 0.2), i * 120)); }
  else if (name === 'click') { playTone(800, 0.05, 'square', 0.08); }
  else if (name === 'unlock') { playTone(440, 0.15); setTimeout(() => playTone(660, 0.2), 100); }
  else if (name === 'step') { playTone(60 + Math.random() * 30, 0.04, 'triangle', 0.06); }
  else if (name === 'hover') { playTone(1200, 0.03, 'sine', 0.04); }
  else if (name === 'ambient') {
    // Low hum
    if (actx._ambient) return;
    try {
      const o = actx.createOscillator();
      const g = actx.createGain();
      o.type = 'sine';
      o.frequency.value = 55;
      g.gain.value = 0.02;
      o.connect(g); g.connect(actx.destination);
      o.start();
      actx._ambient = o;
    } catch(e) {}
  }
}

// --- Station Data (67 stations) ---
const ST = [
  // GAS PLANT — NEBOSH ID1 (25 stations)
  {id:'1.1',e:'gas',n:{ar:'النماذج الاجتماعية القانونية',en:'Social-Legal Models'},i:'⚖️',x:120,q:[
    {t:{ar:'ما الفرق بين التشريع القائم على الأهداف والتوجيهي؟',en:'What is the difference between goal-based and prescriptive legislation?'},o:[{ar:'لا فرق',en:'No difference'},{ar:'القائم يحدد الهدف تاركاً الوسيلة، التوجيهي يفرض وسيلة محددة',en:'Goal-based sets the target leaving the method open; prescriptive mandates a specific method'},{ar:'التوجيهي أكثر مرونة',en:'Prescriptive is more flexible'},{ar:'القائم للبناء فقط',en:'Goal-based is for construction only'}],c:1,x:{ar:'القانون القائم على الأهداف يحدد ما يجب تحقيقه تاركاً الحرية في الوسيلة. التوجيهي يفرض إجراءات محددة.',en:'Goal-based legislation defines what must be achieved, leaving freedom in the method used. Prescriptive legislation mandates specific procedures.'}, d:2, type:'mcq'},
    {t:{ar:'ما عيب التشريع القائم على الأهداف؟',en:'What is the disadvantage of goal-based legislation?'},o:[{ar:'قديم بسرعة',en:'Becomes outdated quickly'},{ar:'الالتزامات قد تظل غامضة حتى تُختبر أمام المحكمة',en:'Obligations may remain ambiguous until tested in court'},{ar:'لا يناسب أماكن كبيرة',en:'Not suitable for large workplaces'},{ar:'يتطلب تحديثاً سنوياً',en:'Requires annual updates'}],c:1,x:{ar:'من عيوبه: غموض التفسير وصعوبة الإنفاذ لاختلاف التفسيرات.',en:'Its disadvantages include: ambiguous interpretation and difficulty in enforcement due to varying interpretations.'}, d:1, type:'mcq'},
    {t:{ar:'ما النموذج الاجتماعي القانوني الذي يرتكز على القيم الأخلاقية؟',en:'Which social-legal model is based on moral values?'},o:[{ar:'النموذج المادي',en:'Physical model'},{ar:'النموذج الأخلاقي',en:'Moral model'},{ar:'النموذج المالي',en:'Financial model'},{ar:'النموذج القانوني فقط',en:'Legal model only'}],c:1,x:{ar:'النموذج الأخلاقي: السلامة حق أخلاقي، لا يجوز المخاطرة بحيات الناس.',en:'The moral model of safety holds that it is morally wrong to place workers at risk of injury or ill-health.'}, d:2, type:'mcq'},
    {t:{ar:'النموذج المالي في السلامة يعتمد على',en:'The financial model in safety relies on'}, a:{ar:['الغرامات وتعويضات العمل'], en:['fines and compensation claims']}, x:{ar:'النموذج المالي: الغرامات وتعويضات العمل تُجبر أصحاب العمل على تحسين معايير السلامة.',en:'The financial model: fines and compensation claims compel employers to improve safety standards.'}, d:1, type:'fill'},
    {t:{ar:'ما دور النموذج المادي في فرض الامتثال للسلامة؟',en:'What role does the physical model play in enforcing safety compliance?'},o:[{ar:'لا دور له',en:'No role'},{ar:'يستخدم الإكراه الفيزيائي مثل الحواجز والقيود المادية',en:'Uses physical coercion such as guards and physical barriers'},{ar:'يعتمد على التوعية فقط',en:'Relies on awareness only'},{ar:'يعتمد على المبادئ الطوعية',en:'Relies on voluntary principles'}],c:1,x:{ar:'النموذج المادي يشمل الإكراه الفيزيائي (حواجز السلامة) والمالي (غرامات) لضمان الامتثال.',en:'The physical model includes physical coercion (safety guards) and financial coercion (fines) to ensure compliance.'}, d:3, type:'mcq'}
  ]},
  {id:'1.2',e:'gas',n:{ar:'الإنفاذ',en:'Enforcement'},i:'🔍',x:230,q:[
    {t:{ar:'ما معنى مبدأ التناسب في إنفاذ السلامة؟',en:'What does the principle of proportionality mean in safety enforcement?'},o:[{ar:'نفس الإجراء للجميع',en:'Same action for everyone'},{ar:'الإجراء يتناسب مع الخطر والمنظمة',en:'The action is proportionate to the hazard and the organisation'},{ar:'الإجراء صارم دائماً',en:'The action is always strict'},{ar:'يتطلب المحكمة',en:'Requires the court'}],c:1,x:{ar:'التناسب: شدة الإجراء تتناسب مع خطورة الخطر وحجم المنظمة.',en:'Proportionality: the severity of the enforcement action is proportionate to the level of risk and the size of the organisation.'}, d:2, type:'mcq'},
    {t:{ar:'أي الأدوات تُستخدم في الإنفاذ؟',en:'Which tools are used in enforcement?'},o:[{ar:'العقوبات فقط',en:'Penalties only'},{ar:'التوجيه، التحذير، الإنذار، التحقيق، الإغلاق',en:'Advice, warning, enforcement notice, investigation, closure'},{ar:'النشر فقط',en:'Publication only'},{ar:'الإغلاق فقط',en:'Closure only'}],c:1,x:{ar:'أدوات متعددة: توجيه، تحذير، إنذار، متابعة، تحقيق، إغلاق.',en:'Multiple tools: advice, warnings, enforcement notices, follow-up, investigation, and suspension/closure of operations.'}, d:1, type:'mcq'},
    {t:{ar:'ما الفرق بين إنذار التحسين وإنذار الحظر؟',en:'What is the difference between an improvement notice and a prohibition notice?'},o:[{ar:'لا فرق',en:'No difference'},{ar:'إنذار التحسين: يمكن الامتثال له. إنذار الحظر: يتوقف الخطر الفوري فوراً',en:'Improvement notice: can be complied with. Prohibition notice: stops immediate danger at once'},{ar:'إنذار الحظر أقل شدة',en:'Prohibition notice is less severe'},{ar:'كلاهما اختياري',en:'Both are optional'}],c:0,x:{ar:'إنذار التحسين يطلب تحسين ظرف معين. إنذار الحظر يوقف النشاط فوراً عند وجود خطر خطير.',en:'An improvement notice requires improving specific conditions. A prohibition notice stops activity immediately when serious danger exists.'}, d:2, type:'mcq'},
    {t:{ar:'مدة الطعن ضد إنذار إنفاذ السلامة',en:'Time limit for appealing a safety enforcement notice'}, a:{ar:['21 يوماً'], en:['21 days']}, x:{ar:'يمكن الطعن ضد إنذار الإنفاذ خلال 21 يوماً من تاريخ الإصدار.',en:'An appeal against an enforcement notice must be made within 21 days of issue.'}, d:1, type:'fill'},
    {t:{ar:'أي powers تملكه مفتش HSE عند التحقيق؟',en:'Which powers does an HSE inspector have during an investigation?'},o:[{ar:'لا أ powers',en:'No powers'},{ar:'فحص الوثائق فقط',en:'Examine documents only'},{ar:'الدخول، أخذ العينات، مصادرة المعدات، تحديد المواعيد',en:'Entry, take samples, seize equipment, set deadlines'},{ar:'الاعتقال فقط',en:'Arrest only'}],c:2,x:{ar:'مفتش HSE: دخول الأماكن، أخذ عينات، مصادرة معدات، إصدار إنذارات، تحديد مواعيد.',en:'HSE inspectors: enter premises, take samples, seize equipment, issue notices, and set compliance deadlines.'}, d:3, type:'mcq'}
  ]},
  {id:'1.3',e:'gas',n:{ar:'الصحة والسلامة في العمل',en:'Workplace H&S'},i:'🏥',x:350,q:[
    {t:{ar:'ما الواجب الأساسي لأي صاحب عمل؟',en:'What is the primary duty of every employer?'},o:[{ar:'توظيف أكبر عدد',en:'Hire the maximum number of workers'},{ar:'ضمان سلامة العمال قدر الإمكان عملياً',en:'Ensure worker safety so far as is reasonably practicable'},{ar:'تقليل التكاليف',en:'Minimise costs'},{ar:'التركيز على الإنتاج',en:'Focus on production'}],c:1,x:{ar:'المادة الأساسية: ضمان السلامة قدر الإمكان عملياً (SARP).',en:'The fundamental duty: ensure safety so far as is reasonably practicable (SARP).'}, d:1, type:'mcq'},
    {t:{ar:'ما معنى "قدر الإمكان عملياً"؟',en:'What does "so far as is reasonably practicable" (SARP) mean?'},o:[{ar:'أقل تكلفة',en:'Lowest cost'},{ar:'التوازن بين تكلفة التخفيف وفوائده',en:'Balancing the cost of mitigation against its benefits'},{ar:'أعلى تكلفة',en:'Highest cost'},{ar:'لا علاقة بالمال',en:'Unrelated to money'}],c:1,x:{ar:'SARP: التوازن بين فوائد تخفيف الخطر والتكاليف والوقت والجهد.',en:'SARP: balancing the benefits of risk reduction against the cost, time, and effort required.'}, d:2, type:'mcq'},
    {t:{ar:'ما واجب العامل تجاه السلامة؟',en:'What is the worker\'s duty regarding safety?'},o:[{ar:'لا واجب له',en:'No duty'},{ar:'المهنة فقط',en:'Work tasks only'},{ar:'أن يهتم بسلامته وسلامة الآخرين المتأثرين بأفعاله',en:'To take reasonable care of their own safety and that of others affected by their actions'},{ar:'الإبلاغ فقط',en:'Reporting only'}],c:2,x:{ar:'العامل واجبه: العناية المعقولة بسلامته وسلامة من يتأثرون بأفعاله.',en:'The worker\'s duty: take reasonable care of their own safety and that of others affected by their actions.'}, d:1, type:'mcq'},
    {t:{ar:'متى يُطلب من صاحب العمل كتابة سياسة السلامة والصحة؟',en:'When is an employer required to write a health and safety policy?'},o:[{ar:'دائماً',en:'Always'},{ar:'عندما يوظف 5 عمال أو أكثر',en:'When employing 5 or more workers'},{ar:'لا يُطلب أبداً',en:'Never required'},{ar:'فقط في المصانع',en:'Only in factories'}],c:1,x:{ar:'الكتابة إلزامية عندما يكون there 5 عمالاً أو أكثر.',en:'A written policy is mandatory when there are 5 or more employees.'}, d:2, type:'mcq'},
    {t:{ar:'دور الشخص المختص في السلامة هو',en:'The role of the competent person in safety is'}, a:{ar:['تقديم الإرشاد الفني المتخصص لصاحب العمل'], en:['providing specialist technical advice to the employer']}, x:{ar:'الشخص المختص يقدم إرشادات فنية ويساعد في تقييم المخاطر ووضع إجراءات السلامة.',en:'The competent person provides technical advice, helps with risk assessments, and develops safety procedures.'}, d:3, type:'fill'}
  ]},
  {id:'1.4',e:'gas',n:{ar:'الهيئات الرقابية',en:'Regulatory Bodies'},i:'🏛️',x:470,q:[
    {t:{ar:'ما الدور الرئيسي لهيئة HSE؟',en:'What is the primary role of the HSE (Health and Safety Executive)?'},o:[{ar:'إصدار التصاريح فقط',en:'Issuing permits only'},{ar:'وضع السياسات وإنفاذها وتقديم الإرشاد',en:'Setting policies, enforcing them, and providing guidance'},{ar:'إدارة المنشآت',en:'Managing facilities'},{ar:'تحصيل الضرائب',en:'Collecting taxes'}],c:1,x:{ar:'HSE: وضع المعايير، إنفاذها، الإرشاد، التحقيق في الحوادث.',en:'HSE: setting standards, enforcement, guidance, and investigating accidents.'}, d:1, type:'mcq'},
    {t:{ar:'متى تتدخل المحكمة؟',en:'When does the court intervene?'},o:[{ar:'دائماً',en:'Always'},{ar:'عند فشل الإجراءات الإدارية أو في الجرائم الخطيرة',en:'When administrative measures fail or in serious criminal cases'},{ar:'أبداً',en:'Never'},{ar:'فقط في المميتة',en:'Only in fatal cases'}],c:1,x:{ar:'المحكمة تتدخل عند فشل الإجراءات الإدارية أو الجرائم الخطيرة.',en:'The court intervenes when administrative enforcement measures fail or in serious criminal offences.'}, d:2, type:'mcq'},
    {t:{ar:'ما دور السلطات المحلية في السلامة والصحة؟',en:'What is the role of local authorities in health and safety?'},o:[{ar:'لا دور لها',en:'No role'},{ar:'إنفاذ السلامة في المنشآت التجارية والخدمية',en:'Enforcing safety in commercial and service premises'},{ar:'إدارة المنشآت الحكومية',en:'Managing government facilities'},{ar:'تحصيل الضرائب',en:'Collecting taxes'}],c:1,x:{ar:'السلطات المحلية: إنفاذ السلامة في المنشآت التجارية والخدمية (مطاعم، فنادق، متاجر).',en:'Local authorities enforce health and safety in commercial and service premises (restaurants, hotels, shops).'}, d:2, type:'mcq'},
    {t:{ar:'صلاحيات مفتش HSG تشمل',en:'Powers of an HSE inspector include'}, a:{ar:['الدخول إلى أي مكان عمل بدون إذن'], en:['entering any workplace without a warrant']}, x:{ar:'مفتش HSE يملك صلاحية الدخول إلى أي مكان عمل أثناء ساعات العمل دون الحاجة ل谕令.',en:'An HSE inspector has the power to enter any workplace during working hours without needing a warrant.'}, d:1, type:'fill'},
    {t:{ar:'ما حالة المبادئ المعتمدة (ACOP) في المحكمة؟',en:'What is the legal status of Approved Codes of Practice (ACOP) in court?'},o:[{ar:'لا قيمة قانونية لها',en:'No legal value'},{ar:'إثبات عدم الامتثال يُعتبر دليلاً على الإهمال ما لم يُثبت خلاف ذلك',en:'Failure to follow is evidence of negligence unless proven otherwise'},{ar:'إلزامية دائماً',en:'Always mandatory'},{ar:'توصيات فقط',en:'Recommendations only'}],c:1,x:{ar:'عدم الامتثال لـ ACOP: دليل على الإهمال ما لم يُثبت أن الم Practices البديلة كانت كافية.',en:'Non-compliance with ACOP: evidence of negligence unless it is proved that alternative practices were adequate.'}, d:3, type:'mcq'}
  ]},
  {id:'1.5',e:'gas',n:{ar:'المسؤولية التنظيمية',en:'Organizational Responsibility'},i:'📋',x:590,q:[
    {t:{ar:'ما معنى الرتبة المتساوية في المسؤولية؟',en:'What does "equal rank in responsibility" mean?'},o:[{ar:'الجميع يحصلون على نفس الراتب',en:'Everyone receives the same salary'},{ar:'كل شخص مسؤول وفق صلاحياته وموقعه',en:'Each person is responsible according to their authority and position'},{ar:'المديرون فقط',en:'Managers only'},{ar:'العمال غير مسؤولين',en:'Workers are not responsible'}],c:1,x:{ar:'كل شخص مسؤول وفقاً لمستوى صلاحياته في الهيكل التنظيمي.',en:'Each person is responsible according to their level of authority within the organisational structure.'}, d:1, type:'mcq'},
    {t:{ar:'هل العميل مسؤول عن السلامة؟',en:'Is the client responsible for safety?'},o:[{ar:'لا أبداً',en:'Never'},{ar:'نعم، إذا كان لديه سيطرة كافية على العمل',en:'Yes, if they have sufficient control over the work'},{ar:'فقط إذا كان مهندساً',en:'Only if they are an engineer'},{ar:'فقط في البناء',en:'Only in construction'}],c:1,x:{ar:'العميل مسؤول إذا كان لديه سيطرة فعلية على طريقة التنفيذ.',en:'The client is responsible if they have practical control over how the work is carried out.'}, d:2, type:'mcq'},
    {t:{ar:'ما واجب المدير تجاه الموارد المالية والبشرية للسلامة؟',en:'What is a director\'s duty regarding financial and human resources for safety?'},o:[{ar:'لا واجب',en:'No duty'},{ar:'يجب أن يوفر موارد كافية للسلامة',en:'Must provide adequate resources for safety'},{ar:'يتحمل العمال فقط',en:'Workers bear it only'},{ar:'يكتفي بالسياسة المكتوبة',en:'Written policy is sufficient'}],c:1,x:{ar:'المدير مسؤول عن توفير الموارد الكافية (مالية وبشرية) لتطبيق سياسة السلامة.',en:'A director is responsible for providing adequate resources (financial and human) to implement the safety policy.'}, d:2, type:'mcq'},
    {t:{ar:'ممثلو العمال في السلامة هم',en:'Worker safety representatives are'}, a:{ar:['عمال معينون من زملائهم لممارسة الضغط على الإدارة'], en:['workers appointed by their peers to represent workers on safety matters']}, x:{ar:'ممثلو السلامة: عمال معينون من الزملاء يمثلون مصالح العمال في مسائل السلامة.',en:'Safety representatives are workers appointed by their peers to represent workers on safety matters.'}, d:1, type:'fill'},
    {t:{ar:'في المشروعة التنظيمية، من المسؤول عن السلامة؟',en:'In organisational responsibility, who holds safety duties?'},o:[{ar:'المدير فقط',en:'The director only'},{ar:'صاحب العمل فقط',en:'The employer only'},{ar:'كل شخص وفقاً لصلاحياته في الهيكل التنظيمي',en:'Everyone according to their authority in the organisational structure'},{ar:'المشرفون فقط',en:'Supervisors only'}],c:2,x:{ar:'كل شخص مسؤول وفقاً لمستوى صلاحياته: مدراء، مشرفون، عمال، عملاء، مقاولون.',en:'Everyone is responsible according to their level of authority: managers, supervisors, workers, clients, and contractors.'}, d:3, type:'mcq'}
  ]},
  {id:'1.6',e:'gas',n:{ar:'الإرشاد والتوجيه',en:'Guidance & Direction'},i:'📖',x:710,q:[
    {t:{ar:'الفرق بين "إلزامي" و"توصوي"؟',en:'What is the difference between "mandatory" and "advisory"?'},o:[{ar:'لا فرق',en:'No difference'},{ar:'إلزامي: يجب الالتزام. توصوي: اختياري لكنه أفضل ممارسة',en:'Mandatory: must be complied with. Advisory: optional but represents best practice'},{ar:'توصوي إجباري',en:'Advisory is compulsory'},{ar:'إلزامي للشركات الكبيرة',en:'Mandatory only for large companies'}],c:1,x:{ar:'إلزامي: واجب قانونياً. توصوي: مرجعي يُعتبر أفضل ممارسة.',en:'Mandatory: a legal duty. Advisory: a reference standard considered best practice.'}, d:1, type:'mcq'},
    {t:{ar:'أي المعايير أكثر مرونة؟',en:'Which type of standard is more flexible?'},o:[{ar:'إلزامي',en:'Mandatory'},{ar:'توصوي',en:'Advisory'},{ar:'كلاهما متساوي',en:'Both are equal'},{ar:'لا معايير',en:'No standards'}],c:1,x:{ar:'التوصوي أكثر مرونة لأنه يقدم إرشادات لا قيوداً صارمة.',en:'Advisory standards are more flexible as they provide guidance rather than rigid constraints.'}, d:2, type:'mcq'},
    {t:{ar:'ما حالة المبادئ المعتمدة (ACOP) قانونياً؟',en:'What is the legal status of Approved Codes of Practice (ACOP)?'}, a:{ar:['ليست إلزامية لكن عدم الامتثال دليل على الإهمال'], en:['not legally binding but non-compliance is evidence of negligence']}, x:{ar:'ACOP: ليست إلزامية بشكل مباشر، لكن عدم اتباعها يُعتبر دليلاً على الإهمال.',en:'ACOP: not directly mandatory, but failure to follow them is evidence of negligence in court.'}, d:1, type:'fill'},
    {t:{ar:'ما هي المعايير البريطانية (BS) في السلامة؟',en:'What are British Standards (BS) in safety?'},o:[{ar:'قوانين إلزامية',en:'Mandatory laws'},{ar:'معايير تفصيلية تقنية تقدم إرشادات تطبيقية',en:'Detailed technical standards providing practical guidance'},{ar:'توصيات سياسية',en:'Policy recommendations'},{ar:'قواعد مؤقتة',en:'Temporary rules'}],c:1,x:{ar:'BS: معايير تقنية تفصيلية تقدم أفضل الممارسات والإرشادات التطبيقية.',en:'British Standards: detailed technical standards providing best practice and practical implementation guidance.'}, d:2, type:'mcq'},
    {t:{ar:'هل يمكن استخدام إرشادات HSE كدليل في المحكمة؟',en:'Can HSE guidance be used as evidence in court?'},o:[{ar:'لا أبداً',en:'Never'},{ar:'نعم، يمكن استخدامها لتوضيح المعايير المقبولة',en:'Yes, it can be used to illustrate acceptable standards'},{ar:'فقط إذا كانت إلزامية',en:'Only if mandatory'},{ar:'فقط للشركات الكبيرة',en:'Only for large companies'}],c:1,x:{ar:'إرشادات HSE: يمكن استخدامها كدليل على المعايير المقبولة في المحكمة.',en:'HSE guidance: can be used as evidence of acceptable standards in court proceedings.'}, d:3, type:'mcq'}
  ]},
  {id:'1.7',e:'gas',n:{ar:'المسؤولية الجنائية',en:'Criminal Responsibility'},i:'⚖️',x:120,q:[
    {t:{ar:'متى تتحمل المنظمة مسؤولية جنائية؟',en:'When does the organisation bear criminal responsibility?'},o:[{ar:'عند إصابة عامل فقط',en:'Only when a worker is injured'},{ar:'عندما يتسبب إهمالها في إصابة أو وفاة',en:'When its negligence causes injury or death'},{ar:'أبداً',en:'Never'},{ar:'فقط عند التعمد',en:'Only in cases of intent'}],c:1,x:{ar:'المنظمة مسؤولة جنائياً إذا أدى إهمالها إلى أذى لل persone.',en:'The organisation is criminally responsible if its negligence results in harm to persons.'}, d:2, type:'mcq'},
    {t:{ar:'عقوبة الإهمال الخطير؟',en:'What is the penalty for gross negligence?'},o:[{ar:'إنذار فقط',en:'Warning only'},{ar:'غرامة أو سجن أو كلاهما',en:'Fine, imprisonment, or both'},{ar:'لا عقوبة',en:'No penalty'},{ar:'إغلاق فقط',en:'Closure only'}],c:1,x:{ar:'الإهمال الخطير: غرامات كبيرة، أحكام سجن، أو إغلاق.',en:'Gross negligence: substantial fines, prison sentences, or facility closure.'}, d:2, type:'mcq'},
    {t:{ar:'ما الشرط الأساسي لإدانة المنظمة بجرائم القتل الخطيرة؟',en:'What is the key element for convicting an organisation of corporate manslaughter?'},o:[{ar:'الخطأ البسيط',en:'Simple error'},{ar:'إهمال كبار المديرين أدى إلى الوفاة',en:'Senior management failure that caused the death'},{ar:'إهمال عامل واحد',en:'A single worker\'s negligence'},{ar:'أي حادث مميت',en:'Any fatal incident'}],c:1,x:{ar:'جرائم القتل الخطيرة: يتطلب إهمال من كبار المديرين أدى بشكل مباشر إلى الوفاة.',en:'Corporate manslaughter: requires a gross management failure that caused the death.'}, d:2, type:'mcq'},
    {t:{ar:'واجب الرعاية (Duty of Care) يعني',en:'Duty of Care means'}, a:{ar:['الالتزام القانوني بضمان عدم إلحاق الأذى بالآخرين'], en:['the legal obligation to ensure others are not harmed']}, x:{ar:'واجب الرعاية: الالتزام القانوني باتخاذ خطوات معقولة لحماية الآخرين من الأذى.',en:'Duty of Care: the legal obligation to take reasonable steps to protect others from harm.'}, d:1, type:'fill'},
    {t:{ar:'ما هي دفاع الإجراءات المعقولة (Due Diligence)؟',en:'What is the defence of due diligence?'},o:[{ar:'الادعاء بإنذار فقط',en:'Claiming a warning only'},{ar:'إثبات أن صاحب العمل اتخذ جميع الخطوات المعقولة لتجنب المخالفة',en:'Proving the employer took all reasonable steps to avoid the offence'},{ar:'عدم وجود سوابق',en:'No previous record'},{ar:'المساعدة القانونية',en:'Legal aid'}],c:1,x:{ar:'الدفاع: إثبات أن صاحب العمل اتخذ كل خطوة معقولة لمنع المخالفة.',en:'The defence: proving the employer took every reasonable step to prevent the offence.'}, d:3, type:'mcq'}
  ]},
  {id:'1.8',e:'gas',n:{ar:'الإدارة والتنظيم',en:'Management & Organization'},i:'🏗️',x:230,q:[
    {t:{ar:'أهم عنصر في نظام إدارة السلامة؟',en:'What is the most important element of a safety management system?'},o:[{ar:'المعدات الغالية',en:'Expensive equipment'},{ar:'التدريب المستمر والتمكين للعمال',en:'Continuous training and worker empowerment'},{ar:'العقاب فقط',en:'Punishment only'},{ar:'الزيارات الميدانية',en:'Field visits only'}],c:1,x:{ar:'التدريب والتمكين أساس لأي نظام سلامة فعال.',en:'Training and empowerment form the foundation of any effective safety management system.'}, d:1, type:'mcq'},
    {t:{ar:'تأثير ثقافة المنظمة على السلامة؟',en:'How does organisational culture affect safety?'},o:[{ar:'لا تؤثر',en:'It has no effect'},{ar:'ثقافة إيجابية تقلل الحوادث بشكل كبير',en:'A positive culture significantly reduces incidents'},{ar:'تؤثر سلباً فقط',en:'It only has a negative effect'},{ar:'على الإنتاجية فقط',en:'On productivity only'}],c:1,x:{ar:'ثقافة السلامة الإيجابية تقلل الحوادث وتحسن الأداء العام.',en:'A positive safety culture reduces incidents and improves overall performance.'}, d:2, type:'mcq'},
    {t:{ar:'ما هو دورة التخطيط-التنفيذ-المراجعة-التحسين؟',en:'What is the Plan-Do-Check-Act cycle?'}, a:{ar:['نموذج لإدارة التحسين المستمر في أنظمة السلامة'], en:['a model for continuous improvement in safety management systems']}, x:{ar:'PDCA: دورة لإدارة التحسين المستمر: تخطيط، تنفيذ، مراجعة، تحسين.',en:'PDCA: a cycle for continuous improvement: Plan, Do, Check, Act.'}, d:1, type:'fill'},
    {t:{ar:'أجزاء سياسة السلامة المكتوبة الثلاثة؟',en:'What are the three parts of a written safety policy?'},o:[{ar:'فقط الإجراءات',en:'Procedures only'},{ar:'ال】,【 Declarations، التنظيم، التطبيق',en:'Statement of intent, organisational arrangements, arrangements for implementation'},{ar:'التدريب والميزانية فقط',en:'Training and budget only'},{ar:'القوانين واللوائح',en:'Laws and regulations'}],c:1,x:{ar:'سياسة السلامة: إعلان النية، الترتيبات التنظيمية، ترتيبات التطبيق.',en:'A safety policy: statement of intent, organisational arrangements, and implementation arrangements.'}, d:2, type:'mcq'},
    {t:{ar:'دور لجنة السلامة في المنظمة هو',en:'The role of the safety committee in an organisation is'}, o:[{ar:'معاقبة العمال فقط',en:'Punishing workers only'},{ar:'إعداد سياسات مالية',en:'Preparing financial policies'},{ar:'مراجعة التقييمات، متابعة الحوادث، التوصية بتحسينات',en:'Reviewing assessments, tracking incidents, recommending improvements'},{ar:'إدارة الإنتاج',en:'Managing production'}], c:2, x:{ar:'لجنة السلامة: مراجعة التقييمات، متابعة الحوادث، التوصية بالتحسينات، الرقابة على التنفيذ.',en:'The safety committee: reviews assessments, tracks incidents, recommends improvements, and monitors implementation.'}, d:3, type:'mcq'}
  ]},
  {id:'1.9',e:'gas',n:{ar:'التشريع الأوروبي',en:'European Legislation'},i:'🇪🇺',x:350,q:[
    {t:{ar:'كم عدد إرشاداتUE الرئيسية في السلامة؟',en:'How many EU Directives are there for safety?'},o:[{ar:'10 فقط',en:'Only 10'},{ar:'25 إرشادة تغطي مجالات مختلفة',en:'25 Directives covering different areas'},{ar:'لا توجد',en:'None'},{ar:'فقط المالية',en:'Only financial'}],c:1,x:{ar:'25 إرشادة أوروبياً تغطي مجالات السلامة المختلفة.',en:'25 European Directives covering various safety-related areas.'}, d:1, type:'mcq'},
    {t:{ar:'تأثير الإرشادات على التشريع المحلي؟',en:'How do Directives affect local legislation?'},o:[{ar:'لا تؤثر',en:'They have no effect'},{ar:'تفرض تبنّيها في التشريعات المحلية',en:'They require transposition into local legislation'},{ar:'توصيات فقط',en:'Recommendations only'},{ar:'على المالية فقط',en:'Financial only'}],c:1,x:{ar:'الدول ملزمة بتبني الإرشادات في تشريعاتها المحلية.',en:'Member States are required to transpose Directives into their national legislation.'}, d:2, type:'mcq'},
    {t:{ar:'ما هي الإرشادية الإطارية 89/391/EEC؟',en:'What is Framework Directive 89/391/EEC?'},o:[{ar:'إرشادية مالية',en:'Financial directive'},{ar:'الإرشادية الأساسية التي تضع المبادئ العامة لإدارة السلامة',en:'The fundamental directive setting out general principles for safety management'},{ar:'إرشادية مؤقتة',en:'Temporary directive'},{ar:'لا وجود لها',en:'Does not exist'}],c:1,x:{ar:'89/391/EEC: الإرشادية الإطارية الأساسية التي تضع مبادئ السلامة العامة.',en:'89/391/EEC: the fundamental framework directive establishing general safety principles.'}, d:2, type:'mcq'},
    {t:{ar:'وكالة السلامة والصحة في العمل الأوروبية تُعرف بـ',en:'The European Agency for Safety and Health at Work is known as'}, a:{ar:['EU-OSHA'], en:['EU-OSHA']}, x:{ar:'EU-OSHA: الوكالة الأوروبية للسلامة والصحة في العمل، مقرها في إسبانيا.',en:'EU-OSHA: the European Agency for Safety and Health at Work, headquartered in Spain.'}, d:1, type:'fill'},
    {t:{ar:'أي من الإرشادات التخصصية التالية لا تندرج تحت الإرشادات الأوروبية للسلامة؟',en:'Which of the following specific directives is NOT covered under EU safety Directives?'},o:[{ar:'إرشادية آلات 2006/42/EC',en:'Machinery Directive 2006/42/EC'},{ar:'إرشادية المخاطر الكيميائية 98/24/EC',en:'Chemical Agents Directive 98/24/EC'},{ar:'إرشادية حماية البيانات 95/46/EC',en:'Data Protection Directive 95/46/EC'},{ar:'إرشادية الأجهزة الطبية 93/42/EEC',en:'Medical Devices Directive 93/42/EEC'}],c:2,x:{ar:'إرشادية حماية البيانات ليست إرشادية سلامة مهنية.',en:'The Data Protection Directive is not an occupational safety directive.'}, d:3, type:'mcq'}
  ]},
  {id:'1.10',e:'gas',n:{ar:'تقييم المخاطر',en:'Risk Assessment'},i:'📊',x:470,q:[
    {t:{ar:'المعادلة الأساسية لتقييم المخاطر؟',en:'What is the basic risk assessment formula?'},o:[{ar:'خطر = أضرار × تكلفة',en:'Hazard = Harm × Cost'},{ar:'مخاطرة = احتمال × خطورة',en:'Risk = Likelihood × Severity'},{ar:'أمان = قواعد × متابعة',en:'Safety = Rules × Monitoring'},{ar:'risk = سرعة × كتلة',en:'Risk = Speed × Mass'}],c:1,x:{ar:'المخاطرة = احتمال الحدوث × خطورة النتيجة.',en:'Risk = Probability of occurrence × Severity of consequence.'}, d:1, type:'mcq'},
    {t:{ar:'الفرق بين الخطر والمخاطرة؟',en:'What is the difference between a hazard and a risk?'},o:[{ar:'لا فرق',en:'No difference'},{ar:'الخطر: مصدر الأذى. المخاطرة: احتمال وقوعه',en:'Hazard: source of harm. Risk: probability of occurrence and its severity'},{ar:'الخطر أخطر',en:'The hazard is more dangerous'},{ar:'المخاطرة مصدر الأذى',en:'Risk is the source of harm'}],c:1,x:{ar:'الخطر: مصدر الأذى المحتمل. المخاطرة: احتمال × شدة الأذى.',en:'Hazard: a potential source of harm. Risk: the likelihood × severity of that harm.'}, d:2, type:'mcq'},
    {t:{ar:'ما هي الخطوات الخمس لتقييم المخاطر؟',en:'What are the five steps of risk assessment?'},o:[{ar:'تحديد، تجاهل، تخفيف، مراقبة، نسيان',en:'Identify, Ignore, Mitigate, Monitor, Forget'},{ar:'تحديد المخاطر، تقييم المخاطر، اتخاذ التحكمات، تطبيقها، مراجعتها',en:'Identify hazards, assess risks, implement controls, apply them, review them'},{ar:'فقط التقييم',en:'Assessment only'},{ar:'التدريب والمراقبة',en:'Training and monitoring'}],c:1,x:{ar:'الخطوات الخمس: تحديد المخاطر، تقييم المخاطر، اتخاذ تدابير التحكم، تطبيقها، مراجعتها.',en:'The five steps: identify hazards, assess risks, decide on control measures, implement them, review them.'}, d:1, type:'mcq'},
    {t:{ar:'مصفوفة المخاطر تستخدم',en:'The risk matrix uses'}, a:{ar:['احتمال الحدوث وشدة النتيجة'], en:['likelihood of occurrence and severity of consequence']}, x:{ar:'مصفوفة المخاطر: احتمال × شدة = مستوى المخاطرة.',en:'Risk matrix: likelihood × severity = risk level.'}, d:2, type:'fill'},
    {t:{ar:'من يُكلف بإجراء تقييم المخاطر؟',en:'Who should carry out a risk assessment?'},o:[{ar:'أي شخص عشوائي',en:'Any random person'},{ar:'شخص مختص لديه المعرفة والخبرة المناسبة',en:'A competent person with appropriate knowledge and experience'},{ar:'فقط المدير العام',en:'Only the general manager'},{ar:'لا أحد',en:'Nobody'}],c:1,x:{ar:'التقييم: شخص مختص بمعرفة وخبرة كافية في طبيعة العمل والمخاطر.',en:'Assessment: a competent person with sufficient knowledge and experience of the work and its hazards.'}, d:3, type:'mcq'}
  ]},
  {id:'1.11',e:'gas',n:{ar:'التحكم في المخاطر',en:'Risk Control Hierarchy'},i:'🛡️',x:590,q:[
    {t:{ar:'التحكم الأكثر فعالية وفق هرم التحكم؟',en:'What is the most effective control according to the hierarchy of controls?'},o:[{ar:'PPE فقط',en:'PPE only'},{ar:'الاستبعاد (إزالة الخطر)',en:'Elimination (removing the hazard)'},{ar:'التعليم فقط',en:'Training only'},{ar:'التحذيرات',en:'Warnings'}],c:1,x:{ar:'الاستبعاد هو الأفضل لأنه يزيل الخطر من مصدره.',en:'Elimination is the most effective as it removes the hazard at its source.'}, d:1, type:'mcq'},
    {t:{ar:'التحكم الأقل فعالية؟',en:'What is the least effective control?'},o:[{ar:'الاستبعاد',en:'Elimination'},{ar:'التحكم الهندسي',en:'Engineering controls'},{ar:'التعليم',en:'Training'},{ar:'PPE',en:'PPE'}],c:1,x:{ar:'PPE خط آخر دفاع؛ لا يمنع الحادث لكنه يخفف الأثر.',en:'PPE is the last line of defence; it does not prevent the incident but mitigates its impact.'}, d:1, type:'mcq'},
    {t:{ar:'ما الترتيب الصحيح لهرم التحكم في المخاطر؟',en:'What is the correct order of the hierarchy of controls?'},o:[{ar:'PPE، تعليم، تحكم إداري، تحكم هندسي، استبعاد',en:'PPE, training, administrative, engineering, elimination'},{ar:'استبعاد، تعويض، تحكم هندسي، تحكم إداري، PPE',en:'Elimination, substitution, engineering controls, administrative controls, PPE'},{ar:'تحكم إداري فقط',en:'Administrative controls only'},{ar:'التعليم والتدريب فقط',en:'Training only'}],c:1,x:{ar:'الترتيب: استبعاد → تعويض → تحكم هندسي → تحكم إداري → معدات شخصية.',en:'The order: Elimination → Substitution → Engineering controls → Administrative controls → PPE.'}, d:2, type:'mcq'},
    {t:{ar:'التحكمات الجماعية تحمي',en:'Collective controls protect'}, a:{ar:['جميع العمال في نفس الوقت'], en:['all workers simultaneously']}, x:{ar:'التحكمات الجماعية: تحمي جميع العمال في منطقة العمل دفعة واحدة.',en:'Collective controls: protect all workers in the work area at the same time.'}, d:1, type:'fill'},
    {t:{ar:'أي من הבאים مثال على التعويض في هرم التحكم؟',en:'Which of the following is an example of substitution in the hierarchy of controls?'},o:[{ar:'ارتداء قفازات',en:'Wearing gloves'},{ar:'استبدال مادة سامة بمادة أقل خطورة',en:'Replacing a toxic substance with a less hazardous one'},{ar:'وضع لافتة تحذير',en:'Placing a warning sign'},{ar:'التدريب على الإجراءات',en:'Training on procedures'}],c:1,x:{ar:'التعويض: استبدال الخطر بخطر أقل خطورة (مثل استبدال مادة كيميائية سامة).',en:'Substitution: replacing a hazard with a less hazardous one (e.g., replacing a toxic chemical).'}, d:3, type:'mcq'}
  ]},
  {id:'1.12',e:'gas',n:{ar:'التحكم الهندسي',en:'Engineering Controls'},i:'⚙️',x:710,q:[
    {t:{ar:'أمثلة على التحكم الهندسي؟',en:'What are examples of engineering controls?'},o:[{ar:'التعليم والتدريب',en:'Education and training'},{ar:'الحواجز، التهوية، الإنذارات، التفريغ الآلي',en:'Guards, ventilation, alarms, automated discharging'},{ar:'PPE فقط',en:'PPE only'},{ar:'القوانين',en:'Regulations'}],c:1,x:{ar:'تحكم هندسي: حواجز فيزيائية، تهوية، إنذارات، أنظمة آلية.',en:'Engineering controls: physical guards, ventilation, alarms, and automated systems.'}, d:1, type:'mcq'},
    {t:{ar:'لماذا أكثر فعالية من الإداري؟',en:'Why are engineering controls more effective than administrative controls?'},o:[{ar:'الأرخص',en:'Cheaper'},{ar:'لا يعتمد على سلوك الإنسان',en:'They do not depend on human behaviour'},{ar:'أسهل',en:'Easier'},{ar:'لا يحتاج صيانة',en:'Require no maintenance'}],c:1,x:{ar:'لا يعتمد على وعي الإنسان؛ يعمل تلقائياً.',en:'They do not rely on human awareness; they function automatically.'}, d:2, type:'mcq'},
    {t:{ar:'ما هو نظام التهوية بالاستhaust المحلية (LEV)؟',en:'What is Local Exhaust Ventilation (LEV)?'}, a:{ar:['نظام يمتص الملوثات من مصدرها قبل وصولها للعامل'], en:['a system that captures pollutants at source before reaching the worker']}, x:{ar:'LEV: نظام يمتص الملوثات (غبار، دخان، بخار) من مصدرها مباشرة.',en:'LEV: a system that captures pollutants (dust, fumes, vapour) directly at the source.'}, d:1, type:'fill'},
    {t:{ar:'ما المتطلبات الأساسية لحجب الماكينات؟',en:'What are the basic requirements for machine guarding?'},o:[{ar:'لافتات فقط',en:'Signs only'},{ar:'حواجز تمنع التواصل مع أجزاء الحركة الخطرة',en:'Guards that prevent contact with dangerous moving parts'},{ar:'التعليم فقط',en:'Training only'},{ar:'لا متطلبات',en:'No requirements'}],c:1,x:{ar:'حجب الماكينات: حواجز فيزيائية تمنع التواصل مع أجزاء الحركة الخطرة.',en:'Machine guarding: physical barriers preventing contact with dangerous moving parts.'}, d:2, type:'mcq'},
    {t:{ar:'أنظمة الاقتران (Interlock) في الحواجز تعمل',en:'Interlock systems in guards work'}, o:[{ar:'عندما يُفتح الحاجز ي停下 الماكينة',en:'When the guard is opened, the machine stops'},{ar:'لا تعمل أبداً',en:'Never work'},{ar:'تبطئ الماكينة فقط',en:'Only slow down the machine'},{ar:'تزيد السرعة',en:'Increase speed'}],c:0,x:{ar:'الاقتران: فتح الحاجز يوقف الماكينة تلقائياً لمنع الإصابة.',en:'Interlocks: opening the guard automatically stops the machine to prevent injury.'}, d:3, type:'mcq'}
  ]},
  {id:'1.13',e:'gas',n:{ar:'التحكّم الإداري',en:'Administrative Controls'},i:'📋',x:120,q:[
    {t:{ar:'أدوات التحكم الإداري؟',en:'What are administrative control tools?'},o:[{ar:'الحواجز فقط',en:'Guards only'},{ar:'التدريب، السياسات، الإجراءات، الترخيص، المتابعة',en:'Training, policies, procedures, permits, and monitoring'},{ar:'العقوبات فقط',en:'Penalties only'},{ar:'المعدات فقط',en:'Equipment only'}],c:1,x:{ar:'أدوات: تدريب، سياسات، إجراءات، تراخيص، متابعة.',en:'Tools include: training, policies, procedures, permits, and monitoring.'}, d:1, type:'mcq'},
    {t:{ar:'عيب التحكم الإداري؟',en:'What is the disadvantage of administrative controls?'},o:[{ar:'لا عيوب',en:'No disadvantages'},{ar:'يعتمد على سلوك الإنسان القابل للخطأ',en:'They rely on human behaviour which is fallible'},{ar:'أغلى من الهندسي',en:'More expensive than engineering controls'},{ar:'بطيء',en:'Slow'}],c:1,x:{ar:'يعتمد على الالتزام البشري المتغير وغير الموثوق 100%.',en:'They depend on human compliance, which is variable and not 100% reliable.'}, d:2, type:'mcq'},
    {t:{ar:'ما هو نظام تصاريح العمل (Permit-to-Work)؟',en:'What is a permit-to-work system?'},o:[{ar:'نظام عقابي',en:'A disciplinary system'},{ar:'نظام مكتوب يضمن أن العمل الخطير يُنفّذ بأمان',en:'A written system ensuring dangerous work is carried out safely'},{ar:'نظام توظيف',en:'A recruitment system'},{ar:'نظام مالي',en:'A financial system'}],c:1,x:{ar:'تصريح العمل: نظام مكتوب يضمن اتخاذ تدابير السلامة قبل بدء العمل الخطير.',en:'A permit-to-work: a written system ensuring safety measures are in place before hazardous work begins.'}, d:2, type:'mcq'},
    {t:{ar:'نظام العمل الآمن هو',en:'A safe system of work is'}, a:{ar:['إجراء مكتوب يحدد الخطوات الآمنة لإنجاز مهمة معينة'], en:['a documented procedure specifying the safe steps to carry out a particular task']}, x:{ar:'نظام العمل الآمن: إجراء مكتوب يحدد طريقة آمنة لإنجاز مهمة معينة.',en:'A safe system of work: a documented procedure specifying the safe way to carry out a particular task.'}, d:1, type:'fill'},
    {t:{ar:'تحليل سلامة الوظيفة (JSA) يتضمن',en:'A Job Safety Analysis (JSA) includes'}, o:[{ar:'الميزانية فقط',en:'Budget only'},{ar:'تقسيم المهمة إلى خطوات، تحديد المخاطر، إجراءات التحكم',en:'Breaking the task into steps, identifying hazards, control measures'},{ar:'فقط الحوادث السابقة',en:'Only past incidents'},{ar:'تدريب الموظفين',en:'Employee training'}],c:1,x:{ar:'JSA: تقسيم المهمة → تحديد مخاطر كل خطوة → وضع إجراءات تحكم.',en:'JSA: break task into steps → identify hazards at each step → establish control measures.'}, d:3, type:'mcq'}
  ]},
  {id:'1.14',e:'gas',n:{ar:'المعدات الشخصية',en:'PPE'},i:'🦺',x:230,q:[
    {t:{ar:'متى تُستخدم PPE؟',en:'When is PPE used?'},o:[{ar:'دائماً كبديل وحيد',en:'Always as the sole measure'},{ar:'عندما لا يمكن تطبيق تحكمات أفضل',en:'When higher-order controls cannot be applied'},{ar:'أبداً',en:'Never'},{ar:'فقط في الطوارئ',en:'Only in emergencies'}],c:1,x:{ar:'PPE خط آخر دفاع: تُستخدم عندما لا يمكن تطبيق تحكمات أفضل.',en:'PPE is the last line of defence: used when higher-order controls cannot be implemented.'}, d:1, type:'mcq'},
    {t:{ar:'أهمية التدريب على PPE؟',en:'Why is training on PPE important?'},o:[{ar:'ليس مهماً',en:'Not important'},{ar:'يضمن الاستخدام الصحيح والفعّال',en:'It ensures correct and effective use'},{ar:'يزيد التكلفة',en:'It increases cost'},{ar:'يحسن المظهر',en:'It improves appearance'}],c:1,x:{ar:'بدون تدريب قد لا يعمل PPE بشكل صحيح.',en:'Without training, PPE may not function correctly.'}, d:2, type:'mcq'},
    {t:{ar:'ما المعايير التي يجب مراعاتها عند اختيار PPE؟',en:'What criteria should be considered when selecting PPE?'},o:[{ar:'اللون فقط',en:'Colour only'},{ar:'طبيعة الخطر، درجة الحماية المطلوبة، ملاءمة العامل',en:'Nature of the hazard, level of protection required, worker fit'},{ar:'التكلفة فقط',en:'Cost only'},{ar:'الماركة التجارية',en:'Brand name'}],c:1,x:{ar:'اختيار PPE: طبيعة الخطر، درجة الحماية، ملاءمة، راحة العامل.',en:'PPE selection: nature of the hazard, level of protection, fit, and worker comfort.'}, d:2, type:'mcq'},
    {t:{ar:'واجب صاحب العمل تجاه معدات الحماية الشخصية (PPE)',en:'The employer\'s duty regarding Personal Protective Equipment (PPE) is'}, a:{ar:['توفيرها مجاناً وتدريب العمال على استخدامها'], en:['providing it free of charge and training workers in its use']}, x:{ar:'صاحب العمل: يوفر PPE مجاناً، يدرّب على الاستخدام، يُبقيها في حالة جيدة.',en:'The employer: provides PPE free of charge, trains workers in its use, and maintains it in good condition.'}, d:1, type:'fill'},
    {t:{ar:'متى يجب فحص وصيانة PPE؟',en:'When should PPE be inspected and maintained?'},o:[{ar:'مرة في السنة',en:'Once a year'},{ar:'بانتظام قبل كل استخدام وبشكل دوري',en:'Regularly before each use and periodically'},{ar:'بعد الحادث فقط',en:'Only after an incident'},{ar:'لا يحتاج صيانة',en:'No maintenance needed'}],c:1,x:{ar:'PPE: فحص دوري قبل كل استخدام + صيانة وقائية منتظمة.',en:'PPE: regular inspection before each use + preventive maintenance on a scheduled basis.'}, d:3, type:'mcq'}
  ]},
  {id:'1.15',e:'gas',n:{ar:'المراقبة الصحية',en:'Health Surveillance'},i:'🩺',x:350,q:[
    {t:{ar:'الهدف من المراقبة الصحية؟',en:'What is the purpose of health surveillance?'},o:[{ar:'التحقق من الحضور',en:'Checking attendance'},{ar:'الكشف المبكر عن أمراض مهنية',en:'Early detection of occupational diseases'},{ar:'قياس الإنتاجية',en:'Measuring productivity'},{ar:'تقليل الرواتب',en:'Reducing salaries'}],c:1,x:{ar:'المراقبة تكشف المرض مبكراً قبل تفاقمه.',en:'Surveillance detects disease early before it worsens.'}, d:1, type:'mcq'},
    {t:{ar:'الفرق بين الفحص والمراقبة الصحية؟',en:'What is the difference between a medical examination and health surveillance?'},o:[{ar:'لا فرق',en:'No difference'},{ar:'الفحص: دوري عام. المراقبة: تتبع خاص بالمخاطر المهنية',en:'Examination: periodic and general. Surveillance: targeted monitoring of occupational hazards'},{ar:'الفحص أشمل',en:'Examination is more comprehensive'},{ar:'المراقبة للإدارة',en:'Surveillance is for management'}],c:1,x:{ar:'المراقبة موجهة تحديداً للمخاطر المهنية.',en:'Surveillance is specifically targeted at occupational hazards.'}, d:2, type:'mcq'},
    {t:{ar:'متى تُطلب المراقبة الصحية؟',en:'When is health surveillance required?'}, a:{ar:['عند التعرض لخطر مهني محدد'], en:['when there is exposure to a specific occupational hazard']}, x:{ar:'المراقبة: عند وجود خطر مهني محدد (ضوضاء، مواد كيميائية، غبار).',en:'Health surveillance: when there is exposure to a specific occupational hazard (noise, chemicals, dust).'}, d:1, type:'fill'},
    {t:{ar:'ما هو اختبار السمع (Audiometry) ولماذا يُستخدم؟',en:'What is audiometry testing and why is it used?'},o:[{ar:'قياس ضغط الدم',en:'Measuring blood pressure'},{ar:'اختبار لقياس حدة السمع وكشف فقدان السمع المبكر',en:'A test to measure hearing acuity and detect early hearing loss'},{ar:'اختبار بصر',en:'Vision test'},{ar:'اختبار دم',en:'Blood test'}],c:1,x:{ar:'السمع: يكشف فقدان السمع المبكر بسبب الضوضاء المهنية.',en:'Audiometry: detects early hearing loss caused by occupational noise exposure.'}, d:2, type:'mcq'},
    {t:{ar:'ما مدة الاحتفاظ بالسجلات الصحية للمراقبة؟',en:'How long should health surveillance records be kept?'},o:[{ar:'سنة واحدة',en:'One year'},{ar:'سنة واحدة فقط',en:'One year only'},{ar:'المدة المطلوبة قانونياً (عادة 40 سنة أو طوال فترة العمل)',en:'The legally required period (typically 40 years or for the duration of employment)'},{ar:'لا حاجة لسجلات',en:'No records needed'}],c:2,x:{ar:'السجلات الصحية: تُحتفظ بها لفترة طويلة قانونياً (40 سنة+) للكشف عن أمراض مهنية متأخرة.',en:'Health records: kept for a long legally defined period (40+ years) to detect delayed occupational diseases.'}, d:3, type:'mcq'}
  ]},
  {id:'1.16',e:'gas',n:{ar:'الصحة النفسية',en:'Mental Health'},i:'🧠',x:470,q:[
    {t:{ar:'أشهر المخاطر النفسية في العمل؟',en:'What are the most common psychological hazards at work?'},o:[{ar:'الضوضاء فقط',en:'Noise only'},{ar:'التوتر المزمن، التنمر، العمل الزائد، انعدام السيطرة',en:'Chronic stress, bullying, overwork, and lack of control'},{ar:'الإجهاد فقط',en:'Fatigue only'},{ar:'لا توجد',en:'None'}],c:1,x:{ar:'ضغوط: توتر، تنمر، إرهاق، فقدان سيطرة.',en:'Pressures include: stress, bullying, fatigue, and loss of control.'}, d:2, type:'mcq'},
    {t:{ar:'كيف تُحسّن المنظمات الصحة النفسية؟',en:'How do organisations improve mental health?'},o:[{ar:'زيادة العمل',en:'Increase workload'},{ar:'التوازن عمل-حياة، بيئة داعمة، برامج دعم',en:'Work-life balance, supportive environment, and support programmes'},{ar:'العقاب فقط',en:'Punishment only'},{ar:'عدم الاهتمام',en:'Ignore the issue'}],c:1,x:{ar:'بيئة داعمة، برامج دعم، وتوازن عمل-حياة هي المفتاح.',en:'A supportive environment, support programmes, and work-life balance are the key.'}, d:2, type:'mcq'},
    {t:{ar:'ما هي معايير إدارة الضغط النفسي الستة التي وضعتها HSE؟',en:'What are the six HSE Management Standards for workplace stress?'},o:[{ar:'فقط التدريب',en:'Training only'},{ar:'الطلب، السيطرة، الدعم، علاقات العمل، الدور، التغيير',en:'Demands, Control, Support, Relationships, Role, Change'},{ar:'الرواتب والعلاوات',en:'Salaries and bonuses'},{ar:'العطل والراحات',en:'Holidays and breaks'}],c:1,x:{ar:'المعايير الستة: طلب، سيطرة، دعم، علاقات عمل، دور، تغيير.',en:'The six standards: Demands, Control, Support, Relationships, Role, Change.'}, d:2, type:'mcq'},
    {t:{ar:'مؤشرات الإجهاد المرتبط بالعمل هي',en:'Indicators of work-related stress include'}, a:{ar:['الغياب المتكرر، انخفاض الأداء، تغيرات سلوكية'], en:['frequent absenteeism, reduced performance, behavioural changes']}, x:{ar:'مؤشرات: غياب متكرر، انخفاض أداء، تغيرات مزاجية، ارتفاع معدل الحوادث.',en:'Indicators: frequent absenteeism, reduced performance, mood changes, increased accident rates.'}, d:1, type:'fill'},
    {t:{ar:'هل يُعتبر الضغط النفسي من التزامات صاحب العمل القانونية؟',en:'Is workplace stress a legal duty of the employer?'},o:[{ar:'لا، هو مسؤولية الفرد',en:'No, it is the individual\'s responsibility'},{ar:'نعم، يجب على صاحب العمل تقييم ومعالجة مخاطر الضغط النفسي',en:'Yes, the employer must assess and address psychosocial risks'},{ar:'فقط إذا كان المرض مسجلاً',en:'Only if the condition is registered'},{ar:'لا قانون ي规制 هذا الأمر',en:'No law governs this'}],c:1,x:{ar:'نعم: صاحب العمل مسؤول قانونياً عن تقييم ومعالجة مخاطر الضغط النفسي في العمل.',en:'Yes: the employer has a legal duty to assess and address psychosocial risks at work.'}, d:3, type:'mcq'}
  ]},
  {id:'1.17',e:'gas',n:{ar:'الإجهاد الحراري',en:'Heat Stress'},i:'🌡️',x:590,q:[
    {t:{ar:'مخاطر الإجهاد الحراري؟',en:'What are the risks of heat stress?'},o:[{ar:'الراحة فقط',en:'Rest only'},{ar:'ضربات الشمس، انخفاض ضغط الدم، انخفاض الإنتاجية',en:'Heatstroke, low blood pressure, reduced productivity'},{ar:'زيادة الإنتاجية',en:'Increased productivity'},{ar:'لا مخاطر',en:'No risks'}],c:1,x:{ar:'إجهاد شمسي، انخفاض ضغط، تعب، انخفاض أداء.',en:'Heat exhaustion, low blood pressure, fatigue, and reduced performance.'}, d:1, type:'mcq'},
    {t:{ar:'تدابير الوقاية؟',en:'What are the preventive measures?'},o:[{ar:'عدم الشرب',en:'Not drinking water'},{ar:'فترات راحة، مياه باردة، ملابس خفيفة، تكييف',en:'Rest breaks, cool water, lightweight clothing, and air conditioning'},{ar:'العمل في الصيف فقط',en:'Work only in summer'},{ar:'لا تدابير',en:'No measures'}],c:1,x:{ar:'وقاية: راحة منتظمة، ترطيب، ملابس مناسبة، تكييف.',en:'Prevention: regular breaks, hydration, appropriate clothing, and air conditioning.'}, d:2, type:'mcq'},
    {t:{ar:'ما هو مؤشر كرتة الحرارة المبللة (WBGT)؟',en:'What is the Wet Bulb Globe Temperature (WBGT) index?'}, a:{ar:['مؤشر يقيس التعرض للإجهاد الحراري في بيئة العمل'], en:['an index measuring heat stress exposure in the work environment']}, x:{ar:'WBGT: مؤشر يجمع بين درجة الحرارة الجافة والرطوبة والإشعاع لقياس الإجهاد الحراري.',en:'WBGT: an index combining dry temperature, humidity, and radiation to measure heat stress.'}, d:1, type:'fill'},
    {t:{ar:'كم من الوقت يستغرق التعود على الحرارة (Acclimatization)؟',en:'How long does heat acclimatization take?'},o:[{ar:'يوم واحد',en:'One day'},{ar:'7 إلى 14 يوماً من التعرض التدريجي',en:'7 to 14 days of gradual exposure'},{ar:'شهر كامل',en:'A full month'},{ar:'لا يحتاج وقتاً',en:'Does not require time'}],c:1,x:{ar:'التعود: 7-14 يوماً من التعرض التدريجي للحرارة مع فترات راحة منتظمة.',en:'Acclimatization: 7-14 days of gradual heat exposure with regular rest breaks.'}, d:2, type:'mcq'},
    {t:{ar:'كم كمية المياه اليومية المطلوبة للعامل في البيئة الحارة؟',en:'What is the recommended daily water intake for a worker in a hot environment?'},o:[{ar:'500 مل',en:'500 ml'},{ar:'8-12 كوب (2-3 لتر) على الأقل',en:'8-12 glasses (2-3 litres) at minimum'},{ar:'فقط عند العطش',en:'Only when thirsty'},{ar:'لا حاجة للماء',en:'No water needed'}],c:1,x:{ar:'الترطيب: 2-3 لتر يومياً على الأقل، يُشرب بانتظام وليس فقط عند العطش.',en:'Hydration: at least 2-3 litres daily, drunk regularly and not just when thirsty.'}, d:3, type:'mcq'}
  ]},
  {id:'1.18',e:'gas',n:{ar:'المواد الخطرة',en:'Hazardous Substances'},i:'☣️',x:710,q:[
    {t:{ar:'الفئات الرئيسية للمواد الخطرة؟',en:'What are the main categories of hazardous substances?'},o:[{ar:'الغازات فقط',en:'Gases only'},{ar:'قابل للاحتراق، مسبب للتآكل، سام، مؤكسد، بيئي',en:'Flammable, corrosive, toxic, oxidising, and environmentally hazardous'},{ar:'الصلبات فقط',en:'Solids only'},{ar:'السوائل فقط',en:'Liquids only'}],c:1,x:{ar:'GHS: قابل للاحتراق، مسبب للتآكل، سام، مؤكسد، ضار بالبيئة.',en:'GHS classifications: flammable, corrosive, toxic, oxidising, and environmentally hazardous.'}, d:1, type:'mcq'},
    {t:{ar:'أهمية ورقة بيانات السلامة (SDS)؟',en:'Why is the Safety Data Sheet (SDS) important?'},o:[{ar:'تسويق المنتج',en:'Product marketing'},{ar:'معلومات شاملة عن المخاطر وطرق التعامل',en:'Comprehensive information on hazards and safe handling procedures'},{ar:'تقليل التكلفة',en:'Reducing cost'},{ar:'تحسين المظهر',en:'Improving appearance'}],c:1,x:{ar:'SDS: معلومات شاملة عن الخصائص والمخاطر والتعامل الآمن.',en:'SDS: comprehensive information on properties, hazards, and safe handling.'}, d:2, type:'mcq'},
    {t:{ar:'ما هو تقييم COSHH؟',en:'What is a COSHH assessment?'},o:[{ar:'تقييم مالي',en:'Financial assessment'},{ar:'تقييم شامل للمخاطر الناتجة عن المواد الخطرة وكيفية التحكم بها',en:'A comprehensive assessment of risks from hazardous substances and how to control them'},{ar:'تقييم تقني فقط',en:'Technical assessment only'},{ar:'تقييم مؤقت',en:'Temporary assessment'}],c:1,x:{ar:'COSHH: تقييم شامل لمخاطر المواد الخطرة وطرق التحكم الآمن.',en:'COSHH: a comprehensive assessment of hazardous substance risks and safe control methods.'}, d:2, type:'mcq'},
    {t:{ar:'حد التعرض المهني (OEL) هو',en:'The Occupational Exposure Limit (OEL) is'}, a:{ar:['أعلى تركيز مسموح به لغاز أو غبار في воздух لفترة معينة'], en:['the maximum concentration of a gas or dust allowed in the air for a set period']}, x:{ar:'OEL: الحد الأقصى لمتوسط التركيز المسموح به في بيئة العمل لفترة محددة.',en:'OEL: the maximum average concentration permitted in the workplace air for a defined period.'}, d:1, type:'fill'},
    {t:{ar:'أي من تدابير التحكم التالية هو الأفضل للمواد الخطرة؟',en:'Which of the following control measures is best for hazardous substances?'},o:[{ar:'التعليم فقط',en:'Training only'},{ar:'الاستبعاد أو التعويض أولاً، ثم التحكم الهندسي',en:'Elimination or substitution first, then engineering controls'},{ar:'PPE فقط',en:'PPE only'},{ar:'الuoافذ المفتوحة',en:'Open windows'}],c:1,x:{ar:'الأفضل: استبعاد/تعويض → تحكم هندسي → تحكم إداري → PPE.',en:'Best practice: elimination/substitution → engineering controls → administrative controls → PPE.'}, d:3, type:'mcq'}
  ]},
  {id:'1.19',e:'gas',n:{ar:'السلامة من التصميم',en:'Safety by Design'},i:'📐',x:120,q:[
    {t:{ar:'ما معنى "السلامة من التصميم"؟',en:'What is meant by "Safety by Design"?'},o:[{ar:'تصميم جميل',en:'Attractive design'},{ar:'دمج مبادئ السلامة من المرحلة الأولى',en:'Integrating safety principles from the earliest stage'},{ar:'تصميم المباني فقط',en:'Building design only'},{ar:'تصميم المعدات فقط',en:'Equipment design only'}],c:1,x:{ar:'السلامة من التصميم تدمج اعتبارات السلامة في كل مرحلة.',en:'Safety by Design embeds safety considerations into every stage of the design process.'}, d:1, type:'mcq'},
    {t:{ar:'لماذا فعالة أكثر؟',en:'Why is it more effective?'},o:[{ar:'الأرخص دائماً',en:'Always the cheapest'},{ar:'تمنع المخاطر قبل ظهورها',en:'It prevents hazards before they arise'},{ar:'أسهل',en:'Easier'},{ar:'مطلوب قانونياً فقط',en:'Required by law only'}],c:1,x:{ar:'الوقاية من التصميم أكثر فعالية من المعالجة.',en:'Prevention through design is more effective than remediation after the fact.'}, d:2, type:'mcq'},
    {t:{ar:'ما هو تقييم مخاطر التصميم؟',en:'What is a design risk assessment?'},o:[{ar:'تصميم جميل',en:'Attractive design'},{ar:'تقييم المخاطر المرتبطة بالتصميم نفسه قبل بدء الإنتاج',en:'Assessing risks associated with the design itself before production begins'},{ar:'تقييم الميزانية',en:'Budget assessment'},{ar:'تقييم الأداء',en:'Performance assessment'}],c:1,x:{ar:'تقييم مخاطر التصميم: تحديد المخاطر في مرحلة التصميم قبل تنفيذ المنتج.',en:'Design risk assessment: identifying hazards at the design stage before product implementation.'}, d:2, type:'mcq'},
    {t:{ar:'المخاطر المتبقية هي',en:'Residual risk is'}, a:{ar:['المخاطر التي تبقى بعد تطبيق جميع تدابير التحكم'], en:['the risk that remains after all control measures have been applied']}, x:{ar:'المخاطر المتبقية: الخطر المتبقي بعد تطبيق جميع تحكمات أقصى فعالية.',en:'Residual risk: the hazard remaining after applying all reasonably practicable controls.'}, d:1, type:'fill'},
    {t:{ar:'ما هي علامة CE ولماذا تهم في السلامة من التصميم؟',en:'What is the CE mark and why is it important for safety by design?'},o:[{ar:'شهادة جودة عامة',en:'General quality certificate'},{ar:'تعليم إلزامي يثبت مطابقة المنتج لمعايير السلامة الأوروبية',en:'A mandatory marking proving the product meets European safety standards'},{ar:'علامة تجارية',en:'Trade mark'},{ar:'شهادة بيئية',en:'Environmental certificate'}],c:1,x:{ar:'CE: علامة إلزامية تثبت أن المنتج متوافق مع معايير السلامة والصحة الأوروبية.',en:'CE: a mandatory marking proving the product complies with European safety and health standards.'}, d:3, type:'mcq'}
  ]},
  {id:'1.20',e:'gas',n:{ar:'الإبلاغ عن الحوادث',en:'Incident Reporting'},i:'🚨',x:230,q:[
    {t:{ar:'الحد الأدنى للحوادث الإبلاغ عنها؟',en:'What is the minimum threshold for reportable incidents?'},o:[{ar:'جميع الحوادث',en:'All incidents'},{ar:'الخطيرة، المميتة، الأمراض المهنية، حوادث المعدات',en:'Major injuries, fatalities, occupational diseases, and dangerous occurrences'},{ar:'لا شيء',en:'Nothing'},{ar:'فقط المميتة',en:'Fatalities only'}],c:1,x:{ar:'إبلاغ إلزامي: خطيرة، مميتة، أمراض مهنية، معدات.',en:'Mandatory reporting: major injuries, fatalities, occupational diseases, and dangerous occurrences.'}, d:1, type:'mcq'},
    {t:{ar:'المدة للإبلاغ عن حادث خطير؟',en:'What is the time limit for reporting a major incident?'},o:[{ar:'30 يوماً',en:'30 days'},{ar:'10 أيام عمل',en:'10 working days'},{ar:'يوم واحد',en:'One day'},{ar:'لا حد',en:'No limit'}],c:1,x:{ar:'10 أيام عمل للإبلاغ عن الحوادث الخطيرة.',en:'10 working days to report a major injury or dangerous occurrence.'}, d:2, type:'mcq'},
    {t:{ar:'من المسؤول عن الإبلاغ عن الحوادث في العمل؟',en:'Who is responsible for reporting workplace incidents?'},o:[{ar:'العامل فقط',en:'The worker only'},{ar:'صاحب العمل هو المسؤول الرئيسي عن الإبلاغ',en:'The employer is primarily responsible for reporting'},{ar:'شرطة فقط',en:'Police only'},{ar:'لا أحد',en:'Nobody'}],c:1,x:{ar:'صاحب العمل: المسؤول الرئيسي عن الإبلاغ عن الحوادث الخطيرة والمميتة.',en:'The employer: primarily responsible for reporting major injuries and fatalities.'}, d:2, type:'mcq'},
    {t:{ar:'RIDDOR تعني',en:'RIDDOR stands for'}, a:{ar:['Reporting of Injuries, Diseases and Dangerous Occurrences Regulations'], en:['Reporting of Injuries, Diseases and Dangerous Occurrences Regulations']}, x:{ar:'RIDDOR: لوائح الإبلاغ عن الإصابات والأمراض والوقائع الخطيرة.',en:'RIDDOR: the Reporting of Injuries, Diseases and Dangerous Occurrences Regulations.'}, d:1, type:'fill'},
    {t:{ar:'أي من الحوادث التالية وقوع خطير (dangerous occurrence)؟',en:'Which of the following is a dangerous occurrence?'},o:[{ar:'التعثر الخفيف',en:'Minor stumble'},{ar:'انهيار جزئي لسقف أو هيكل يُستخدم في العمل',en:'Partial collapse of a roof or structure used for work'},{ar:'تأخر في العمل',en:'Work delay'},{ar:'الشكاوى البسيطة',en:'Minor complaints'}],c:1,x:{ar:'الوقائع الخطيرة: انهيار هيكلي، تسرب مواد خطرة، انفجار، تعطل معدات أمان.',en:'Dangerous occurrences: structural collapse, hazardous material release, explosions, safety equipment failure.'}, d:3, type:'mcq'}
  ]},
  {id:'1.21',e:'gas',n:{ar:'التحقيق في الحوادث',en:'Incident Investigation'},i:'🔍',x:350,q:[
    {t:{ar:'الهدف الرئيسي للتحقيق؟',en:'What is the primary objective of an investigation?'},o:[{ar:'معاقبة المسؤولين',en:'Punishing those responsible'},{ar:'اكتشاف الأسباب الجذرية ومنع التكرار',en:'Discovering root causes and preventing recurrence'},{ar:'توثيق الحادث فقط',en:'Documenting the incident only'},{ar:'الحصول على تعويض',en:'Obtaining compensation'}],c:1,x:{ar:'الهدف: اكتشاف الأسباب الجذرية ومنع التكرار.',en:'The objective: identify root causes and prevent recurrence.'}, d:1, type:'mcq'},
    {t:{ar:'الأساس خطيرة في التحقيق؟',en:'What is the most critical aspect of an investigation?'},o:[{ar:'السبب المباشر فقط',en:'The immediate cause only'},{ar:'الأسباب الجذرية (نظامية)',en:'Root causes (systemic)'},{ar:'السبب المالي',en:'The financial cause'},{ar:'السبب الشخصي فقط',en:'The personal cause only'}],c:1,x:{ar:'الأسباب الجذرية (نظامية) هي الأهم لتمنع التكرار.',en:'Root causes (systemic) are the most important to prevent recurrence.'}, d:2, type:'mcq'},
    {t:{ar:'ما هي طرق التحقيق الشائعة في الحوادث؟',en:'What are common incident investigation methods?'},o:[{ar:'التخمين فقط',en:'Guessing only'},{ar:'تحليل لماذا-5، تحليل السبب الجذري، تحليل مخطط العظم',en:'5-Why analysis, root cause analysis, fishbone (Ishikawa) diagram'},{ar:'الإبلاغ فقط',en:'Reporting only'},{ar:'العقوبات فقط',en:'Punishment only'}],c:1,x:{ar:'طرق شائعة: لماذا-5، تحليل السبب الجذري، مخطط العظم (إيشيكاوا).',en:'Common methods: 5-Why analysis, root cause analysis, fishbone (Ishikawa) diagram.'}, d:2, type:'mcq'},
    {t:{ar:'تأمين مسرح الحادث يعني',en:'Securing the incident scene means'}, a:{ar:['منع الوصول للمحافظة على الأدلة'], en:['preventing access to preserve evidence']}, x:{ar:'تأمين المسرح: منع الوصول للمحافظة على الأدلة الفيزيائية.',en:'Securing the scene: preventing access to preserve physical evidence.'}, d:1, type:'fill'},
    {t:{ar:'من يجب أن يكون في فريق التحقيق؟',en:'Who should be on the investigation team?'},o:[{ar:'مفردون فقط',en:'Individuals only'},{ar:'فريق متعدد التخصصات يشمل خبراء تقنيين وممثلين عن العمال',en:'A multi-disciplinary team including technical experts and worker representatives'},{ar:'المدير العام فقط',en:'Only the general manager'},{ar:'الشرطة فقط',en:'Police only'}],c:1,x:{ar:'فريق التحقيق: متعدد التخصصات، يشمل خبراء تقنيين وممثلين عن العمال.',en:'The investigation team: multi-disciplinary, including technical experts and worker representatives.'}, d:3, type:'mcq'}
  ]},
  {id:'1.22',e:'gas',n:{ar:'التعويضات',en:'Compensation'},i:'💰',x:470,q:[
    {t:{ar:'من يتحمل تكاليف التعويض؟',en:'Who bears the cost of compensation?'},o:[{ar:'العامل فقط',en:'The worker only'},{ar:'صاحب العمل أو صندوق التعويضات',en:'The employer or the compensation fund'},{ar:'الحكومة فقط',en:'The government only'},{ar:'التأمين فقط',en:'Insurance only'}],c:1,x:{ar:'صاحب العمل مسؤول عن التعويض أو صندوق التعويضات.',en:'The employer is responsible for compensation, or the industrial injuries compensation scheme.'}, d:1, type:'mcq'},
    {t:{ar:'هل يمكن للعامل مقاضاة صاحب العمل؟',en:'Can a worker sue their employer?'},o:[{ar:'لا أبداً',en:'Never'},{ar:'نعم، عند إثبات الإهمال',en:'Yes, if negligence is proven'},{ar:'فقط إذا كان عائقاً',en:'Only if disabled'},{ar:'فقط في المميتة',en:'Only in fatal cases'}],c:1,x:{ar:'نعم، يمكن المقاضاة عند إثبات الإهمال.',en:'Yes, legal action can be taken if negligence is proven.'}, d:2, type:'mcq'},
    {t:{ar:'ما هو مكافحة إعاقات الإصابات الصناعية (IIDB)؟',en:'What is the Industrial Injuries Disablement Benefit (IIDB)?'}, a:{ar:['مبلغ أسبوعي يُدفع للعمال الذين أُصيبوا بسبب عملهم'], en:['a weekly payment to workers injured as a result of their work']}, x:{ar:'IIDB: مكافحة أسبوعية للعمال المصابين في العمل أو المصابين بأمراض مهنية.',en:'IIDB: a weekly benefit for workers injured at work or suffering from occupational diseases.'}, d:1, type:'fill'},
    {t:{ar:'نظام التعويض بدون إهمال (No-Fault) يعمل',en:'The no-fault compensation system works'}, o:[{ar:'يتطلب إثبات الإهمال',en:'Requires proof of negligence'},{ar:'يُدفع التعويض بغض النظر عن المسؤولية عند إصابة عامل في العمل',en:'Compensation is paid regardless of fault when a worker is injured at work'},{ar:'يتطلب دعوى قضائية',en:'Requires a court case'},{ar:'فقط للعمال الدائمين',en:'Only for permanent workers'}],c:1,x:{ar:'نظام بدون إهمال: تعويض تلقائي عند الإصابة في العمل دون الحاجة لإثبات إهمال صاحب العمل.',en:'No-fault system: automatic compensation for workplace injury without proving employer negligence.'}, d:2, type:'mcq'},
    {t:{ar:'ما هي تأمين المسؤولية تجاه العمال؟',en:'What is employers\' liability insurance?'},o:[{ar:'تأمين على المباني',en:'Building insurance'},{ar:'تأمين إلزامي يغطي تعويض العمال المصابين في العمل',en:'Mandatory insurance covering compensation for workers injured at work'},{ar:'تأمين طبي خاص',en:'Private medical insurance'},{ar:'تأمين المركبات',en:'Vehicle insurance'}],c:1,x:{ar:'تأمين المسؤولية: إلزامي، يغطي تعويض العمال المصابين في العمل.',en:'Employers\' liability insurance: mandatory, covering compensation for workers injured at work.'}, d:3, type:'mcq'}
  ]},
  {id:'1.23',e:'gas',n:{ar:'التوثيق والسجلات',en:'Documentation & Records'},i:'📝',x:590,q:[
    {t:{ar:'لماذا التوثيق ضروري؟',en:'Why is documentation essential?'},o:[{ar:'لتحسين المظهر',en:'To improve appearance'},{ar:'يثبت الامتثال ويسهل التتبع',en:'It proves compliance and facilitates tracking'},{ar:'يزيد العمل',en:'It increases workload'},{ar:'مطلوب للضرائب',en:'Required for tax purposes'}],c:1,x:{ar:'التوثيق يثبت الامتثال القانوني ويسهل التتبع.',en:'Documentation provides evidence of legal compliance and facilitates audit trails.'}, d:1, type:'mcq'},
    {t:{ar:'السجلات الأساسية؟',en:'What are the essential records?'},o:[{ar:'سجل الموظفين فقط',en:'Employee records only'},{ar:'حوادث، تدريب، تقييمات، تصاريح، فحوصات المعدات',en:'Incidents, training, assessments, permits, and equipment inspections'},{ar:'لا حاجة لسجلات',en:'No records needed'},{ar:'سجل المبيعات',en:'Sales records'}],c:1,x:{ar:'سجلات: حوادث، تدريب، تقييمات، تصاريح، فحوصات.',en:'Records include: incidents, training, assessments, permits, and inspections.'}, d:1, type:'mcq'},
    {t:{ar:'كم مدة الاحتفاظ بالسجلات القانونية للسلامة؟',en:'How long should legal safety records be retained?'},o:[{ar:'سنة واحدة',en:'One year'},{ar:'المدة المحددة قانونياً (عادة من 3 إلى 40 سنة حسب نوع السجل)',en:'The legally specified period (typically 3 to 40 years depending on record type)'},{ar:'لا مدة محددة',en:'No specified period'},{ar:'إلى الأبد',en:'Forever'}],c:1,x:{ar:'مدة الاحتفاظ: تتراوح بين 3-40 سنة حسب نوع السجل والتشريع المطبق.',en:'Retention periods: typically 3 to 40 years depending on the record type and applicable legislation.'}, d:2, type:'mcq'},
    {t:{ar:'سياق التدقيق (Audit Trail) هو',en:'An audit trail is'}, a:{ar:['سجل زمني متسلسل للأنشطة والقرارات'], en:['a chronological sequential record of activities and decisions']}, x:{ar:'سياق التدقيق: سجل زمني يتابع جميع الأنشطة والقرارات المتخذة.',en:'Audit trail: a chronological record tracking all activities and decisions made.'}, d:1, type:'fill'},
    {t:{ar:'هل يمكن استخدام السجلات كدليل قانوني في المحكمة؟',en:'Can safety records be used as legal evidence in court?'},o:[{ar:'لا أبداً',en:'Never'},{ar:'نعم، إذا كانت مُوثقة ومحفوظة بشكل صحيح',en:'Yes, if they are properly documented and maintained'},{ar:'فقط السجلات الحكومية',en:'Only government records'},{ar:'فقط أمام لجنة تحقيق',en:'Only before an inquiry committee'}],c:1,x:{ar:'السجلات: دليل قانوني في المحكمة إذا كانت موثقة ومحفوظة بشكل صحيح.',en:'Records: admissible as legal evidence in court if properly documented and maintained.'}, d:3, type:'mcq'}
  ]},
  {id:'1.24',e:'gas',n:{ar:'التشريعات الإضافية',en:'Additional Legislation'},i:'➕',x:710,q:[
    {t:{ar:'التشريعات الإضافية المهمة؟',en:'What are the important additional legislations?'},o:[{ar:'الضرائب فقط',en:'Tax only'},{ar:'البناء، التصميم، التفجير، المواد الخطرة، البيئة',en:'Construction, design, demolition, hazardous substances, and environment'},{ar:'الموظفين فقط',en:'Personnel only'},{ar:'لا تشريعات',en:'No legislation'}],c:1,x:{ar:'تشريعات إضافية: البناء، التصميم، التفجير، المواد الخطرة، البيئة.',en:'Additional legislation covers: construction, design, demolition, hazardous substances, and environmental protection.'}, d:1, type:'mcq'},
    {t:{ar:'أهمية تشريعات المواد الخطرة؟',en:'Why are hazardous substances regulations important?'},o:[{ar:'تصنيف فقط',en:'Classification only'},{ar:'ضمن التعامل الآمن في التخزين والنقل والاستخدام',en:'They ensure safe handling during storage, transport, and use'},{ar:'تقليل التكلفة',en:'Reducing cost'},{ar:'تحسين المظهر',en:'Improving appearance'}],c:1,x:{ar:'تشريعات المواد الخطرة تضمن التعامل الآمن في جميع المراحل.',en:'Hazardous substances regulations ensure safe handling at every stage.'}, d:2, type:'mcq'},
    {t:{ar:'ما هو DSEAR ولماذا مهم؟',en:'What is DSEAR and why is it important?'},o:[{ar:'قانون ضريبي',en:'Tax law'},{ar:'لوائح المواد الخطرة والأجواء المتفجرة التي تحمي العمال من الانفجارات والحرائق',en:'Dangerous Substances and Explosive Atmospheres Regulations protecting workers from explosions and fires'},{ar:'قانون بيئي فقط',en:'Environmental law only'},{ar:'قانون توظيف',en:'Employment law'}],c:1,x:{ar:'DSEAR: لوائح المواد الخطرة والأجواء المتفجرة لحماية العمال من مخاطر الانفجار والحرائق.',en:'DSEAR: Dangerous Substances and Explosive Atmospheres Regulations protecting workers from explosion and fire risks.'}, d:2, type:'mcq'},
    {t:{ar:'أنظمة الضغط (Pressure Systems) تتطلب',en:'Pressure systems require'}, a:{ar:['فحص دوري وتقديم تقرير من متخصص قبل التشغيل'], en:['periodic inspection and a written scheme of examination before operation']}, x:{ar:'أنظمة الضغط: فحص دوري + مخطط مكتوب + تقرير متخصص قبل التشغيل.',en:'Pressure systems: periodic inspection + written scheme of examination + specialist report before operation.'}, d:1, type:'fill'},
    {t:{ar:'ما هي LOLER ولماذا تهم في صناعة الغاز؟',en:'What is LOLER and why is it important in the gas industry?'},o:[{ar:'قانون بيئي',en:'Environmental law'},{ar:'لوائح عمليات الرفع ومعدات الرفع التي تضمن فحص وتشغيل آمن للمعدات',en:'Lifting Operations and Lifting Equipment Regulations ensuring safe inspection and use of lifting equipment'},{ar:'قانون ضريبي',en:'Tax law'},{ar:'قانون توظيف',en:'Employment law'}],c:1,x:{ar:'LOLER: لوائح عمليات الرفع ومعدات الرفع لإ ensure فحص وتشغيل آمن.',en:'LOLER: Lifting Operations and Lifting Equipment Regulations ensuring safe inspection and operation of lifting equipment.'}, d:3, type:'mcq'}
  ]},
  {id:'1.25',e:'gas',n:{ar:'المبادئ الخمسة لإدارة المخاطر',en:'5 HIRA Principles'},i:'🔧',x:120,q:[
    {t:{ar:'ما هي المبادئ الخمسة (HIRA)؟',en:'What are the five HIRA (Hazard Identification and Risk Assessment) principles?'},o:[{ar:'تحديد، تقييم، تخفيف، مراقبة، مراجعة',en:'Identify, Assess, Control, Monitor, Review'},{ar:'تحديد، تجاهل، تخفيف، مراقبة، نسيان',en:'Identify, Ignore, Mitigate, Monitor, Forget'},{ar:'تحديد فقط',en:'Identify only'},{ar:'تقييم فقط',en:'Assess only'}],c:1,x:{ar:'HIRA: تحديد، تقييم، تخفيف، مراقبة، مراجعة دورياً.',en:'HIRA: Identify hazards, Assess risk, implement Controls, Monitor effectiveness, and Review periodically.'}, d:1, type:'mcq'},
    {t:{ar:'لماذا المراجعة الدورية ضرورية؟',en:'Why is periodic review essential?'},o:[{ar:'لأنها مطلوبة قانونياً فقط',en:'Because it is only legally required'},{ar:'لأن المخاطر تتغير مع الوقت',en:'Because hazards change over time'},{ar:'لأنها تقلل التكاليف',en:'Because it reduces costs'},{ar:'لأنها تحسّن الصورة',en:'Because it improves image'}],c:1,x:{ar:'المخاطر متغيرة؛ المراجعة تضمن فعالية التحكمات الحالية.',en:'Hazards are dynamic; periodic review ensures that existing controls remain effective.'}, d:2, type:'mcq'},
    {t:{ar:'ما هي أساليب تحديد المخاطر في HIRA؟',en:'What are the methods for hazard identification in HIRA?'}, a:{ar:['الملاحظة، الفحص، الاستشارة، تحليل الحوادث'], en:['observation, inspection, consultation, and incident analysis']}, x:{ar:'تحديد المخاطر: ملاحظة مباشرة، فحص دوري، استشارة الخبراء، تحليل الحوادث.',en:'Hazard identification: direct observation, periodic inspection, expert consultation, and incident analysis.'}, d:1, type:'fill'},
    {t:{ar:'كيف يُحسب مستوى المخاطرة في مصفوفة HIRA؟',en:'How is the risk level calculated in a HIRA matrix?'},o:[{ar:'جمع الأرقام فقط',en:'Adding numbers only'},{ar:'قسمة الخطر على المخاطرة',en:'Dividing hazard by risk'},{ar:'احتمال الحدوث × شدة النتيجة',en:'Likelihood of occurrence multiplied by severity of consequence'},{ar:'متوسط المخاطر',en:'Average risk'}],c:2,x:{ar:'حساب المخاطرة: احتمال الحدوث × شدة النتيجة = مستوى المخاطرة.',en:'Risk calculation: likelihood of occurrence × severity of consequence = risk level.'}, d:2, type:'mcq'},
    {t:{ar:'ما هي تقنيات المراقبة المستخدمة بعد تطبيق التحكمات؟',en:'What monitoring techniques are used after implementing controls?'},o:[{ar:'المراقبة العشوائية فقط',en:'Random monitoring only'},{ar:'مراقبة مباشرة (ملاحظة)، مراقبة غير مباشرة (سجلات)، مراقبة صحية',en:'Active monitoring (observation), reactive monitoring (records), health surveillance'},{ar:'الانتظار والترقب فقط',en:'Wait and watch only'},{ar:'لا توجد تقنيات',en:'No techniques exist'}],c:1,x:{ar:'مراقبة: مباشرة (فحص ميداني)، غير مباشرة (تحليل السجلات)، صحية (فحوصات دورية).',en:'Monitoring: active (field inspection), reactive (records analysis), and health (periodic examinations).'}, d:3, type:'mcq'}
  ]},

  // OIL REFINERY — NEBOSH ID2 (15 stations)
  {id:'2.1',e:'oil',n:{ar:'الإجهاد وصحة العمال',en:'Stress & Worker Health'},i:'😤',x:120,q:[
    {t:{ar:'مصادر الإجهاد الرئيسية في العمل؟',en:'What are the main sources of stress at work?'},o:[{ar:'العمل فقط',en:'Work only'},{ar:'العمل الزائد/النقص، علاقات العمل، التغييرات التنظيمية',en:'Overload/underload, work relationships, organizational changes'},{ar:'الجو فقط',en:'Weather only'},{ar:'الرواتب فقط',en:'Salaries only'}],c:1,x:{ar:'مصادر: حمل عمل، علاقات، تغييرات تنظيمية، أمن وظيفي.',en:'Sources: workload, relationships, organizational changes, job security.'}, d:1, type:'mcq'},
    {t:{ar:'تأثير الإجهاد المزمن على الأداء؟',en:'What is the effect of chronic stress on performance?'},o:[{ar:'لا يتأثر',en:'No effect'},{ar:'انخفاض التركيز، زيادة الأخطاء، غياب، حوادث',en:'Reduced concentration, increased errors, absenteeism, accidents'},{ar:'تحسين الأداء',en:'Improved performance'},{ar:'زيادة الإنتاجية',en:'Increased productivity'}],c:1,x:{ar:'الإجهاد يقلل التركيز والقرار ويزيد الأخطاء والحوادث.',en:'Stress reduces focus and decision-making and increases errors and accidents.'}, d:2, type:'mcq'},
    {t:{ar:'ما هي تقنيات إدارة الإجهاد الفعّالة في بيئة العمل؟',en:'What are effective workplace stress management techniques?'},o:[{ar:'العزل التام',en:'Complete isolation'},{ar:'إدارة الوقت، تفويض الصلاحيات، الراحة المنتظمة، التواصل الفعّال',en:'Time management, delegation, regular breaks, effective communication'},{ar:'العمل الإضافي فقط',en:'Extra work only'},{ar:'تجاهل المشكلة',en:'Ignoring the problem'}],c:1,x:{ar:'تقنيات فعّالة: إدارة الوقت، تفويض، راحة، تواصل، دعم زملائي.',en:'Effective techniques: time management, delegation, breaks, communication, peer support.'}, d:2, type:'mcq'},
    {t:{ar:'أعراض الإجهاد الجسدية تشمل',en:'Physical symptoms of stress include'}, a:{ar:['صداع، آلام ظهر، مشاكل هضمية، ارتفاع ضغط الدم'], en:['headaches, back pain, digestive problems, high blood pressure']}, x:{ar:'الإجهاد يظهر جسدياً: صداع، آلام ظهر، مشاكل معوية، ارتفاع ضغط الدم، أرق.',en:'Stress manifests physically: headaches, back pain, digestive issues, elevated blood pressure, insomnia.'}, d:1, type:'fill'},
    {t:{ar:'دور الإدارة في تقليل ضغوط العمل هو',en:'The role of management in reducing workplace stress is'}, o:[{ar:'زيادة العمل',en:'Increasing workload'},{ar:'تجاهل شكاوى العمال',en:'Ignoring worker complaints'},{ar:'تحديد الأدوار الواضحة، الدعم، المرونة، العدالة التنظيمية',en:'Clear role definition, support, flexibility, organisational fairness'},{ar:'العقاب فقط',en:'Punishment only'}], c:2, x:{ar:'الإدارة: تحديد أدوار واضحة، دعم، مرونة في العمل، عدالة تنظيمية، استماع.',en:'Management: clear roles, support, work flexibility, organisational justice, active listening.'}, d:3, type:'mcq'}
  ]},
  {id:'2.2',e:'oil',n:{ar:'الغبار والجسيمات',en:'Dust & Particulates'},i:'💨',x:230,q:[
    {t:{ar:'المخاطر الصحية للغبار الصناعي؟',en:'What are the health hazards of industrial dust?'},o:[{ar:'لا مخاطر',en:'No hazards'},{ar:'أمراض رئوية، حساسية، سرطان الرئة',en:'Pulmonary diseases, allergies, lung cancer'},{ar:'تحسين التنفس',en:'Improved breathing'},{ar:'لا يسبب أمراضاً',en:'Does not cause diseases'}],c:1,x:{ar:'الغبار: التليف الرئوي، الربو، سرطان الرئة في الحالات الشديدة.',en:'Dust: pulmonary fibrosis, asthma, and lung cancer in severe cases.'}, d:1, type:'mcq'},
    {t:{ar:'كيف يُتحكم في التعرض للغبار؟',en:'How is dust exposure controlled?'},o:[{ar:'عدم الارتداد فقط',en:'Not wearing PPE only'},{ar:'التحكم الهندسي، PPE، رش الماء',en:'Engineering controls, PPE, water spraying'},{ar:'فتح النوافذ',en:'Opening windows'},{ar:'التجاهل',en:'Ignoring it'}],c:1,x:{ar:'تحكم: تهوية، مضخات، PPE، رش ماء، ترطيب.',en:'Controls: ventilation, extraction fans, PPE, water spraying, dampening.'}, d:2, type:'mcq'},
    {t:{ar:'ما الفرق بين الغبار القابل للاستنشاق والغبار المستنشق الرئوي؟',en:'What is the difference between inhalable and respirable dust?'},o:[{ar:'لا فرق',en:'No difference'},{ar:'القابل للاستنشاق: يدخل الأنف والحنجرة. المستنشق الرئوي: يصل للرئتين',en:'Inhalable: enters nose and throat. Respirable: reaches deep into lungs'},{ar:'الاستنشقي أقل خطورة',en:'Inhalable is less hazardous'},{ar:'الرئوي لا يصل للجسم',en:'Respirable does not reach the body'}],c:1,x:{ar:'الاستنشقي: أكبر جسيمات تصل للتجويف الأنفي. الرئوي: جسيمات دقيقة تصل للأساكيب.',en:'Inhalable: larger particles settling in nasal cavity. Respirable: fine particles reaching the alveoli.'}, d:2, type:'mcq'},
    {t:{ar:'حد التعرض المهني (OEL) للغبار الصناعي هو',en:'The occupational exposure limit (OEL) for industrial dust is'}, a:{ar:['التركيز الأقصى المسموح به في الهواء أثناء فترة عمل محددة'], en:['the maximum concentration allowed in the air during a defined exposure period']}, x:{ar:'OEL يُحدّد بالmiligram/متر مكعب ويعتمد على نوع الغبار وطبيعته الكيميائية.',en:'OEL is measured in mg/m³ and depends on the dust type and its chemical nature.'}, d:1, type:'fill'},
    {t:{ar:'نظام التهوية بالاستhaust المحلية (LEV) في التحكم بالغبار يعمل بـ',en:'A Local Exhaust Ventilation (LEV) system for dust control works by'}, o:[{ar:'تبريد الهواء فقط',en:'Cooling air only'},{ar:'امتصاص الملوثات من مصدرها مباشرة قبل وصولها للتنفس',en:'Capturing pollutants directly at source before reaching the breathing zone'},{ar:'رياح خارجية',en:'External wind'},{ar:'لا يُستخدم للغبار',en:'Not used for dust'}], c:1, x:{ar:'LEV: يمتص الغبار من مصدره مباشرة عبر فوهات استيعاب ومرشحات.',en:'LEV: captures dust directly at the source through extraction hoods and filters.'}, d:3, type:'mcq'}
  ]},
  {id:'2.3',e:'oil',n:{ar:'الضوضاء',en:'Noise'},i:'🔊',x:350,q:[
    {t:{ar:'مستوى الضوضاء الخطير للسمع؟',en:'What is the dangerous noise level for hearing?'},o:[{ar:'50 ديسيبل',en:'50 decibels'},{ar:'أكثر من 85 ديسيبل لمدة 8 ساعات',en:'Over 85 decibels for 8 hours'},{ar:'100 ديسيبل دائماً',en:'100 decibels always'},{ar:'لا يوجد حد',en:'No limit'}],c:1,x:{ar:'85 ديسيبل لمدة 8 ساعات هو الحد المقبول.',en:'85 decibels for 8 hours is the acceptable limit.'}, d:1, type:'mcq'},
    {t:{ar:'وسائل الحماية من الضوضاء؟',en:'What are the means of noise protection?'},o:[{ar:'عدم السمع فقط',en:'Not hearing only'},{ar:'سدادات الأذن، خوذات عازلة، التحكم الهندسي',en:'Earplugs, ear defenders, engineering controls'},{ar:'الهاتف فقط',en:'Phone only'},{ar:'الصراخ',en:'Shouting'}],c:1,x:{ar:'حماية: سدادات، خوذ، تحكم هندسي في مصدر الضوضاء.',en:'Protection: earplugs, ear defenders, engineering controls at the noise source.'}, d:2, type:'mcq'},
    {t:{ar:'الفرق بين فقدان السمع المؤقت والدائم بسبب الضوضاء؟',en:'What is the difference between temporary and permanent noise-induced hearing loss?'},o:[{ar:'لا فرق',en:'No difference'},{ar:'المؤقت: يزول بعد الراحة. الدائم: لا رجعة فيه بسبب تلف الخلاياHair',en:'Temporary: recovers after rest. Permanent: irreversible damage to hair cells'},{ar:'المؤقت أخطر',en:'Temporary is more dangerous'},{ar:'الدائم يُعالج بالأدوية',en:'Permanent is treatable with medication'}],c:1,x:{ar:'TTS (مؤقت): يزول. PTS (دائم): تلف لا رجعة فيه لخلايا القوقعة.',en:'TTS (temporary): recovers. PTS (permanent): irreversible damage to cochlear hair cells.'}, d:2, type:'mcq'},
    {t:{ar:'مناطق حماية الضوضاء (Ear Protection Zones) هي مناطق',en:'Ear Protection Zones are areas where'}, a:{ar:['يتجاوز مستوى الضوضاء 85 ديسيبل ويجب ارتداء حماية الأذن'], en:['noise levels exceed 85 decibels and hearing protection must be worn']}, x:{ar:'مناطق حماية الأذن: منطقة يتجاوز فيها الضوضاء 85 dB ويُطلب ارتداء حماية الأذن.',en:'Ear Protection Zones: areas exceeding 85 dB where hearing protection is mandatory.'}, d:1, type:'fill'},
    {t:{ar:'ما هي زراعة السمع (Dosimetry) ولماذا تُستخدم في مراقبة الضوضاء؟',en:'What is noise dosimetry and why is it used?'},o:[{ar:'قياس درجة الحرارة',en:'Temperature measurement'},{ar:'جهاز يُلبس لقياس التعرض الكلي للضوضاء طوال فترة العمل',en:'A wearable device measuring total noise exposure throughout the working day'},{ar:'قياس الرطوبة',en:'Humidity measurement'},{ar:'لا يُستخدم',en:'Not used'}],c:1,x:{ar:'الجرعة الصوتية: جهاز يُلبس يقيس التعرض الكلي للضوضاء طوال يوم العمل.',en:'Dosimetry: a personal wearable device that measures cumulative noise exposure over the working day.'}, d:3, type:'mcq'}
  ]},
  {id:'2.4',e:'oil',n:{ar:'الإشعاع',en:'Radiation'},i:'☢️',x:470,q:[
    {t:{ar:'الأنواع الرئيسية للإشعاع في العمل؟',en:'What are the main types of radiation at work?'},o:[{ar:'المرئية فقط',en:'Visible light only'},{ar:'أيوني (X-ray) وغير أيوني (UV, laser)',en:'Ionizing (X-ray) and non-ionizing (UV, laser)'},{ar:'الشمس فقط',en:'Sun only'},{ar:'لا يوجد',en:'None'}],c:1,x:{ar:'أيوني: أشعة X، غاماً. غير أيوني: UV، ليزر، ميكروويف.',en:'Ionizing: X-rays, gamma. Non-ionizing: UV, laser, microwave.'}, d:1, type:'mcq'},
    {t:{ar:'مبدأ ALARA؟',en:'What is the ALARA principle?'},o:[{ar:'التعرض بأمان دائماً',en:'Always safe exposure'},{ar:'التعرض بالقدر الأدنى الممكن عملياً',en:'Exposure as low as reasonably practicable'},{ar:'عدم التعرض أبداً',en:'No exposure ever'},{ar:'التعرض القصوى',en:'Maximum exposure'}],c:1,x:{ar:'ALARA: التعرض الأدنى الممكن عملياً.',en:'ALARA: As Low As Reasonably Practicable — minimum feasible exposure.'}, d:2, type:'mcq'},
    {t:{ar:'ما هي الأEffects الصحية للإشعاع الأيوني على جسم الإنسان؟',en:'What are the health effects of ionizing radiation on the human body?'},o:[{ar:'لا آثار',en:'No effects'},{ar:'إصابة الخلايا، أمراض الدم، سرطان، تلف الأنسجة',en:'Cell injury, blood disorders, cancer, tissue damage'},{ar:'تحسن المناعة',en:'Improved immunity'},{ar:'زيادة الطاقة',en:'Increased energy'}],c:1,x:{ar:'الإشعاع الأيوني يُسبب تلف الحمض النووي، أمراض الدم، سرطان، حروق إشعاعية.',en:'Ionizing radiation causes DNA damage, blood disorders, cancer, and radiation burns.'}, d:2, type:'mcq'},
    {t:{ar:'الحد السنوي للتعرض للإشعاع الأيوني هو',en:'The annual dose limit for ionizing radiation exposure is'}, a:{ar:['20 مللي سيفرت للمutowنين و1 مللي سيفرت للعامة'], en:['20 millisieverts for radiation workers and 1 millisievert for the public']}, x:{ar:'الحد السنوي: 20 mSv للمutowنين (متوسط 5 سنوات) و1 mSv للعامة.',en:'Annual limit: 20 mSv for occupationally exposed workers (averaged over 5 years) and 1 mSv for the public.'}, d:1, type:'fill'},
    {t:{ar:'أجهزة القياس الشخصية (Dosimeters) للإشعاع تُستخدم لـ',en:'Personal dosimeters for radiation are used to'}, o:[{ar:'قياس درجة الحرارة',en:'Measure temperature'},{ar:'تسجيل التعرض الكلي للإشعاع لكل عامل بشكل فردي',en:'Recording the total radiation dose for each worker individually'},{ar:'قياس الرطوبة',en:'Measure humidity'},{ar:'تحسين الإضاءة',en:'Improve lighting'}], c:1, x:{ar:'الجرامومتر: يُلبس لتسجيل التعرض الكلي للإشعاع لكل فرد بشكل مستمر.',en:'Dosimeter: worn to continuously record cumulative radiation dose for each individual.'}, d:3, type:'mcq'}
  ]},
  {id:'2.5',e:'oil',n:{ar:'الكيميائيات الخطرة',en:'Hazardous Chemicals'},i:'🧪',x:590,q:[
    {t:{ar:'الفرق بين LD50 وTD50؟',en:'What is the difference between LD50 and TD50?'},o:[{ar:'لا فرق',en:'No difference'},{ar:'LD50 تقتل 50%، TD50 تسبب مرض في 50%',en:'LD50 kills 50%, TD50 causes disease in 50%'},{ar:'LD50 أقل خطورة',en:'LD50 is less hazardous'},{ar:'TD50 أكثر',en:'TD50 is more hazardous'}],c:1,x:{ar:'LD50: قاتل 50%. TD50: مرضي 50%.',en:'LD50: Lethal dose for 50%. TD50: Toxic dose causing disease in 50%.'}, d:2, type:'mcq'},
    {t:{ar:'أهمية تصنيف GHS؟',en:'What is the importance of GHS classification?'},o:[{ar:'تسويق فقط',en:'Marketing only'},{ar:'تصنيف موحد عالمي يضمن التعامل الآمن',en:'Globally harmonized classification ensuring safe handling'},{ar:'تقليل التكلفة',en:'Cost reduction'},{ar:'تحسين المظهر',en:'Improved appearance'}],c:1,x:{ar:'GHS يُوحّد تصنيف المواد الخطرة عالمياً.',en:'GHS harmonizes the classification of hazardous substances globally.'}, d:1, type:'mcq'},
    {t:{ar:'ما هي طرق دخول المواد الكيميائية إلى الجسم؟',en:'What are the routes of chemical entry into the body?'},o:[{ar:'الاستنشاق فقط',en:'Inhalation only'},{ar:'استنشاق، ابتلاع، امتصاص جلدي، حقن',en:'Inhalation, ingestion, skin absorption, injection'},{ar:'النظر فقط',en:'Eye contact only'},{ar:'لا توجد طرق',en:'No routes exist'}],c:1,x:{ar:'طرق الدخول: استنشاق، ابتلاع، جلد، حقن، عيون.',en:'Entry routes: inhalation, ingestion, skin absorption, injection, eyes.'}, d:2, type:'mcq'},
    {t:{ar:'تقييم COSHH يتطلب تحديد',en:'A COSHH assessment requires identifying'}, a:{ar:['كل المواد الخطرة، مخاطرها، طرق التحكم، المراقبة الصحية'], en:['all hazardous substances, their hazards, control methods, and health surveillance']}, x:{ar:'COSHH: تحديد جميع المواد الخطرة، تقييم المخاطر، تحكمات، مراقبة صحية.',en:'COSHH: identify all hazardous substances, assess risks, implement controls, and arrange health surveillance.'}, d:1, type:'fill'},
    {t:{ar:'ما الفرق بين بطاقة بيانات السلامة (SDS) وملصق GHS؟',en:'What is the difference between a Safety Data Sheet (SDS) and a GHS label?'},o:[{ar:'لا فرق',en:'No difference'},{ar:'SDS: معلومات تفصيلية شاملة. الملصق: ملخص بصري سريع للخطر',en:'SDS: comprehensive detailed information. Label: quick visual hazard summary'},{ar:'الملصق أشمل',en:'The label is more comprehensive'},{ar:'SDS للتسويق',en:'SDS is for marketing'}],c:1,x:{ar:'SDS: 16 قسم معلومات تفصيلية. الملصق: ملخص مرئي للخطر والتعامل الآمن.',en:'SDS: 16 sections of detailed information. Label: visual summary of hazards and safe handling.'}, d:3, type:'mcq'}
  ]},
  {id:'2.6',e:'oil',n:{ar:'أمراض المهنة',en:'Occupational Diseases'},i:'🏥',x:710,q:[
    {t:{ar:'الفرق بين مرض المهنة وإصابة العمل؟',en:'What is the difference between an occupational disease and a work injury?'},o:[{ar:'لا فرق',en:'No difference'},{ar:'مرض المهنة: تدريجي مزمن. إصابة العمل: حادث مفاجئ',en:'Occupational disease: gradual/chronic. Work injury: sudden/acute accident'},{ar:'مرض المهنة أخطر',en:'Occupational disease is more dangerous'},{ar:'إصابة العمل تتطلب تقريراً فقط',en:'Work injury requires a report only'}],c:1,x:{ar:'مرض المهنة: تدريجي Chronic. إصابة العمل: حادث Acute.',en:'Occupational disease: gradual Chronic. Work injury: sudden Acute incident.'}, d:2, type:'mcq'},
    {t:{ar:'أمثلة على أمراض المهنة؟',en:'What are examples of occupational diseases?'},o:[{ar:'السقوط فقط',en:'Falls only'},{ar:'الصمم الصناعي، التليف الرئوي، الأمراض الجلدية',en:'Noise-induced hearing loss, pulmonary fibrosis, skin diseases'},{ar:'الحروق فقط',en:'Burns only'},{ar:'الكدمات فقط',en:'Bruises only'}],c:1,x:{ar:'أمراض مهنية: صمم، أمراض رئوية، جلدية، عضلية.',en:'Occupational diseases: hearing loss, pulmonary, dermatological, musculoskeletal disorders.'}, d:1, type:'mcq'},
    {t:{ar:'ما هي فترة الكمون (Latency Period) في أمراض المهنة؟',en:'What is the latency period in occupational diseases?'},o:[{ar:'فترة العلاج',en:'Treatment period'},{ar:'الفترة الزمنية بين التعرض للخطر المهني والظهور الفعلي للمرض',en:'The time between exposure to the occupational hazard and the actual onset of disease'},{ar:'فترة التوظيف',en:'Employment period'},{ar:'فترة الإجازة',en:'Leave period'}],c:1,x:{ar:'فترة الكمون: قد تمتد لسنوات أو عقود بين التعرض الأولي والظهور السريري.',en:'Latency period: can extend years or decades between initial exposure and clinical manifestation.'}, d:2, type:'mcq'},
    {t:{ar:'الفرق بين الإصابة المهنية ومرض المهنة من حيث الإبلاغ هو',en:'The difference between occupational injury and disease in reporting is'}, a:{ar:['الإصابة: تُبلغ فوراً. المرض: قد يُبلغ عند التشخيص الطبي بعد فترات طويلة'], en:['Injury: reported immediately. Disease: may be reported upon medical diagnosis after long periods']}, x:{ar:'الإصابة: إبلاغ فوري. المرض: يُكتشف متأخراً بسبب فترات الكمون الطويلة.',en:'Injury: immediate reporting. Disease: discovered late due to long latency periods.'}, d:1, type:'fill'},
    {t:{ar:'ما دور الطبيب المهني في كشف أمراض المهنة؟',en:'What is the role of the occupational physician in detecting occupational diseases?'},o:[{ar:'لا دور له',en:'No role'},{ar:'المتابعة الصحية الدورية، ربط المرض بالتعرض المهني، التوصية بإجراءات وقائية',en:'Periodic health monitoring, linking disease to occupational exposure, recommending preventive measures'},{ar:'العلاج فقط',en:'Treatment only'},{ar:'كتابة التقارير المالية',en:'Writing financial reports'}],c:1,x:{ar:'الطبيب المهني: مراقبة صحية، تشخيص، ربط مرض-تعرض، توصيات وقائية.',en:'Occupational physician: health monitoring, diagnosis, linking disease to exposure, preventive recommendations.'}, d:3, type:'mcq'}
  ]},
  {id:'2.7',e:'oil',n:{ar:'الحرارة والبرد',en:'Heat & Cold'},i:'🌡️',x:120,q:[
    {t:{ar:'علامات ضربات الشمس؟',en:'What are the signs of heatstroke?'},o:[{ar:'الفرح فقط',en:'Happiness only'},{ar:'صداع، دوخة، غثيان، احمرار، فقدان الوعي',en:'Headache, dizziness, nausea, redness, loss of consciousness'},{ar:'زيادة الطاقة',en:'Increased energy'},{ar:'لا علامات',en:'No signs'}],c:1,x:{ar:'ضربات شمس: صداع، دوخة، غثيان، حمراء، إغماء.',en:'Heatstroke: headache, dizziness, nausea, redness, fainting.'}, d:1, type:'mcq'},
    {t:{ar:'علاج إصابات البرد؟',en:'How are cold injuries treated?'},o:[{ar:'الماء الساخن فقط',en:'Hot water only'},{ar:'إعادة حرارة تدريجية، ملابس جافة، مشروبات دافئة',en:'Gradual rewarming, dry clothing, warm drinks'},{ar:'التجاهل',en:'Ignoring it'},{ar:'العمل بسرعة',en:'Working quickly'}],c:1,x:{ar:'علاج: حرارة تدريجية، ملابس جافة، مشروبات، مراقبة.',en:'Treatment: gradual rewarming, dry clothing, warm drinks, monitoring.'}, d:2, type:'mcq'},
    {t:{ar:'ما هي عوامل الخطر الرئيسية للإجهاد الحراري في بيئة العمل؟',en:'What are the key risk factors for heat stress in the workplace?'},o:[{ar:'الإضاءة فقط',en:'Lighting only'},{ar:'درجة الحرارة والرطوبة وسرعة الهواء والإشعاع الحراري',en:'Temperature, humidity, air speed, and radiant heat'},{ar:'الضوضاء فقط',en:'Noise only'},{ar:'لا توجد عوامل',en:'No factors exist'}],c:1,x:{ar:'عوامل الخطر: درجة الحرارة، الرطوبة، سرعة الهواء، الإشعاع، الجهد البدني.',en:'Risk factors: temperature, humidity, air velocity, radiant heat, physical exertion.'}, d:2, type:'mcq'},
    {t:{ar:'فترات الراحة والعمل المناسبة في البيئات الحارة تُحسب بـ',en:'Work-rest cycles in hot environments are determined by'}, a:{ar:['مؤشر حرارة الكرت المبلل (WBGT) ومستوى الجهد البدني'], en:['the Wet Bulb Globe Temperature (WBGT) index and the level of physical exertion']}, x:{ar:'فترات العمل-الراحة تعتمد على WBGT ومستوى الجهد البدني والتعود على الحرارة.',en:'Work-rest cycles depend on WBGT, physical exertion level, and heat acclimatization status.'}, d:1, type:'fill'},
    {t:{ar:'تأثير البرد الشديد على أداء العامل يشمل',en:'The effects of extreme cold on worker performance include'}, o:[{ar:'تحسن التركيز',en:'Improved focus'},{ar:'تقلص العضلات، انخفاض الدقة الحركية، بطء التفكير، تصلب المفاصل',en:'Muscle contraction, reduced motor precision, slower thinking, stiffened joints'},{ar:'زيادة الإنتاجية',en:'Increased productivity'},{ar:'تحسن المزاج',en:'Improved mood'}], c:1, x:{ar:'البرد: تقلص عضلي، بطء تفكير، تصلب مفاصل، انخفاض دقة الحركة، إرهاق.',en:'Cold: muscle spasms, slower cognition, stiff joints, reduced motor accuracy, fatigue.'}, d:3, type:'mcq'}
  ]},
  {id:'2.8',e:'oil',n:{ar:'الإجهاد المتكرر',en:'Repetitive Strain'},i:'🔄',x:230,q:[
    {t:{ar:'أمثلة على RSI؟',en:'What are examples of Repetitive Strain Injury (RSI)?'},o:[{ar:'السقوط',en:'Falls'},{ar:'التهاب الأوتار، نفق المعصم، التهاب الكتف',en:'Tendonitis, carpal tunnel syndrome, shoulder inflammation'},{ar:'الحروق',en:'Burns'},{ar:'الكدورات',en:'Bruises'}],c:1,x:{ar:'RSI: التهاب أوتار، نفق المعصب، التهاب مفاصل متكرر.',en:'RSI: tendonitis, carpal tunnel syndrome, repetitive joint inflammation.'}, d:1, type:'mcq'},
    {t:{ar:'كيف يُمنع RSI؟',en:'How is RSI prevented?'},o:[{ar:'بأكبر قوة',en:'With maximum force'},{ar:'فترات راحة، تصميم ergonomic، تمارين',en:'Rest breaks, ergonomic design, exercises'},{ar:'عدم العمل',en:'Not working'},{ar:'الراحة فقط',en:'Rest only'}],c:1,x:{ar:'وقاية: توقفات، تصميم ergonomic، تمارين إطالة.',en:'Prevention: breaks, ergonomic design, stretching exercises.'}, d:2, type:'mcq'},
    {t:{ar:'ما هي العوامل الميكانيكية المحيطة (Ergonomic Risk Factors) التي تسبب اضطرابات العضلات الهيكلية؟',en:'What are the ergonomic risk factors that cause musculoskeletal disorders?'},o:[{ar:'الإضاءة فقط',en:'Lighting only'},{ar:'تكرار، قوة، وضعية الجسد، ضغط الوقت',en:'Repetition, force, posture, and time pressure'},{ar:'الضوضاء فقط',en:'Noise only'},{ar:'الحرارة فقط',en:'Heat only'}],c:1,x:{ar:'عوامل: تكرار الحركة، قوة الزخم، وضعية الجسد غير الطبيعية، مدة التعرض.',en:'Factors: movement repetition, forceful exertions, awkward postures, and duration of exposure.'}, d:2, type:'mcq'},
    {t:{ar:'الأعراض المبكرة لاضطرابات الإجهاد المتكرر تشمل',en:'Early symptoms of repetitive strain injuries include'}, a:{ar:[' وخز، التنميل، آلام خفيفة، صعوبة قبض اليد في الصباح'], en:['tingling, numbness, mild pain, and difficulty gripping in the morning']}, x:{ar:'أعراض مبكرة: وخز، تنميل، آلام خفيفة عند التكرار، تيبس مفاصل صباحاً.',en:'Early symptoms: tingling, numbness, mild pain with repetition, morning joint stiffness.'}, d:1, type:'fill'},
    {t:{ar:'تقييم المخاطر الميكانيكية المحيطية في محطة العمل يتضمن',en:'An ergonomic workstation risk assessment includes'}, o:[{ar:'قياس الأرباح فقط',en:'Measuring profits only'},{ar:'تحليل الحركة، تقييم وضعية الجسد، فحص تصميم الأدوات والكرسي',en:'Motion analysis, posture assessment, tool and chair design evaluation'},{ar:'عدم التقييم',en:'No assessment needed'},{ar:'تقييم الميزانية',en:'Budget assessment'}], c:1, x:{ar:'تقييم ergonomic: تحليل حركة اليد، وضعية الجسد، تصميم المعدات، فترات الراحة.',en:'Ergonomic assessment: hand motion analysis, posture review, equipment design, rest interval evaluation.'}, d:3, type:'mcq'}
  ]},
  {id:'2.9',e:'oil',n:{ar:'الجروح والإصابات',en:'Wounds & Injuries'},i:'🩹',x:350,q:[
    {t:{ar:'أكثر أنواع الجروح شيوعاً؟',en:'What are the most common types of wounds?'},o:[{ar:'الحروق فقط',en:'Burns only'},{ar:'السحجات، القطع، السقوط، الدهس',en:'Abrasions, cuts, falls, crush injuries'},{ar:'لا توجد جروح',en:'No wounds'},{ar:'الغوص فقط',en:'Diving only'}],c:1,x:{ar:'أشهر الجروح: قطع، سحجات، سقوط، كدمات، دهس.',en:'Most common wounds: cuts, abrasions, falls, bruises, crush injuries.'}, d:1, type:'mcq'},
    {t:{ar:'أهمية الإسعافات الأولية؟',en:'What is the importance of first aid?'},o:[{ar:'ليس مهماً',en:'Not important'},{ar:'تقليل حدة الإصابة ومنع المضاعفات',en:'Reducing injury severity and preventing complications'},{ar:'زيادة التكلفة',en:'Increasing cost'},{ar:'تحسين المظهر',en:'Improving appearance'}],c:1,x:{ar:'الإسعافات: إنقاذ أرواح، تقليل أذى، منع تفاقم.',en:'First aid: saves lives, reduces harm, prevents complications.'}, d:2, type:'mcq'},
    {t:{ar:'ما الفرق بين أنواع النزيف (شرعي، شرياني، وريدي)؟',en:'What is the difference between the types of bleeding (arterial, venous, capillary)?'},o:[{ar:'لا فرق',en:'No difference'},{ar:'شرعي: أحمر نابض. وريدي: أحمر غامق مستمر. شعيري: بسيط',en:'Arterial: bright red pulsating. Venous: dark red flowing. Capillary: minor oozing'},{ar:'الكل متساوي',en:'All are the same'},{ar:'النزيف لا يختلف',en:'Bleeding does not differ'}],c:1,x:{ar:'الشرياني: أحمر فاتح نابضي (أخطر). الوريدي: أحمر غامق. الشعيري: سطحي.',en:'Arterial: bright red pulsating (most dangerous). Venous: dark red flowing. Capillary: superficial.'}, d:2, type:'mcq'},
    {t:{ar:'الحروق تُصنّف وفقاً لـ',en:'Burns are classified according to'}, a:{ar:['عمق إصابة الأنسجة: سطحية، سماكة، كاملة السماكة'], en:['depth of tissue damage: superficial, partial thickness, full thickness']}, x:{ar:'تصنيف الحروق: الدرجة الأولى (سطحية)، الثانية (فقاعات)، الثالثة (عميقة).',en:'Burn classification: first degree (superficial), second degree (blistering), third degree (deep).'}, d:1, type:'fill'},
    {t:{ar:'محتويات حقيبة الإسعافات الأولية الأساسية تشمل',en:'Essential first aid kit contents include'}, o:[{ar:'أدوات المطبخ فقط',en:'Kitchen utensils only'},{ar:'شاش، لاصقات، مقص، قفازات، مادة تعقيم، بطانيات حرارية',en:'Gauze, bandages, scissors, gloves, antiseptic, thermal blankets'},{ar:'الألعاب فقط',en:'Toys only'},{ar:'لا تحتاج محتويات',en:'No contents needed'}], c:1, x:{ar:'حقيبة الإسعاف: شاش، لاصقات، مقص، قفازات، معقم، بطانيات، دليل إسعاف.',en:'First aid kit: gauze, plasters, scissors, gloves, antiseptic, blankets, first aid guide.'}, d:3, type:'mcq'}
  ]},
  {id:'2.10',e:'oil',n:{ar:'التوتر والصحة النفسية',en:'Stress & Mental Health'},i:'😔',x:470,q:[
    {t:{ar:'علامات التوتر المزمن؟',en:'What are the signs of chronic stress?'},o:[{ar:'الحماس فقط',en:'Enthusiasm only'},{ar:'إرهاق مزمن، صعوبة نوم، تقلبات مزاجية',en:'Chronic fatigue, difficulty sleeping, mood swings'},{ar:'نشاط زائد',en:'Excessive activity'},{ar:'ثقة زائدة',en:'Overconfidence'}],c:1,x:{ar:'علامات: إرهاق، أرق، تقلبات، فقدان حافز، صداع مزمن.',en:'Signs: fatigue, insomnia, mood swings, loss of motivation, chronic headaches.'}, d:2, type:'mcq'},
    {t:{ar:'كيف تساعد المنظمات؟',en:'How do organizations help?'},o:[{ar:'زيادة العمل',en:'Increasing workload'},{ar:'برامج دعم، بيئة داعمة، توازن عمل-حياة',en:'Support programs, supportive environment, work-life balance'},{ar:'عزل فقط',en:'Isolation only'},{ar:'تجاهل',en:'Ignoring'}],c:1,x:{ar:'مساعدة: برامج EAP، إرشاد، مرونة عمل، بيئة إيجابية.',en:'Help: EAP programs, counselling, work flexibility, positive environment.'}, d:2, type:'mcq'},
    {t:{ar:'ما هي خطوات الإسعاف النفسي الأولي (Mental Health First Aid) في العمل؟',en:'What are the steps of workplace Mental Health First Aid?'},o:[{ar:'تجاهل المشكلة',en:'Ignore the problem'},{ar:'التقييم الأولي، الاستماع ohne حكم، الإحالة للمساعدات المتخصصة',en:'Initial assessment, non-judgemental listening, referral to professional services'},{ar:'العقاب',en:'Punishment'},{ar:'العزل',en:'Isolation'}],c:1,x:{ar:'خطوات: تقييم، استماع، دعم، إحالة لمساعدات متخصصة.',en:'Steps: assess, listen without judgement, provide support, refer to professional services.'}, d:2, type:'mcq'},
    {t:{ar:'المعايير الإدارية الستة لإدارة الضغط النفسي التي وضعتها HSE هي',en:'The six HSE Management Standards for stress are'}, a:{ar:['الطلب، السيطرة، الدعم، علاقات العمل، الدور، التغيير'], en:['Demands, Control, Support, Relationships, Role, Change']}, x:{ar:'المعايير الستة: طلب العمل، السيطرة على العمل، الدعم، علاقات العمل، الدور، التغيير التنظيمي.',en:'The six standards: Demands, Control, Support, Relationships, Role, Change.'}, d:1, type:'fill'},
    {t:{ar:'تأثير الغياب المتكرر المرتبط بالصحة النفسية على المنظمة يشمل',en:'The impact of mental health-related absenteeism on the organisation includes'}, o:[{ar:'تحسن الإنتاجية',en:'Improved productivity'},{ar:'زيادة العبء على الزملاء، تكاليف بديلة، انخفاض معنويات الفريق',en:'Increased burden on colleagues, replacement costs, reduced team morale'},{ar:'عدم تأثير',en:'No impact'},{ar:'تحسن جودة العمل',en:'Improved work quality'}], c:1, x:{ar:'الغياب: زيادة العبء على الزملاء، تكاليف بديلة، انخفاض معنويات، فقدان خبرة.',en:'Absenteeism: increased colleague burden, cover costs, reduced morale, loss of experience.'}, d:3, type:'mcq'}
  ]},
  {id:'2.11',e:'oil',n:{ar:'المخاطر البيولوجية',en:'Biological Hazards'},i:'🦠',x:590,q:[
    {t:{ar:'المخاطر البيولوجية؟',en:'What are biological hazards?'},o:[{ar:'الحشرات فقط',en:'Insects only'},{ar:'بكتيريا، فيروسات، فطريات، نفايات طبية',en:'Bacteria, viruses, fungi, medical waste'},{ar:'لا توجد',en:'None'},{ar:'النباتات فقط',en:'Plants only'}],c:1,x:{ar:'مخاطر: كائنات حية، نفايات طبية، مزارع، مختبرات.',en:'Hazards: living organisms, medical waste, farms, laboratories.'}, d:1, type:'mcq'},
    {t:{ar:'كيف تُتعامل معها؟',en:'How are they managed?'},o:[{ar:'عدم الارتداد فقط',en:'Not wearing PPE only'},{ar:'تطعيمات، PPE، تعقيم، إدارة نفايات',en:'Vaccinations, PPE, decontamination, waste management'},{ar:'تجاهل',en:'Ignoring'},{ar:'هروب',en:'Fleeing'}],c:1,x:{ar:'تعامل: تطعيم، PPE، تعقيم، إدارة نفايات، بروتوكولات.',en:'Management: vaccination, PPE, decontamination, waste management, protocols.'}, d:2, type:'mcq'},
    {t:{ar:'ما هي طرق انتقال المخاطر البيولوجية إلى العامل؟',en:'What are the transmission routes of biological hazards to workers?'},o:[{ar:'الاتصال المباشر فقط',en:'Direct contact only'},{ar:'اتصال مباشر، استنشاق، تلوث غذائي، لدغ/عض',en:'Direct contact, inhalation, food contamination, bites/stings'},{ar:'النظر فقط',en:'Visual contact only'},{ar:'لا توجد طرق انتقال',en:'No transmission routes'}],c:1,x:{ar:'طرق الانتقال: ملامسة مباشرة، استنشاق، طعام ملوث، لدغ حشرات، جروح.',en:'Transmission: direct contact, inhalation, contaminated food, insect bites, wounds.'}, d:2, type:'mcq'},
    {t:{ar:'تصنيف المخاطر البيولوجية وفقاً لـ WHO يعتمد على',en:'The WHO classification of biological hazards is based on'}, a:{ar:['مستوى المخاطر والعلاج المتوفر والتطعيمات المتاحة'], en:['level of hazard, availability of treatment, and available vaccines']}, x:{ar:'تصنيف WHO: 4 مستويات (منخفض → عالي) بناءً على خطورة المرض وطرق العلاج.',en:'WHO classification: 4 risk levels (low to high) based on disease severity and treatment options.'}, d:1, type:'fill'},
    {t:{ar:'إجراءات التعامل مع التسربات البيولوجية (Biological Spills) تتضمن',en:'Procedures for handling biological spills include'}, o:[{ar:'المسح بالماء فقط',en:'Wipe with water only'},{ar:'عزل المنطقة، ارتداء معدات، تعقيم، توثيق، التخلص الآمن',en:'Isolate area, wear equipment, decontaminate, document, safe disposal'},{ar:'تجاهل',en:'Ignore'},{ar:'المسح بفوط عادية',en:'Wipe with ordinary cloth'}], c:1, x:{ar:'معالجة التسرب: عزل المنطقة، PPE، مادة تعقيم مناسبة، توثيق، تخلص آمن.',en:'Spill response: isolate, PPE, appropriate disinfectant, documentation, safe disposal.'}, d:3, type:'mcq'}
  ]},
  {id:'2.12',e:'oil',n:{ar:'المخاطر السيكولوجية',en:'Psychological Hazards'},i:'😰',x:710,q:[
    {t:{ar:'المخاطر السيكولوجية غير المادية؟',en:'What are non-physical psychological hazards?'},o:[{ar:'الجو فقط',en:'Weather only'},{ar:'تنمر، تمييز، حمل عمل زائد، انعدام سيطرة',en:'Bullying, discrimination, excessive workload, lack of control'},{ar:'الرواتب فقط',en:'Salaries only'},{ar:'لا توجد',en:'None'}],c:1,x:{ar:'مخاطر: تنمر، تمييز، حمل عمل، فقدان سيطرة، صراع.',en:'Hazards: bullying, discrimination, workload, loss of control, conflict.'}, d:2, type:'mcq'},
    {t:{ar:'تأثيرها على الصحة؟',en:'What is their effect on health?'},o:[{ar:'لا تأثير',en:'No effect'},{ar:'اضطرابات نفسية وجسدية، انخفاض أداء',en:'Psychological and physical disorders, reduced performance'},{ar:'تحسن صحة',en:'Improved health'},{ar:'زيادة طاقة',en:'Increased energy'}],c:1,x:{ar:'تأثير: قلق، اكتئاب، اضطرابات نوم، مشاكل هضمية.',en:'Effects: anxiety, depression, sleep disorders, digestive problems.'}, d:2, type:'mcq'},
    {t:{ar:'ما هي علامات التنمر في مكان العمل (Workplace Bullying)؟',en:'What are the signs of workplace bullying?'},o:[{ar:'التعاون فقط',en:'Cooperation only'},{ar:'استبعاد متكرر، إهانة علنية، تكليف بأعمال مهينة، تجاهل مقصود',en:'Repeated exclusion, public humiliation, demeaning tasks, deliberate ignoring'},{ar:'المدح الزائد',en:'Excessive praise'},{ar:'المنافسة الصحية',en:'Healthy competition'}],c:1,x:{ar:'تنمر: استبعاد، إهانة، حمل عمل مفرط، تهميش، تهديدات غير مباشرة.',en:'Bullying: exclusion, humiliation, excessive workload, marginalisation, veiled threats.'}, d:2, type:'mcq'},
    {t:{ar:'تقييم المخاطر السيكولوجية في العمل يتطلب',en:'Assessing psychosocial hazards at work requires'}, a:{ar:['استبيانات، مقابلات، تحليل بيانات الغياب، ملاحظة السلوك'], en:['surveys, interviews, absence data analysis, and behavioural observation']}, x:{ar:'تقييم سيكولوجي: استبيانات رضا، تحليل غياب، مقابلات مراقبة، ملاحظة.',en:'Psychosocial assessment: satisfaction surveys, absence analysis, surveillance interviews, observation.'}, d:1, type:'fill'},
    {t:{ar:'تأثير العمل بالورديات (Shift Work) على الصحة النفسية يشمل',en:'The impact of shift work on mental health includes'}, o:[{ar:'تحسن النوم',en:'Improved sleep'},{ar:'اضطراب إيقاع الأكل، أرق، تعب مزمن، انزوا عائلي واجتماعي',en:'Disrupted eating patterns, insomnia, chronic fatigue, family and social isolation'},{ar:'تحسن التركيز',en:'Improved focus'},{ar:'لا تأثير',en:'No effect'}], c:1, x:{ar:'الورديات: اضطراب نوم، أرق، عزل اجتماعي، مشاكل هضمية، إرهاق مزمن.',en:'Shift work: sleep disruption, insomnia, social isolation, digestive problems, chronic fatigue.'}, d:3, type:'mcq'}
  ]},
  {id:'2.13',e:'oil',n:{ar:'الإشعاع غير الأيوني',en:'Non-ionizing Radiation'},i:'💡',x:120,q:[
    {t:{ar:'أنواع الإشعاع غير الأيوني؟',en:'What are the types of non-ionizing radiation?'},o:[{ar:'السلفية فقط',en:'Incandescent only'},{ar:'UV، ليزر، IR، ميكروويف',en:'UV, laser, infrared, microwave'},{ar:'الضوء فقط',en:'Light only'},{ar:'لا يوجد',en:'None'}],c:1,x:{ar:'غير أيوني: UV، ليزر، IR، ميكروويف، حقول كهربائية.',en:'Non-ionizing: UV, laser, infrared, microwave, electric fields.'}, d:1, type:'mcq'},
    {t:{ar:'كيف تُمنع أضرار الليزر؟',en:'How are laser hazards prevented?'},o:[{ar:'عدم النظر فقط',en:'Not looking only'},{ar:'نظارات حماية، حجب، تحكم طاقة، تعليم',en:'Protective eyewear, shielding, energy control, training'},{ar:'العدسة فقط',en:'Lenses only'},{ar:'الظلام فقط',en:'Darkness only'}],c:1,x:{ar:'حماية: نظارات، تحكم طاقة، حجب، تعليم، إنذارات.',en:'Protection: eyewear, energy control, shielding, training, warnings.'}, d:2, type:'mcq'},
    {t:{ar:'ما هي أضرار الأشعة فوق البنفسجية (UV) على الجلد والعيون؟',en:'What are the effects of UV radiation on skin and eyes?'},o:[{ar:'لا أضرار',en:'No harm'},{ar:'حروق شمسية، تلف الجلد المزمن، إعتام عدسة العين، التهاب القرنية',en:'Sunburn, chronic skin damage, cataracts, and corneal inflammation'},{ar:'تحسن البصر',en:'Improved vision'},{ar:'تحسن البشرة',en:'Improved skin'}],c:1,x:{ar:'UV: حروق، شيخوخة جلدية مبكرة، سرطان جلد، إعتام عدسة، التهاب قرنية.',en:'UV: burns, premature skin ageing, skin cancer, cataracts, and corneal inflammation (arc eye).'}, d:2, type:'mcq'},
    {t:{ar:'الحد المسموح به للأشعة فوق البنفسجية (UV) في بيئة العمل يُعتمد على',en:'The acceptable UV exposure limit in the workplace depends on'}, a:{ar:['طول الموجة UV وطول فترة التعرض'], en:['the UV wavelength and the duration of exposure']}, x:{ar:'حد UV يعتمد على طول الموجة (UVA, UVB, UVC) ومدة التعرض المتواصل.',en:'UV limits depend on wavelength (UVA, UVB, UVC) and continuous exposure duration.'}, d:1, type:'fill'},
    {t:{ar:'الألياف الضوئية (Fibre Optics) تُفضل في بيئات الخطر لأنها',en:'Fibre optics are preferred in hazardous environments because they'}, o:[{ar:'أرخص',en:'Are cheaper'},{ar:'لا تنقل الكهرباء ولا تُسبب شرارات في الأجواء المتفجرة',en:'Do not carry electricity and do not produce sparks in explosive atmospheres'},{ar:'أسهل في التركيب',en:'Easier to install'},{ar:'أقوى',en:'Are stronger'}], c:1, x:{ar:'الألياف الضوئية: لا تنقل تياراً كهربائياً، آمنة في أجواء متفجرة.',en:'Fibre optics: no electrical current, safe in explosive atmospheres (no spark risk).'}, d:3, type:'mcq'}
  ]},
  {id:'2.14',e:'oil',n:{ar:'الإجهاد الحراري المتقدم',en:'Advanced Heat Stress'},i:'🔥',x:230,q:[
    {t:{ar:'مخاطر العمل في البيئات الحارة؟',en:'What are the hazards of working in hot environments?'},o:[{ar:'الراحة فقط',en:'Rest only'},{ar:'إجهاد شمسي، جفاف، انخفاض ضغط، انخفاض أداء',en:'Heatstroke, dehydration, low blood pressure, reduced performance'},{ar:'زيادة طاقة',en:'Increased energy'},{ar:'لا مخاطر',en:'No hazards'}],c:1,x:{ar:'مخاطر: إجهاد شمسي، جفاف، دوخة، انخفاض أداء.',en:'Hazards: heatstroke, dehydration, dizziness, reduced performance.'}, d:1, type:'mcq'},
    {t:{ar:'تدابير الوقاية المتقدمة؟',en:'What are advanced preventive measures?'},o:[{ar:'عدم الشرب',en:'Not drinking'},{ar:'إجازات منتظمة، تكييف، مراقبة طبية، نظام تحذير',en:'Regular breaks, air conditioning, medical monitoring, warning system'},{ar:'عمل ليلي فقط',en:'Night work only'},{ar:'عدم ارتداء ملابس',en:'Not wearing clothing'}],c:1,x:{ar:'وقاية: إجازات، تكييف، مراقبة، نظام تحذير مبكر.',en:'Prevention: breaks, air conditioning, monitoring, early warning system.'}, d:2, type:'mcq'},
    {t:{ar:'ما هي عملية التعود على الحرارة (Heat Acclimatization) وما مدة تتطلبها؟',en:'What is heat acclimatization and how long does it take?'}, o:[{ar:'عدم التعود مطلقاً',en:'No acclimatization needed'},{ar:'عملية تدريجية لتعود الجسم على الحرارة تستغرق 7-14 يوماً',en:'A gradual process of adapting the body to heat, taking 7-14 days'},{ar:'يوم واحد فقط',en:'One day only'},{ar:'شهر كامل',en:'A full month'}],c:1,x:{ar:'التعود على الحرارة: عملية تدريجية 7-14 يوماً مع زيادة تدريجية في التعرض.',en:'Heat acclimatization: a 7-14 day gradual increase in heat exposure.'}, d:2, type:'mcq'},
    {t:{ar:'تعويض السوائل والأملاح المعدنية للعامل في البيئة الحارة يتطلب',en:'Fluid and electrolyte replacement for workers in hot environments requires'}, a:{ar:['شرب منتظم وليس فقط عند العطش، وتعويض الأملاح المفقودة بالعرق'], en:['regular drinking not only when thirsty, and replacing salts lost through sweat']}, x:{ar:'الترطيب: شرب منتظام كل 15-20 دقيقة + ماء + أملاح معدنية.',en:'Hydration: drink every 15-20 minutes + water + mineral salts lost in sweat.'}, d:1, type:'fill'},
    {t:{ar:'نظام الإنذار المبكر للإجهاد الحراري في بيئة العمل يعمل بـ',en:'An early warning system for heat stress in the workplace works by'}, o:[{ar:'انتظار ظهور الأعراض',en:'Waiting for symptoms to appear'},{ar:'مراقبة مستمرة لمؤشر WBGT وتطبيق بروتوكولات التدخل عند العتبات',en:'Continuous WBGT monitoring and triggering intervention protocols at thresholds'},{ar:'عدم المراقبة',en:'No monitoring'},{ar:'الاعتماد على شكاوى العمال فقط',en:'Relying only on worker complaints'}], c:1, x:{ar:'الإنذار المبكر: قياس WBGT مستمر + بروتوكولات تدخل عند تجاوز العتبات.',en:'Early warning: continuous WBGT measurement + intervention protocols when thresholds are exceeded.'}, d:3, type:'mcq'}
  ]},
  {id:'2.15',e:'oil',n:{ar:'التقييم الصحي المهني',en:'Occupational Health Assessment'},i:'📋',x:350,q:[
    {t:{ar:'ما هو التقييم الصحي المهني (OHA)؟',en:'What is an Occupational Health Assessment (OHA)?'},o:[{ar:'فحص دوري فقط',en:'Periodic examination only'},{ar:'تقييم شامل: تاريخ طبي، تExpose، مراقبة',en:'Comprehensive assessment: medical history, exposure assessment, surveillance'},{ar:'فحص عيون فقط',en:'Eye examination only'},{ar:'قياس طول فقط',en:'Height measurement only'}],c:1,x:{ar:'OHA: تاريخ طبي، تقييم تعرض، مراقبة صحية، إرشاد.',en:'OHA: medical history, exposure assessment, health surveillance, counselling.'}, d:2, type:'mcq'},
    {t:{ar:'متى يُطلب التقييم؟',en:'When is the assessment required?'},o:[{ar:'عند التوظيف فقط',en:'At recruitment only'},{ar:'قبل التعيين، أثناء العمل، عند التعرض للخطر، بعد الحادث',en:'Pre-employment, during work, after hazardous exposure, after an incident'},{ar:'عند المغادرة فقط',en:'At departure only'},{ar:'أبداً',en:'Never'}],c:1,x:{ar:'متطلبات: توظيف، تعرض خطر، حادث، شكاوى صحية.',en:'Requirements: recruitment, hazardous exposure, incident, health complaints.'}, d:2, type:'mcq'},
    {t:{ar:'ما هو شهادة اللياقة للعمل (Fitness for Work Certificate) وما أهميته؟',en:'What is a fitness for work certificate and why is it important?'}, o:[{ar:'شهادة تعليمية',en:'An educational certificate'},{ar:'تقرير طبي يؤكد قدرة العامل على أداء وظيفته بأمان دون خطر على صحته أو غيره',en:'A medical report confirming a worker can safely perform their role without risk to themselves or others'},{ar:'شهادة مالية',en:'A financial certificate'},{ar:'إجازة مرضية',en:'A sick leave certificate'}],c:1,x:{ar:'شهادة اللياقة: تأكيد طبي على القدرة على العمل بأمان مع مراعاة طبيعة العمل.',en:'Fitness certificate: medical confirmation of safe ability to work, considering the nature of the job.'}, d:2, type:'mcq'},
    {t:{ar:'الفحص الطبي قبل التعيين (Pre-employment Medical) يشمل',en:'A pre-employment medical examination includes'}, a:{ar:['تاريخ طبي، فحص جسدي، فحوصات مخبرية مناسبة لطبيعة العمل'], en:['medical history, physical examination, and laboratory tests appropriate to the role']}, x:{ar:'قبل التعيين: تاريخ طبي، فحص جسدي، فحوصات خاصة (سمع، رئة، دم) حسب الخطر.',en:'Pre-employment: medical history, physical exam, specific tests (hearing, lung, blood) depending on hazards.'}, d:1, type:'fill'},
    {t:{ar:'سجلات المراقبة الصحية المهنية يجب أن تُحفظ لمدة',en:'Occupational health surveillance records must be retained for'}, o:[{ar:'سنة واحدة فقط',en:'One year only'},{ar:'المدة المطلوبة قانونياً عادة 40 سنة أو طوال فترة التعرض',en:'The legally required period, typically 40 years or for the duration of exposure'},{ar:'لا حاجة لحفظ',en:'No retention needed'},{ar:'إلى الأبد',en:'Indefinitely'}], c:1, x:{ar:'السجلات الصحية: تُحفظ 40+ سنة لاكتشاف أمراض مهنية متأخرة.',en:'Health records: retained 40+ years for detecting late-onset occupational diseases.'}, d:3, type:'mcq'}
  ]},

  // OFFSHORE — NEBOSH ID3 (12 stations)
  {id:'3.1',e:'sea',n:{ar:'الأدوات والآلات',en:'Tools & Equipment'},i:'🔧',x:120,q:[
    {t:{ar:'مبادئ السلامة عند استخدام الأدوات اليدوية؟',en:'What are the safety principles for using hand tools?'},o:[{ar:'استخدام أي أداة',en:'Use any tool'},{ar:'اختيار مناسب، فحص، صيانة، تخزين',en:'Proper selection, inspection, maintenance, storage'},{ar:'استخدام الأقوى دائماً',en:'Always use the most powerful one'},{ar:'عدم الفحص',en:'No inspection needed'}],c:1,x:{ar:'مبادئ: اختيار مناسب، فحص دوري، صيانة، تخزين صحيح.',en:'Principles: proper selection, periodic inspection, maintenance, correct storage.'}, d:1, type:'mcq'},
    {t:{ar:'أهمية فحص الأدوات؟',en:'Why is tool inspection important?'},o:[{ar:'ليس مهماً',en:'Not important'},{ar:'اكتشاف التالف قبل أن يسبب حادثاً',en:'To detect defects before they cause an incident'},{ar:'زيادة الوقت',en:'To waste time'},{ar:'تحسين المظهر',en:'To improve appearance'}],c:1,x:{ar:'الفحص يكشف العيوب قبل أن تسبب إصابة.',en:'Inspection detects defects before they cause injury.'}, d:2, type:'mcq'},
    {t:{ar:'متى تتم معايرة مفتاح العزم؟',en:'When should a torque wrench be calibrated?'},o:[{ar:'أبداً',en:'Never'},{ar:'دورياً حسب جدول الصيانة وعند أي سقوط أو صدمة',en:'Periodically per maintenance schedule and after any drop or impact'},{ar:'عند الشراء فقط',en:'Only at purchase'},{ar:'مرة في العمر',en:'Once in a lifetime'}],c:1,x:{ar:'المعايرة الدورية + بعد أي سقوط أو صدمة ضرورية لضمان دقة العزم.',en:'Periodic calibration plus after any drop or shock is essential to ensure torque accuracy.'}, d:2, type:'mcq'},
    {t:{ar:'الأدوات الهوائية تتطلب على خط الهواء',en:'Pneumatic tools require on the air supply line'}, a:{ar:['فلتر ومزيل رطوبة وشريحة زيت'], en:['a filter, moisture trap, and oiler']}, x:{ar:'خط الهواء: فلتر يمنع الأوساخ، مزيل الرطوبة يمنع الماء، شريحة الزيت تشحم الأداة.',en:'The air line needs: filter to remove debris, moisture trap to remove water, and oiler to lubricate the tool.'}, d:1, type:'fill'},
    {t:{ar:'نظام ترميز ألوان الأدوات في المناطق الخطرة على المنصات؟',en:'What is the tool color coding system in offshore hazardous areas?'},o:[{ar:'لا يوجد نظام معتمد',en:'No standard system exists'},{ar:'أحمر لdangerous، أصفر لـ-inspect، أخضر لـ-safe',en:'Red for dangerous, yellow for inspection needed, green for safe to use'},{ar:'اللون العشوائي',en:'Random colors'},{ar:'الأسود والלבן فقط',en:'Black and white only'}],c:1,x:{ar:'ترميز: أحمر (خطير/معطّل)، أصفر (يحتاج فحص)، أخضر (آمن للاستخدام).',en:'Color coding: red (dangerous/defective), yellow (needs inspection), green (safe to use).'}, d:2, type:'mcq'}
  ]},
  {id:'3.2',e:'sea',n:{ar:'الرافعات',en:'Cranes & Lifting'},i:'🏗️',x:220,q:[
    {t:{ar:'القواعد الذهبية للرافعات؟',en:'What are the golden rules for cranes?'},o:[{ar:'الحزم فقط',en:'Lashing only'},{ar:'التحقق من الحمولة، Zones محظورة، لا مرور تحتها',en:'Load check, exclusion zones, no personnel underneath'},{ar:'عدم الاستخدام',en:'Do not use'},{ar:'السرعة القصوى',en:'Maximum speed'}],c:1,x:{ar:'قواعد: فحص حمولة، منع مرور تحتها، اتصال، مراقبة.',en:'Rules: load verification, exclusion zones, no under-hook access, continuous monitoring.'}, d:2, type:'mcq'},
    {t:{ar:'متى يُمنع تشغيل الرافعة؟',en:'When is crane operation prohibited?'},o:[{ar:'في الليل فقط',en:'At night only'},{ar:'رياح عالية، عطل، عدم تأهيل، حمولة زائدة',en:'High winds, malfunction, operator disqualification, overloaded'},{ar:'دائماً',en:'Always'},{ar:'في العطلات فقط',en:'During holidays only'}],c:1,x:{ar:'منع: رياح عالية، عطل، عدم تأهيل، حمولة زائدة.',en:'Prohibited: high winds, malfunction, unqualified operator, overloading.'}, d:2, type:'mcq'},
    {t:{ar:'متى تُستخدم Tagline أثناء الرفع؟',en:'When are taglines used during lifting?'},o:[{ar:'عندما تريد فقط',en:'When you want'},{ar:'دائماً لتوجيع الحمولة ومنع الدوران',en:'Always to guide the load and prevent swinging'},{ar:'فقط للأحمال الصغيرة',en:'Only for light loads'},{ar:'لا حاجة لها',en:'Not needed'}],c:1,x:{ar:'Tagline ضرورية دائماً لتوجيع الحمولة ومنع الدوران دون لمسها باليد.',en:'Taglines are always necessary to guide the load and prevent rotation without hand contact.'}, d:2, type:'mcq'},
    {t:{ar:'شهادة تأهيل مشغّل الرافعة تُعرف بـ',en:'Crane operator certification is known as'}, a:{ar:['CCS أو CPCS أو ما يعادلها حسب الدولة'], en:['CCS or CPCS or equivalent depending on the country']}, x:{ar:'شهادة CPCS (UK) أو CCS: إثبات تأهيل مشغّل الرافعة بإمكانيات عملية ونظرية.',en:'CPCS (UK) or CCS certification: demonstrates operator competency through practical and theoretical assessment.'}, d:1, type:'fill'},
    {t:{ar:'ما الذي يجب أن يتضمن خطة الرفع (Lift Plan)؟',en:'What should a lift plan include?'},o:[{ar:'الحمولة فقط',en:'Load details only'},{ar:'الحمولة، نقطة الارتكاز، مسارات، طقس، معدات، أفراد',en:'Load, centre of gravity, paths, weather, equipment, personnel'},{ar:'لا حاجة لخطة',en:'No plan needed'},{ar:'الميزانية فقط',en:'Budget only'}],c:1,x:{ar:'خطة الرفع: تفاصيل الحمولة، CG، مسارات، ظروف، معدات، أفراد، تدابير طوارئ.',en:'Lift plan: load details, centre of gravity, routes, conditions, equipment, personnel, emergency measures.'}, d:3, type:'mcq'}
  ]},
  {id:'3.3',e:'sea',n:{ar:'الارتفاعات',en:'Working at Heights'},i:'🪜',x:320,q:[
    {t:{ar:'الحماية الأساسية ضد السقوط من الارتفاعات؟',en:'What is the primary protection against falls from height?'},o:[{ar:'عدم الصعود فقط',en:'Do not climb'},{ar:'سياجات، شبكات، أنظمة احتواء، معدات شخصية، تعليم',en:'Guardrails, nets, containment systems, PPE, training'},{ar:'القفز فقط',en:'Jump only'},{ar:'عدم النظر',en:'Do not look down'}],c:1,x:{ar:'حماية: سياجات، شبكات، معدات حماية، تعليم، تصميم.',en:'Protection: guardrails, nets, personal fall protection, training, design.'}, d:1, type:'mcq'},
    {t:{ar:'أهمية Harness ضد السقوط؟',en:'Why is a fall arrest harness important?'},o:[{ar:'للمظهر فقط',en:'For appearance only'},{ar:'يمنع السقوط أو يخفف الأثر',en:'Prevents or mitigates the impact of a fall'},{ar:'يزيد السقوط',en:'Increases the fall'},{ar:'لا أهمية',en:'Not important'}],c:1,x:{ar:'Harness يمنع السقوط أو يخفف الأثر عبر امتصاص الطاقة.',en:'A harness prevents a fall or reduces impact through energy absorption.'}, d:2, type:'mcq'},
    {t:{ar:'الفرق بين نظام الحماية من السقوط ونظام الاقتران؟',en:'What is the difference between fall arrest and fall restraint?'},o:[{ar:'لا فرق',en:'No difference'},{ar:'الاقتران: يمنع الوصول للحافة. الحماية: يوقف السقوط بعد وقوعه',en:'Restraint: prevents reaching the edge. Arrest: stops the fall after it occurs'},{ar:'الاقتران أخطر',en:'Restraint is more dangerous'},{ar:'الحماية أقل فعالية',en:'Arrest is less effective'}],c:1,x:{ar:'الاقتران (Restraint): يمنع الوصول للحافة. الحماية (Arrest): يوقف السقوط ويامتص الطاقة.',en:'Restraint prevents reaching the fall edge. Arrest stops a fall in progress and absorbs energy.'}, d:2, type:'mcq'},
    {t:{ar:'.inspect the scaffold before use requires',en:'Inspect the scaffold before use requires'}, a:{ar:['فحص بصري من شخص مؤهل قبل كل نوبة و بعد ظروف طقس سيئة'], en:['visual inspection by a competent person before each shift and after adverse weather']}, x:{ar:'فحص السقالة: من شخص مؤهل، قبل كل استخدام، وبعد رياح/أمطار.',en:'Scaffold inspection: by a competent person, before each use, and after adverse weather conditions.'}, d:1, type:'fill'},
    {t:{ar:'زاوية السلّم الآمنة هي',en:'The safe ladder angle is'},o:[{ar:'60 درجة',en:'60 degrees'},{ar:'75 درجة (نسبة 1:4)',en:'75 degrees (1 in 4 ratio)'},{ar:'45 درجة',en:'45 degrees'},{ar:'90 درجة',en:'90 degrees'}],c:1,x:{ar:'زاوية السلّم الآمنة: 75 درجة (نسبة 1:4). قاعدة السلّم تبعد عن الجدار بمسافة ثلث الارتفاع.',en:'Safe ladder angle: 75 degrees (1 in 4 ratio). The base should be one-quarter of the working height from the wall.'}, d:2, type:'mcq'}
  ]},
  {id:'3.4',e:'sea',n:{ar:'الحرائق والانفجارات',en:'Fire & Explosions'},i:'🔥',x:420,q:[
    {t:{ar:'مثلث الحريق؟',en:'What are the three elements of the fire triangle?'},o:[{ar:'الماء والرمل والرذاذ',en:'Water, sand, and mist'},{ar:'الوقود + الأكسجين + الحرارة',en:'Fuel + Oxygen + Heat'},{ar:'الهواء والماء والنار',en:'Air, water, and fire'},{ar:'لا يوجد',en:'Does not exist'}],c:1,x:{ar:'مثلث: وقود + أكسجين + حرارة. إزالة أي عنصر تُخمّد النار.',en:'Triangle: fuel + oxygen + heat. Removing any element extinguishes the fire.'}, d:1, type:'mcq'},
    {t:{ar:'الفرق بين الحريق الكهربائي والكيميائي؟',en:'What is the difference between electrical and chemical fires?'},o:[{ar:'لا فرق',en:'No difference'},{ar:'الكهربائي: مصدر كهرباء. الكيميائي: تفاعل كيميائي',en:'Electrical: electrical source. Chemical: chemical reaction'},{ar:'الكهربائي أبسط',en:'Electrical is simpler'},{ar:'الكيميائي أخطر',en:'Chemical is more dangerous'}],c:1,x:{ar:'الكهربائي: طاقة كهربائية. الكيميائي: تفاعل كيميائي قابل للاحتراق.',en:'Electrical: electrical energy source. Chemical: combustible chemical reaction.'}, d:2, type:'mcq'},
    {t:{ar:'أي طفاية تُستخدم لحريق كهربائي؟',en:'Which extinguisher is used on an electrical fire?'},o:[{ar:'الماء فقط',en:'Water only'},{ar:'طفاية CO2 أو порошك جاف لأنها غير موصلة للكهرباء',en:'CO2 or dry powder extinguisher as they are non-conductive'},{ar:'الرغوة فقط',en:'Foam only'},{ar:'الرمل فقط',en:'Sand only'}],c:1,x:{ar:'حريق كهربائي: CO2 أو بودرة جافة (غير موصلة). لا تستخدم ماء أو رغوة.',en:'Electrical fire: CO2 or dry powder (non-conductive). Never use water or foam.'}, d:2, type:'mcq'},
    {t:{ar:'الحد الأدنى للconição المتفجرة (LEM) هو',en:'The Lower Explosive Limit (LEL) is'}, a:{ar:['أدنى تركيز للغاز في الهواء يمكن اشتعاله'], en:['the minimum concentration of gas in air that can ignite']}, x:{ar:'LEL: أدنى تركيز قابل للاشتعال. UEL: أعلى تركيز. بينهما منطقة الخطر.',en:'LEL: minimum flammable concentration. UEL: maximum. Between them is the danger zone.'}, d:1, type:'fill'},
    {t:{ar:'ما هو مخمّس الحريق (Fire Pentagon)؟',en:'What is the fire pentagon?'},o:[{ar:'5 أنواع حريق',en:'5 types of fire'},{ar:'مثلث الحريق + تفاعل كيميائي ذاتي + الطاقة',en:'Fire triangle + self-sustaining chemical reaction + energy'},{ar:'5 طفايات',en:'5 extinguishers'},{ar:'5 فرق إطفاء',en:'5 firefighting teams'}],c:1,x:{ar:'خمّس الحريق: وقود + أكسجين + حرارة + تفاعل كيميائي ذاتي + طاقة.',en:'Fire pentagon: fuel + oxygen + heat + self-sustaining chemical reaction + energy.'}, d:3, type:'mcq'}
  ]},
  {id:'3.5',e:'sea',n:{ar:'الإخلاء والطوارئ',en:'Evacuation & Emergency'},i:'🚁',x:520,q:[
    {t:{ar:'خطوات الإخلاء؟',en:'What are the evacuation steps?'},o:[{ar:'الهروب فقط',en:'Just run'},{ar:'إنذار، إخلاء منظم، تجمع، عد، إبلاغ',en:'Alarm, orderly evacuation, assembly, headcount, notification'},{ar:'الإخفاء فقط',en:'Hide only'},{ar:'عدم الحركة',en:'Do not move'}],c:1,x:{ar:'خطوات: إنذار، إخلاء، تجمع، عد أفراد، إبلاغ.',en:'Steps: alarm, evacuation, assembly point, headcount, notification.'}, d:1, type:'mcq'},
    {t:{ar:'أهمية التدريب على الطوارئ؟',en:'Why is emergency drill training important?'},o:[{ar:'ليس مهماً',en:'Not important'},{ar:'يضمن استجابة سريعة ومنظمة عند الحادث الحقيقي',en:'Ensures a fast, organized response during a real incident'},{ar:'يقلل التكلفة فقط',en:'Only reduces costs'},{ar:'يحسن الصورة فقط',en:'Only improves image'}],c:1,x:{ar:'التدريب يُنشّط الذاكرة العضلية ويضمن استجابة فورية.',en:'Training builds muscle memory and ensures an immediate response.'}, d:2, type:'mcq'},
    {t:{ar:'ما الوقت الأقصى لارتداء بذلة النجاة (Survival Suit)؟',en:'What is the maximum time to don a survival suit?'},o:[{ar:'5 دقائق',en:'5 minutes'},{ar:'2 دقيقة أو أقل',en:'2 minutes or less'},{ar:'10 دقائق',en:'10 minutes'},{ar:'لا حد زمني',en:'No time limit'}],c:1,x:{ar:'ارتداء بذلة النجاة: يجب أن يُنجز في دقيقتين أو أقل في حالة طوارئ.',en:'Donning a survival suit: must be completed in 2 minutes or less in an emergency.'}, d:2, type:'mcq'},
    {t:{ar:'فريق البحث والإنقاذ البحري (SAR) يتكون من',en:'The Search and Rescue (SAR) team consists of'}, a:{ar:['قائد وطاقم طبي ومشغلي معدات إنقاذ وطيار'], en:['a leader, medical crew, rescue equipment operators, and a pilot']}, x:{ar:'SAR: قائد، طاقم طبي، مشغلي معدات إنقاذ، طيار، مع تدريب دوري.',en:'SAR team: team leader, medical crew, rescue equipment operators, pilot, with regular training.'}, d:1, type:'fill'},
    {t:{ar:'ماذا يحدث عند نقطة التجمع (Muster Point)؟',en:'What happens at the muster point?'},o:[{ar:'ال休息 فقط',en:'Rest only'},{ar:'عد الأفراد، تسجيل الحضور، الإبلاغ، انتظار التعليمات',en:'Headcount, attendance recording, reporting, await instructions'},{ar:'العودة للعمل',en:'Return to work'},{ar:'الترفيه',en:'Entertainment'}],c:1,x:{ar:'نقطة التجمع: عد أفراد + تسجيل + إبلاغ + انتظار تعليمات الإخلاء.',en:'Muster point: headcount + attendance recording + notification + await evacuation instructions.'}, d:2, type:'mcq'}
  ]},
  {id:'3.6',e:'sea',n:{ar:'الحفر والتنقيب',en:'Excavation'},i:'⛏️',x:620,q:[
    {t:{ar:'مخاطر الحفر في المناطق الصناعية؟',en:'What are the hazards of excavation in industrial areas?'},o:[{ar:'لا مخاطر',en:'No hazards'},{ar:'انهيار التربة، تسربات، مواد مدفونة، أسلاك كهربائية',en:'Ground collapse, leaks, buried materials, electrical cables'},{ar:'الإجهاد فقط',en:'Stress only'},{ar:'الضوضاء فقط',en:'Noise only'}],c:1,x:{ar:'مخاطر: انهيار، تسربات، مواد مدفونة، أسلاك، أنابيب.',en:'Hazards: collapse, ingress, buried services, cables, pipelines.'}, d:1, type:'mcq'},
    {t:{ar:'إجراءات السلامة قبل الحفر؟',en:'What are the safety procedures before excavation?'},o:[{ar:'البدء مباشرة',en:'Start immediately'},{ar:'تحديد مواد مدفونة، فحص، تصاريح، إنذارات',en:'Identify buried services, surveys, permits, alerts'},{ar:'عدم التخطيط',en:'No planning needed'},{ar:'حفر في الليل فقط',en:'Excavate at night only'}],c:1,x:{ar:'إجراءات: تحديد مواد مدفونة، فحص، تصاريح، إنذار، مراقبة.',en:'Procedures: locate buried services, survey, permits, alerts, monitoring.'}, d:2, type:'mcq'},
    {t:{ar:'متى تُستخدم صندوق الخندق (Trench Box)؟',en:'When is a trench box used?'},o:[{ar:'دائماً في كل حفر',en:'Always in every excavation'},{ar:'في خنائق أعمق من 1.2 متر لمنع انهيار الجدران',en:'In trenches deeper than 1.2 metres to prevent wall collapse'},{ar:'فقط في المناطق الجافة',en:'Only in dry areas'},{ar:'لا حاجة له',en:'Not needed'}],c:1,x:{ar:'صندوق الخندق: إلزامي في خنائق أعمق من 1.2 م لمنع انهيار الجدران.',en:'Trench box: mandatory in trenches deeper than 1.2 m to prevent sidewall collapse.'}, d:2, type:'mcq'},
    {t:{ar:'Benching في الحفر يعني',en:'Benching in excavation means'}, a:{ar:['قطع جدران الخندق بزاوية لمنع الانهيار'], en:['cutting excavation walls at an angle to prevent collapse']}, x:{ar:'Benching: قطع الجدران بزاوية (1:1 أو أكثر) لمنع الانهيار.',en:'Benching: cutting excavation walls at an angle (1:1 or steeper) to prevent collapse.'}, d:1, type:'fill'},
    {t:{ar:'ما المطلوب حول فتحة الحفر لمنع السقوط؟',en:'What is required around an excavation opening to prevent falls?'},o:[{ar:'لا شيء',en:'Nothing'},{ar:'حواجز وسياجات على الأطراف، تحذيرات، إضاءة ليلية',en:'Barriers and guardrails at edges, warnings, night lighting'},{ar:'لوحة واحدة فقط',en:'One sign only'},{ar:'الإغلاق الدائم',en:'Permanent closure'}],c:1,x:{ar:'حول الحفر: حواجز + سياجات + تحذيرات + إضاءة ليلية.',en:'Around excavations: barriers + guardrails + warning signs + night-time lighting.'}, d:2, type:'mcq'}
  ]},
  {id:'3.7',e:'sea',n:{ar:'المواد الخطرة والنقل',en:'Hazmat & Transport'},i:'🚛',x:120,q:[
    {t:{ar:'الفئات الخمس للمواد الخطرة في النقل؟',en:'What are the five hazard classes for dangerous goods in transport?'},o:[{ar:'الغازات فقط',en:'Gases only'},{ar:'متفجرات، غازات، سوائل قابلة للاحتراق، مؤكسدة، سامة',en:'Explosives, gases, flammable liquids, oxidizers, toxic'},{ar:'الصلبات فقط',en:'Solids only'},{ar:'عضوية فقط',en:'Organic only'}],c:1,x:{ar:'فئات IMDG: متفجرات، غازات، سوائل قابلة للاحتراق، مؤكسدة، سامة.',en:'IMDG classes: explosives, gases, flammable liquids, oxidizers, toxic substances.'}, d:1, type:'mcq'},
    {t:{ar:'أهمية الملصقات التحذيرية؟',en:'Why are warning labels important?'},o:[{ar:'ديكور فقط',en:'Decoration only'},{ar:'تحذير من الخطر وتسهّل التعامل الآمن',en:'Warn of hazards and facilitate safe handling'},{ar:'تحسين المظهر',en:'Improve appearance'},{ar:'زيادة التكلفة',en:'Increase cost'}],c:1,x:{ar:'الملصقات تحذّر من نوع الخطر وتسهل التعامل الآمن.',en:'Labels warn of hazard type and facilitate safe handling.'}, d:2, type:'mcq'},
    {t:{ar:'ما هي أوراق بيانات السلامة (SDS)؟',en:'What are Safety Data Sheets (SDS)?'},o:[{ar:'نماذج توظيف',en:'Employment forms'},{ar:'وثيقة بـ16 قسماً تصف خصائص المواد الخطرة وطرق التعامل معها',en:'A document with 16 sections describing hazardous substance properties and handling procedures'},{ar:'قائمة أسعار',en:'Price list'},{ar:'شهادة تأمين',en:'Insurance certificate'}],c:1,x:{ar:'SDS: وثيقة بـ16 قسماً: التعريف، المخاطر، التكوين، الإسعافات، الإطفاء، التخزين، التخلص.',en:'SDS: 16-section document covering: identification, hazards, composition, first aid, firefighting, storage, disposal.'}, d:2, type:'mcq'},
    {t:{ar:'يجب وضع لافتة IMDG على',en:'IMDG placards must be placed on'}, a:{ar:['جميع وسائط النقل التي تحوي مواد خطرة'], en:['all transport vehicles carrying dangerous goods']}, x:{ar:'لافتات IMDG: إلزامية على كل وسيلة نقل تحوي مواد خطرة، بحجم ولون حسب الفئة.',en:'IMDG placards: mandatory on all vehicles carrying dangerous goods, size and colour per hazard class.'}, d:1, type:'fill'},
    {t:{ar:'أي PPE يُطلب عند نقل المواد الكيميائية الخطرة؟',en:'Which PPE is required when handling hazardous chemicals?'},o:[{ar:'قفازات فقط',en:'Gloves only'},{ar:'قفازات مقاومة للمواد + نظارات + جهاز تنفس + بذلة وقائية',en:'Chemical-resistant gloves + goggles + respirator + protective suit'},{ar:'خوذة فقط',en:'Helmet only'},{ar:'لا حاجة لـ PPE',en:'No PPE needed'}],c:1,x:{ar:'PPE كيميائي: قفازات مقاومة + نظارات + جهاز تنفس + بذلة وقائية حسب نوع المادة.',en:'Chemical PPE: chemical-resistant gloves + goggles + respirator + protective suit per substance type.'}, d:2, type:'mcq'}
  ]},
  {id:'3.8',e:'sea',n:{ar:'الآلات الدوّارة',en:'Rotating Machinery'},i:'⚙️',x:220,q:[
    {t:{ar:'مخاطر الآلات الدوّارة؟',en:'What are the hazards of rotating machinery?'},o:[{ar:'لا مخاطر',en:'No hazards'},{ar:'تشابك، دهس، قطع، انصمام، ضوضاء',en:'Entanglement, crushing, cutting, entanglement, noise'},{ar:'الإجهاد فقط',en:'Stress only'},{ar:'الحرارة فقط',en:'Heat only'}],c:1,x:{ar:'مخاطر: تشابك، قطع، دهس، ضوضاء.',en:'Hazards: entanglement, cutting, crushing, noise.'}, d:1, type:'mcq'},
    {t:{ar:'الحماية الأساسية للآلات؟',en:'What is the primary machine guarding method?'},o:[{ar:'عدم الاقتراب فقط',en:'Do not approach'},{ar:'حجب ودرعات، إيقاف طوارئ، تأهيل، تعليم',en:'Guards and barriers, emergency stop, qualification, training'},{ar:'إغلاق فقط',en:'Lockout only'},{ar:'عدم صيانة',en:'No maintenance'}],c:1,x:{ar:'حماية: حجب، إيقاف طوارئ، تأهيل، صيانة، تعليم.',en:'Protection: guarding, emergency stop, qualification, maintenance, training.'}, d:2, type:'mcq'},
    {t:{ar:'ما هي خطوات LOTO (إغلاق وتعليق الطاقة)؟',en:'What are the Lockout/Tagout (LOTO) steps?'},o:[{ar:'إغلاق فقط',en:'Just switch off'},{ar:'إرسال، عزل، تخزين، تأكيد، تعليق، اختبار',en:'Notify, isolate, lock, verify, tag, test'},{ar:'الاتصال بالهاتف فقط',en:'Phone call only'},{ar:'لا خطوات رسمية',en:'No formal steps'}],c:1,x:{ar:'LOTO: إبلاغ → عزل → تخزين → تأكيد → تعليق بطاقة → اختبار.',en:'LOTO: notify → isolate → store (energy) → verify → attach tag → test.'}, d:3, type:'mcq'},
    {t:{ar:'أنواع الحجب الآلي هي',en:'Types of machine guarding are'}, a:{ar:['ثابت ومتصل بحوارم وقابل للتعديل'], en:['fixed, interlocked, and adjustable guards']}, x:{ar:'أنواع الحجب: ثابت (Fixed)، متصل بحوارم (Interlocked)، قابل للتعديل (Adjustable).',en:'Guarding types: fixed (permanent), interlocked (removes power when opened), adjustable (position variable).'}, d:1, type:'fill'},
    {t:{ar:'ما الذي يجب فحصه قبل تشغيل الآلة الدوّارة؟',en:'What should be checked before starting rotating machinery?'},o:[{ar:'لا شيء',en:'Nothing'},{ar:'الحجب، إيقاف الطوارئ، الحماية الشخصية، vùng الخطر',en:'Guards, emergency stop, PPE, danger zone'},{ar:'فقط السرعة',en:'Speed only'},{ar:'الميزانية فقط',en:'Budget only'}],c:1,x:{ar:'قبل التشغيل: فحص الحجب + إيقاف الطوارئ + PPE + منطقة الخطر.',en:'Before operation: check guards + emergency stop + PPE + danger zone clear.'}, d:2, type:'mcq'}
  ]},
  {id:'3.9',e:'sea',n:{ar:'السلامة البحرية',en:'Marine Safety'},i:'⚓',x:320,q:[
    {t:{ar:'مخاطر العمل على المنصات البحرية؟',en:'What are the hazards of working on offshore platforms?'},o:[{ar:'الراحة فقط',en:'Rest only'},{ar:'رياح عالية، أمواج، عزل، صعوبة الإخلاء بالطائرة',en:'High winds, waves, isolation, difficulty of aerial evacuation'},{ar:'الجو فقط',en:'Weather only'},{ar:'لا مخاطر',en:'No hazards'}],c:1,x:{ar:'مخاطر: رياح، أمواج، عزل جغرافي، إخلاء صعب.',en:'Hazards: wind, waves, geographical isolation, difficult evacuation.'}, d:1, type:'mcq'},
    {t:{ar:'كيف يختلف الإخلاء في البحر؟',en:'How does offshore evacuation differ?'},o:[{ar:'نفس البر',en:'Same as onshore'},{ar:'إخلاء جوي (طائرة/هليكوبتر) أو بحري، مع تحديات الطقس',en:'Aerial (helicopter) or marine evacuation, with weather challenges'},{ar:'عدم الإخلاء',en:'No evacuation'},{ar:'بالسيارة فقط',en:'By car only'}],c:1,x:{ar:'إخلاء بحري أو جوي، يعتمد على الطقس والمسافة.',en:'Marine or aerial evacuation, depending on weather and distance.'}, d:2, type:'mcq'},
    {t:{ar:'ما هو HUET ولماذا هو ضروري؟',en:'What is HUET and why is it essential?'},o:[{ar:'نوع طائرة',en:'A type of aircraft'},{ar:'تدريب الهروب تحت الماء من طائرة هليكوبتر، ضروري لنقل بحري',en:'Helicopter Underwater Escape Training, essential for offshore transport'},{ar:'نظام إنذار',en:'An alarm system'},{ar:'نوع بذلة',en:'A type of suit'}],c:1,x:{ar:'HUET: تدريب على الهروب من طائرة هليكوبتر غارقة، ضروري لجميع أفراد المنصة.',en:'HUET: training for escaping from a submerged helicopter, mandatory for all platform personnel.'}, d:2, type:'mcq'},
    {t:{ar:'جهاز منع الاندفاع (BOP) يُستخدم لـ',en:'The Blowout Preventer (BOP) is used to'}, a:{ar:['إغلاق البئر في حالة ارتفاع الضغط غير المتوقع'], en:['shut in the well in case of unexpected pressure surge']}, x:{ar:'BOP: جهاز منع الاندفاع، يُغلق البئر تلقائياً عند ارتفاع الضغط.',en:'BOP: Blowout Preventer, automatically closes the well during pressure surge.'}, d:1, type:'fill'},
    {t:{ar:'بروتوكولات الاتصال البحري تتطلب',en:'Marine communication protocols require'},o:[{ar:'لا بروتوكولات',en:'No protocols'},{ar:'ntc فصلي + راديو UHF/VHF + إجراءات اتصال واضحة',en:'Structured comms checks + UHF/VHF radio + clear communication procedures'},{ar:'الهاتف الشخصي فقط',en:'Personal phone only'},{ar:'الإشارات اليدوية فقط',en:'Hand signals only'}],c:1,x:{ar:'اتصال بحري: فحص اتصال فصلي + راديو UHF/VHF + إجراءات واضحة.',en:'Marine comms: routine radio checks + UHF/VHF radios + clear standardised procedures.'}, d:2, type:'mcq'}
  ]},
  {id:'3.10',e:'sea',n:{ar:'السلامة الكهربائية',en:'Electrical Safety'},i:'⚡',x:420,q:[
    {t:{ar:'الخطر الرئيسي للكهرباء في بيئة رطبة؟',en:'What is the main electrical hazard in wet environments?'},o:[{ar:'لا خطر',en:'No hazard'},{ar:'الصعق وحرق الشبكة بسبب الرطوبة العالية',en:'Electrocution and network damage due to high humidity'},{ar:'زيادة إنتاجية',en:'Increased productivity'},{ar:'تحسين إضاءة',en:'Improved lighting'}],c:1,x:{ar:'الرطوبة تزيد مخاطر الصعق وتلف المعدات الكهربائية.',en:'Humidity increases the risk of electrocution and electrical equipment damage.'}, d:2, type:'mcq'},
    {t:{ar:'أنظمة التأريض في المناطق الخطرة؟',en:'What is the purpose of earthing systems in hazardous areas?'},o:[{ar:'ديكور فقط',en:'Decoration only'},{ar:'منع تراكم الشحنات الساكنة ومنع الصعق',en:'Prevent static charge buildup and electrocution'},{ar:'تحسين إضاءة',en:'Improve lighting'},{ar:'زيادة حرارة',en:'Increase temperature'}],c:1,x:{ar:'التأريض يمنع الشحنات الساكنة ويحمي من الصعق.',en:'Earthing prevents static charges and protects against electrocution.'}, d:2, type:'mcq'},
    {t:{ar:'ما هو الاندفاع الكهربائي (Arc Flash)؟',en:'What is an arc flash?'},o:[{ar:'انقطاع تيار',en:'Power cut'},{ar:'انفجار كهربائي بسبب قوس كهربائي بين موصلين',en:'An electrical explosion caused by an electric arc between conductors'},{ar:'تيار مستمر',en:'Continuous current'},{ar:'إضاءة زائدة',en:'Excessive lighting'}],c:1,x:{ar:'Arc Flash: انفجار كهربائي بحرارة تصل 20,000 درجة مئوية، يسبب حروقاً وعمى.',en:'Arc flash: electrical explosion with temperatures up to 20,000°C, causing burns and blindness.'}, d:2, type:'mcq'},
    {t:{ar:'جهاز التسرب التدريجي (RCD) يحمي من',en:'A Residual Current Device (RCD) protects against'}, a:{ar:['التسرب الكهربائي والصعق بقطع التيار عند عدم التوازن'], en:['electric shock by disconnecting power on current imbalance']}, x:{ar:'RCD: يقطع التيار فوراً عند كشف تسرب (فوق 30 مللي أمبير).',en:'RCD: disconnects power immediately upon detecting leakage (above 30 mA).'}, d:1, type:'fill'},
    {t:{ar:'ماذا يعني عزل الطاقة الكهربائية (Isolation)؟',en:'What does electrical energy isolation mean?'},o:[{ar:'إغلاق المصباح فقط',en:'Turning off the light only'},{ar:'فصل الطاقة الكهربائية بالكامل مع قفل وتعليق بطاقة',en:'Complete disconnection of electrical supply with lock and tag'},{ar:'تقليل السرعة',en:'Reducing speed'},{ar:'الإغلاق الجزئي',en:'Partial shutdown'}],c:1,x:{ar:'عزل: فصل كامل + قفل + تعليق بطاقة + اختبار الغياب + مراقبة.',en:'Isolation: complete disconnection + lock + tag + dead test + monitoring.'}, d:2, type:'mcq'}
  ]},
  {id:'3.11',e:'sea',n:{ar:'الصيانة الوقائية',en:'Preventive Maintenance'},i:'🛠️',x:520,q:[
    {t:{ar:'الفرق بين الصيانة الوقائية والتصحيحية؟',en:'What is the difference between preventive and corrective maintenance?'},o:[{ar:'لا فرق',en:'No difference'},{ar:'وقائية: دورية لمنع العطل. تصحيحية: بعد العطل',en:'Preventive: periodic to prevent failure. Corrective: after failure'},{ar:'وقائية أبطأ',en:'Preventive is slower'},{ar:'تصحيحية أفضل دائماً',en:'Corrective is always better'}],c:1,x:{ar:'وقائية تمنع العطل. تصحيحية تعالجه بعد وقوعه.',en:'Preventive maintenance prevents breakdowns. Corrective fixes them after failure.'}, d:1, type:'mcq'},
    {t:{ar:'أهمية الصيانة الوقائية في السلامة؟',en:'Why is preventive maintenance important for safety?'},o:[{ar:'تقليل تكاليف فقط',en:'Only reduces costs'},{ar:'تمنع الحوادث الناتجة عن تلف المعدات',en:'Prevents incidents caused by equipment failure'},{ar:'تحسين إنتاجية فقط',en:'Only improves productivity'},{ar:'لا أهمية',en:'Not important'}],c:1,x:{ar:'الصيانة الوقائية تمنع الحوادث من تلف المعدات.',en:'Preventive maintenance prevents incidents from equipment failure.'}, d:2, type:'mcq'},
    {t:{ar:'الفرق بين الصيانة الوقائية والتنبؤية؟',en:'What is the difference between preventive and predictive maintenance?'},o:[{ar:'لا فرق',en:'No difference'},{ar:'وقائية: جدول ثابت. تنبؤية: تعتمد على بيانات حالة المعدات الفعلية',en:'Preventive: fixed schedule. Predictive: based on actual equipment condition data'},{ar:'التنبؤية أقل فعالية',en:'Predictive is less effective'},{ar:'الوقائية أحدث',en:'Preventive is newer'}],c:1,x:{ar:'وقائية: جدول زمني ثابت. تنبؤية: تحليل بيانات فعلي (اهتزاز، حرارة) لتحديد متى تحتاج الصيانة.',en:'Preventive: fixed time-based schedule. Predictive: uses actual condition data (vibration, temperature) to schedule maintenance.'}, d:2, type:'mcq'},
    {t:{ar:'MTBF يعني',en:'MTBF stands for'}, a:{ar:['متوسط الوقت بين الأعطال'], en:['Mean Time Between Failures']}, x:{ar:'MTBF: متوسط الوقت بين الأعطال. يُستخدم لقياس موثوقية المعدات وتخطيط الصيانة.',en:'MTBF: Mean Time Between Failures. Used to measure equipment reliability and plan maintenance.'}, d:1, type:'fill'},
    {t:{ar:'لماذا توثيق سجلات الصيانة ضروري على المنصات البحرية؟',en:'Why are maintenance records essential on offshore platforms?'},o:[{ar:'لملء الورق فقط',en:'For paperwork only'},{ar:'تتبع تاريخ المعدات، التحقق من الامتثال، تحليل الأعطال، تخطيط الصيانة المستقبلية',en:'Track equipment history, verify compliance, analyse failures, plan future maintenance'},{ar:'لتخزين في الأرشيف فقط',en:'For archive storage only'},{ar:'لا أهمية لها',en:'Not important'}],c:1,x:{ar:'السجلات: تتبع + امتثال + تحليل أعطال + تخطيط مستقبلي + أدلة قانونية.',en:'Records: tracking + compliance + failure analysis + future planning + legal evidence.'}, d:3, type:'mcq'}
  ]},
  {id:'3.12',e:'sea',n:{ar:'السلامة البحرية المتقدمة',en:'Advanced Marine Safety'},i:'🌊',x:620,q:[
    {t:{ar:'أنظمة الإنذار على المنصات؟',en:'What are the alarm systems on platforms?'},o:[{ar:'الصراخ فقط',en:'Shouting only'},{ar:'إنذارات صوتية/مرئية، كشف غاز، إنذار حريق',en:'Audible/visual alarms, gas detection, fire alarms'},{ar:'الهاتف فقط',en:'Phone only'},{ar:'لا أنظمة',en:'No systems'}],c:1,x:{ar:'أنظمة: إنذار صوتي/مرئي، كشف غاز، إنذار حريق، اتصالات.',en:'Systems: audible/visual alarms, gas detection, fire alarms, communications.'}, d:1, type:'mcq'},
    {t:{ar:'كيف يُتعامل مع طقس السيء؟',en:'How should severe weather be managed?'},o:[{ar:'العمل كالمعتاد',en:'Work as usual'},{ar:'إيقاف أعمال خارجية، تعزيز تثبيت، مراقبة أحوال جوية',en:'Stop outdoor work, secure equipment, monitor weather conditions'},{ar:'تجاهل',en:'Ignore it'},{ar:'إخلاء فقط',en:'Evacuate only'}],c:1,x:{ar:'تعامل: إيقاف أعمال خارجية، تعزيز، مراقبة أرصاد.',en:'Response: stop outdoor operations, secure moorings, monitor meteorological conditions.'}, d:2, type:'mcq'},
    {t:{ar:'ما هي العمليات المتزامنة (SIMOPS)؟',en:'What are Simultaneous Operations (SIMOPS)?'},o:[{ar:'عمل ليلي فقط',en:'Night work only'},{ar:'إجراء عمليات متعددة في نفس الوقت يتطلب تقييم مخاطر مشترك',en:'Conducting multiple operations at the same time requiring joint risk assessment'},{ar:'عمل فردي فقط',en:'Individual work only'},{ar:'لا توجد عمليات متزامنة',en:'No simultaneous operations'}],c:1,x:{ar:'SIMOPS: عمليات متزامنة تتطلب تقييم مخاطر مشترك وتنسيق بين الفرق.',en:'SIMOPS: simultaneous operations requiring joint risk assessment and coordination between teams.'}, d:2, type:'mcq'},
    {t:{ar:'دراسة HAZOP تُستخدم لـ',en:'A HAZOP study is used to'}, a:{ar:['تحديد المخاطر والانحرافات في العمليات وتصميمها'], en:['identify hazards and deviations in processes and their design']}, x:{ar:'HAZOP: دراسة منهجية لتحديد مخاطر العمليات وانحرافاتها في مراحل التصميم.',en:'HAZOP: systematic study to identify process hazards and deviations during the design stage.'}, d:1, type:'fill'},
    {t:{ar:'نظام تصاريح العمل (Permit to Work) على المنصات يتطلب',en:'The Permit to Work system on platforms requires'},o:[{ar:'لا تصاريح',en:'No permits needed'},{ar:'تصريح مكتوب يحدد العمل والمخاطر والتدابير وفترة الصلاحية',en:'A written permit specifying work, hazards, controls, and validity period'},{ar:'口头 فقط',en:'Verbal only'},{ar:'موافقة المدير فقط',en:'Manager approval only'}],c:1,x:{ar:'PTW: تصريح مكتوب يحدد: نوع العمل، المخاطر، التدابير، المسؤولون، مدة الصلاحية.',en:'PTW: written permit specifying: work type, hazards, controls, responsible persons, validity period.'}, d:3, type:'mcq'}
  ]},

  // OFFICE — BCSP (15 stations)
  {id:'bc1',e:'off',n:{ar:'مبادئ السلامة المهنية',en:'Safety Principles'},i:'📚',x:120,q:[
    {t:{ar:'هرم التحكم في المخاطر؟',en:'What is the hierarchy of risk controls?'},o:[{ar:'PPE فقط',en:'PPE only'},{ar:'استبعاد > استبدال > هندسي > إداري > PPE',en:'Elimination > Substitution > Engineering > Administrative > PPE'},{ar:'تعليم فقط',en:'Training only'},{ar:'قوانين فقط',en:'Rules only'}],c:1,x:{ar:'هرم: استبعاد (الأفضل) → استبدال → هندسي → إداري → PPE (الأقل).',en:'Hierarchy: elimination (best) → substitution → engineering → administrative → PPE (least effective).'}, d:1, type:'mcq'},
    {t:{ar:'الفرق بين الخطر والمخاطرة؟',en:'What is the difference between hazard and risk?'},o:[{ar:'لا فرق',en:'No difference'},{ar:'الخطر: مصدر الأذى. المخاطرة: احتمال وقوعه وشدته',en:'Hazard: source of harm. Risk: likelihood and severity of occurrence'},{ar:'الخطر أخطر دائماً',en:'Hazard is always more dangerous'},{ar:'المخاطرة مصدر الأذى',en:'Risk is the source of harm'}],c:1,x:{ar:'الخطر: مصدر الأذى. المخاطرة: احتمال × شدة الأذى.',en:'Hazard: source of harm. Risk: likelihood × severity of harm.'}, d:2, type:'mcq'},
    {t:{ar:'ما مبدأ ALARP؟',en:'What is the ALARP principle?'},o:[{ar:'تقديم أسرع استجابة',en:'Fastest response'},{ar:'خفض المخاطر إلى أدنى مستوى ممكن عملياً',en:'Reducing risk to as low as reasonably practicable'},{ar:'إرسال تقرير فقط',en:'Report only'},{ar:'تطبيق أقصى تدابير بدون مراعاة التكلفة',en:'Apply maximum controls regardless of cost'}],c:1,x:{ar:'ALARP: خفض المخاطر إلى أدنى مستوى معقول مع مراعاة التكلفة والجهد.',en:'ALARP: reducing risk to the lowest level reasonably practicable, balancing cost and effort against benefit.'}, d:2, type:'mcq'},
    {t:{ar:'لماذا نوثّق الحوادث الوشيكة (Near-Misses)؟',en:'Why do we report near-misses?'},o:[{ar:'لإنشاء أرشيف فقط',en:'For record-keeping only'},{ar:'لأنها أدوات تعليمية تمنع تكرار الحوادث الفعلية',en:'They are learning tools that prevent actual incidents from recurring'},{ar:'لتوسيع العقوبات',en:'To increase penalties'},{ar:'لا حاجة لتوثيقها',en:'No need to report them'}],c:1,x:{ar:'الحوادث الوشيكة: فرصة مجانية لاكتشاف نقاط الضعف قبل وقوع حادث حقيقي.',en:'Near-misses: a free opportunity to identify weaknesses before a real incident occurs.'}, d:1, type:'mcq'},
    {t:{ar:'مصفوفة تقييم المخاطر تعتمد على',en:'A risk assessment matrix is based on'}, a:{ar:['احتمال وقوع الخطر × خطورته'], en:['likelihood of occurrence multiplied by severity']}, x:{ar:'مصفوفة المخاطر: احتمال وقوع الخطر × شدة الأذى = مستوى الخطورة.',en:'Risk matrix: likelihood × severity = risk level. This determines the priority of control measures.'}, d:1, type:'fill'}
  ]},
  {id:'bc2',e:'off',n:{ar:'حماية من الحريق',en:'Fire Protection'},i:'🔥',x:230,q:[
    {t:{ar:'ما هو Flashover؟',en:'What is Flashover?'},o:[{ar:'اندفاع اللهب',en:'Flash flame'},{ar:'تحويل كامل محتويات الغرفة لحالة اشتعال في وقت واحد',en:'Simultaneous ignition of all combustible materials in a room'},{ar:'انبعاث غازات فقط',en:'Gas release only'},{ar:'انهيار مبنى',en:'Building collapse'}],c:1,x:{ar:'Flashover: جميع المواد تصل لنقطة الاشتعال الذاتي في نفس الوقت.',en:'Flashover: all materials reach their auto-ignition temperature simultaneously.'}, d:2, type:'mcq'},
    {t:{ar:'أنواع مخاطر الحريق الأربعة؟',en:'What are the four classes of fire?'},o:[{ar:'سخونة فقط',en:'Heat only'},{ar:'A (صلبة)، B (سائلة)، C (غازية)، D (معادن)',en:'A (solids), B (liquids), C (gases), D (metals)'},{ar:'إضاءة فقط',en:'Lighting only'},{ar:'ضوضاء فقط',en:'Noise only'}],c:1,x:{ar:'أنواع: A صلبة، B سائلة، C غازية، D معادن.',en:'Classes: A solids, B liquids, C gases, D combustible metals.'}, d:1, type:'mcq'},
    {t:{ar:'ما مكونات مثلث الحريق الثلاثة؟',en:'What are the three components of the fire triangle?'},o:[{ar:'ضوء وماء وهواء',en:'Light, water, and air'},{ar:'وقود وحرارة وأكسجين',en:'Fuel, heat, and oxygen'},{ar:'نار ودخان وحرارة',en:'Fire, smoke, and heat'},{ar:'حديد ونحاس وألومنيوم',en:'Iron, copper, and aluminum'}],c:1,x:{ar:'مثلث الحريق: وقود (material)، حرارة (ignition source)، أكسجين (oxidiser). إزالة أي عنصر تطفئ النار.',en:'Fire triangle: fuel, heat, and oxygen. Removing any element extinguishes the fire.'}, d:1, type:'mcq'},
    {t:{ar:'أي طفاية تُستخدم على حرائق الفئة C؟',en:'What extinguisher is used on Class C fires?'},o:[{ar:'ماء فقط',en:'Water only'},{ar:'إطار حراري (Powder) أو ثاني أكسيد الكربون',en:'Dry powder or CO2'},{ar:'رغوة فقط',en:'Foam only'},{ar:'رمل فقط',en:'Sand only'}],c:1,x:{ar:'الفئة C (غازات): مسحوق جاف (ABC) أو CO2. لا تستخدم ماء على حرائق الغاز.',en:'Class C (gases): dry powder (ABC) or CO2. Never use water on gas fires.'}, d:2, type:'mcq'},
    {t:{ar:'نقطة الوميض (Flash Point) هي',en:'Flash Point is'}, a:{ar:['أدنى درجة حرارة تتصاعد منها كميات كافية من البخار لتشكّل خليط قابل للاشتعال'], en:['the lowest temperature at which enough vapour is produced to form an ignitable mixture']}, x:{ar:'نقطة الوميض: أدنى درجة حرارة يتصاعد فيها البخار بكمية كافية لتشكيل مزيج قابل للاشتعال مع الهواء.',en:'Flash Point: the lowest temperature at which a liquid produces enough vapour to form an ignitable mixture with air.'}, d:2, type:'fill'}
  ]},
  {id:'bc3',e:'off',n:{ar:'السلامة الكهربائية',en:'Electrical Safety'},i:'⚡',x:350,q:[
    {t:{ar:'التيار الخطير للإنسان؟',en:'What is the dangerous current level for humans?'},o:[{ar:'1 mA',en:'1 mA'},{ar:'10 mA وخز، 100 mA فيبريليشن قلبي',en:'10 mA tingling, 100 mA cardiac fibrillation'},{ar:'1000 mA فقط',en:'1000 mA only'},{ar:'لا خطر',en:'No danger'}],c:1,x:{ar:'فوق 100 mA يسبب اضطراب نظم القلب والوفاة.',en:'Above 100 mA causes cardiac arrhythmia and death.'}, d:1, type:'mcq'},
    {t:{ar:'مبادئ السلامة الكهربائية؟',en:'What are the electrical safety principles?'},o:[{ar:'عدم لمس الأسلاك فقط',en:'Do not touch wires only'},{ar:'عزل، فحص، تأهيل، PPE، إجراءات طوارئ',en:'Isolation, inspection, qualification, PPE, emergency procedures'},{ar:'استخدام أسلاك فقط',en:'Use wires only'},{ar:'عدم فحص',en:'No inspection'}],c:1,x:{ar:'مبادئ: عزل، فحص، تأهيل، حماية، إجراءات طوارئ.',en:'Principles: isolation, inspection, qualification, protection, emergency procedures.'}, d:2, type:'mcq'},
    {t:{ar:'ما هو نظام القفل والوسم (LOTO)؟',en:'What is Lockout/Tagout (LOTO)?'},o:[{ar:'نظام تخزين فقط',en:'Storage system only'},{ar:'إجراءات لعزل مصادر الطاقة ووسمها لمنع التشغيل غير المصرح به',en:'Procedures to isolate energy sources and tag them to prevent unauthorized operation'},{ar:'نظام عدّ المعدات',en:'Equipment counting system'},{ar:'بروتوكول إغلاق المبنى',en:'Building lockdown protocol'}],c:1,x:{ar:'LOTO: عزل مصادر الطاقة (كهرباء، ضغط، حرارة) ووسمها لمنع التشغيل أثناء الصيانة.',en:'LOTO: isolating energy sources (electrical, pressure, thermal) and tagging them to prevent startup during maintenance.'}, d:2, type:'mcq'},
    {t:{ar:'لماذا التأريض (Earthing) مهم في السلامة الكهربائية؟',en:'Why is earthing important in electrical safety?'},o:[{ar:'لتحسين التكييف فقط',en:'For air conditioning only'},{ar:'يمنع تراكم التيار الزائد على الهيكل المعدني ويقلل خطر الصدمة',en:'Prevents excess current buildup on metal frames and reduces shock hazard'},{ar:'لزيادة كفاءة الطاقة فقط',en:'To increase energy efficiency only'},{ar:'لا أهمية له',en:'No importance'}],c:1,x:{ar:'التأريض: يوفر مسار منخفض المقاومة للتيار الأرضي لمنع الصدمة الكهربائية وحماية المعدات.',en:'Earthing: provides a low-resistance path for fault current to prevent electric shock and protect equipment.'}, d:2, type:'mcq'},
    {t:{ar:'الحد الأقصى المسموح به للجهد الكهربائي المنخفض (SELV) هو',en:'The maximum allowed extra-low voltage (SELV) is'}, a:{ar:['50 فولت تيار متردد أو 120 فولت مستمر'], en:['50 volts AC or 120 volts DC']}, x:{ar:'SELV: جهد منخفض زائد لا يتجاوز 50V AC أو 120V DC، يُستخدم في البيئات الرطبة والمناطق الخطرة.',en:'SELV: extra-low voltage not exceeding 50V AC or 120V DC, used in damp and hazardous areas.'}, d:1, type:'fill'}
  ]},
  {id:'bc4',e:'off',n:{ar:'البيئة المريحة',en:'Ergonomics'},i:'🪑',x:470,q:[
    {t:{ar:'أكثر اضطرابات العضلات الهيكلية شيوعاً؟',en:'What are the most common musculoskeletal disorders?'},o:[{ar:'الحروق',en:'Burns'},{ar:'آلام الظهر والرقبة والكتفين والمعصم',en:'Back, neck, shoulder, and wrist pain'},{ar:'الحساسية فقط',en:'Allergies only'},{ar:'الصداع فقط',en:'Headaches only'}],c:1,x:{ar:'MSDs: آلام ظهر، رقبة، كتف، معصم، ساق.',en:'MSDs: back, neck, shoulder, wrist, and leg pain.'}, d:1, type:'mcq'},
    {t:{ar:'كيف يُحسّن تصميم محطة العمل؟',en:'How can workstation design be improved?'},o:[{ar:'زيادة الحجم فقط',en:'Increase size only'},{ar:'ارتفاع مناسب، إضاءة جيدة، تهوية، ترتيب الأدوات',en:'Proper height, good lighting, ventilation, tool arrangement'},{ar:'عدم التغيير',en:'Do not change'},{ar:'تقليل مساحة',en:'Reduce space'}],c:1,x:{ar:'تحسين: ارتفاع، إضاءة، تهوية، ترتيب، مرونة.',en:'Improvement: height, lighting, ventilation, arrangement, flexibility.'}, d:2, type:'mcq'},
    {t:{ar:'ما العوامل الأربعة الرئيسية في التعامل اليدوي؟',en:'What are the four key factors in manual handling?'},o:[{ar:'سرعة ووزن فقط',en:'Speed and weight only'},{ar:'الوضعية، الحمل، المسافة، البيئة',en:'Posture, load, distance, environment'},{ar:'الإرهاق فقط',en:'Fatigue only'},{ar:'القفز فقط',en:'Jumping only'}],c:1,x:{ar:'التعامل اليدوي: وضعية الجسم، وزن الحمل، مسافة النقل، ظروف البيئة (حرارة، رطوبة).',en:'Manual handling: body posture, load weight, carrying distance, environmental conditions (heat, humidity).'}, d:2, type:'mcq'},
    {t:{ar:'تقرير الأجهزة البصرية (VDU) يتطلب فاصل زمني كل',en:'Display screen equipment (VDU) reports require a break every'}, o:[{ar:'30 دقيقة',en:'30 minutes'},{ar:'ساعة واحدة من العمل المتواصل',en:'One hour of continuous work'},{ar:'4 ساعات',en:'4 hours'},{ar:'نهاية اليوم فقط',en:'End of day only'}],c:1,x:{ar:'فاصل 5-10 دقائق كل ساعة من العمل على شاشة العرض لمنع إرهاق العيون والظهر.',en:'A 5-10 minute break every hour of screen work to prevent eye and back strain.'}, d:1, type:'mcq'},
    {t:{ar:'اضطراب العضلات الهيكلية الناتج عن التعرض المتكرر يُعرف بـ',en:'Musculoskeletal disorder caused by repetitive exposure is known as'}, a:{ar:['إصابة الإجهاد المتكرر'], en:['repetitive strain injury (RSI)']}, x:{ar:'RSI: إصابات ناتجة عن حركات متكررة (كتابة، تشغيل مكن، رفع أوزان) تؤدي لألم مزمن.',en:'RSI: injuries caused by repetitive motions (typing, machine operation, lifting) leading to chronic pain.'}, d:2, type:'fill'}
  ]},
  {id:'bc5',e:'off',n:{ar:'السلامة الكيميائية',en:'Chemical Safety'},i:'🧪',x:590,q:[
    {t:{ar:'الفرق بين TLV-TWA وSTEL وC؟',en:'What is the difference between TLV-TWA, STEL, and TLV-C?'},o:[{ar:'لا فرق',en:'No difference'},{ar:'TWA: متوسط 8 ساعات. STEL: 15 دقيقة. C: لحظي قاتل',en:'TWA: 8-hour average. STEL: 15-minute short-term. C: ceiling (immediate danger)'},{ar:'STEL أطول دائماً',en:'STEL is always longer'},{ar:'TLV-C أقل خطورة',en:'TLV-C is least dangerous'}],c:1,x:{ar:'TWA: متوسط 8 ساعات. STEL: 15 دقيقة. C: لحظي فوري.',en:'TWA: 8-hour time-weighted average. STEL: 15-minute short-term exposure. C: ceiling limit.'}, d:2, type:'mcq'},
    {t:{ar:'كيف يُقيّم التعرض الكيميائي؟',en:'How is chemical exposure assessed?'},o:[{ar:'بالشم فقط',en:'By smell only'},{ar:'قياس كمي مقارنة بالمعايير، فحص معدات، مراقبة صحية',en:'Quantitative measurement against standards, equipment checks, health surveillance'},{ar:'عدم التقييم',en:'No assessment'},{ar:'بالنظر فقط',en:'By visual inspection only'}],c:1,x:{ar:'تقييم: قياس كمي، مقارنة بـ TLVs، مراقبة صحية.',en:'Assessment: quantitative measurement, comparison with TLVs, health surveillance.'}, d:2, type:'mcq'},
    {t:{ar:'كم قسماً أساسيALLY في بطاقة بيانات السلامة (SDS)؟',en:'How many essential sections are in a Safety Data Sheet (SDS)?'},o:[{ar:'5 أقسام فقط',en:'5 sections only'},{ar:'16 قسماً حسب التنسيق الدولي للمواد الكيميائية',en:'16 sections per the internationally harmonised format'},{ar:'10 أقسام',en:'10 sections'},{ar:'عدم وجود قسم موحد',en:'No unified format'}],c:1,x:{ar:'SDS: 16 قسماً حسب GHS تشمل المكونات، المخاطر، وسائل الحماية، الإسعاف، التخزين.',en:'SDS: 16 sections per GHS covering composition, hazards, protective measures, first aid, storage.'}, d:2, type:'mcq'},
    {t:{ar:'ما معنى مبدأ التسلسل الهرمي لتدابير التحكم الكيميائي؟',en:'What does the hierarchy of chemical control measures mean?'},o:[{ar:'استخدام معدات الحماية فقط',en:'Use PPE only'},{ar:'استبعاد > استبدال > عزل > هندسي > إداري > PPE',en:'Elimination > Substitution > Isolation > Engineering > Administrative > PPE'},{ar:'التدبير الإداري فقط',en:'Administrative only'},{ar:'استخدام مروحة فقط',en:'Use a fan only'}],c:1,x:{ar:'تسلسل: استبعاد المادة الكيميائية (الأفضل) → استبدالها → عزل المصدر → تحكمات هندسية → إداري → PPE.',en:'Sequence: eliminate the chemical (best) → substitute → isolate source → engineering controls → administrative → PPE.'}, d:2, type:'mcq'},
    {t:{ar:'تقييم التعرض الكيميائي (COSHH) يشمل',en:'A COSHH assessment includes'}, a:{ar:['تحديد المواد الخطرة وتقييم التعرض ووضع تدابير التحكم'], en:['identifying hazardous substances, assessing exposure, and implementing control measures']}, x:{ar:'COSHH: تقييم شامل يشمل تحديد المواد الكيميائية الخطرة، تقييم التعرض، ووضع تدابير تحكم فعّالة.',en:'COSHH: a comprehensive assessment identifying hazardous chemicals, evaluating exposure, and implementing effective controls.'}, d:1, type:'fill'}
  ]},
  {id:'bc6',e:'off',n:{ar:'الصحة المهنية',en:'Occupational Health'},i:'🏥',x:710,q:[
    {t:{ar:'الفئات الرئيسية للصحة المهنية؟',en:'What are the main categories of occupational health hazards?'},o:[{ar:'الطب فقط',en:'Medicine only'},{ar:'كيميائي، فيزيائي، بيولوجي، سيكولوجي، ميكانيكي',en:'Chemical, physical, biological, psychological, mechanical'},{ar:'رياضة فقط',en:'Sports only'},{ar:'نوم فقط',en:'Sleep only'}],c:1,x:{ar:'فئات: كيميائي، فيزيائي، بيولوجي، سيكولوجي، ميكانيكي.',en:'Categories: chemical, physical, biological, psychological, mechanical.'}, d:1, type:'mcq'},
    {t:{ar:'أهمية برنامج الرعاية الصحية؟',en:'Why is a health care program important?'},o:[{ar:'ليس مهماً',en:'Not important'},{ar:'كشف مبكر، علاج، تقليل غياب، تحسين أداء',en:'Early detection, treatment, reduced absenteeism, improved performance'},{ar:'زيادة تكلفة فقط',en:'Only increases cost'},{ar:'تحسين صورة فقط',en:'Only improves image'}],c:1,x:{ar:'رعاية صحية: كشف مبكر، علاج، تقليل غياب، تحسين أداء.',en:'Health care: early detection, treatment, reduced absenteeism, improved performance.'}, d:2, type:'mcq'},
    {t:{ar:'ما الأسباب الرئيسية لفقدان السمع الناتج عن الضوضاء (NIHL)؟',en:'What is the main cause of Noise-Induced Hearing Loss (NIHL)?'},o:[{ar:'السماع للموسيقى فقط',en:'Listening to music only'},{ar:'التعرض المطول والمتكرر لمستويات صوتية عالية تتجاوز 85 ديسיבל',en:'Prolonged and repeated exposure to noise levels above 85 decibels'},{ar:'العمر فقط',en:'Age only'},{ar:'الوراثة فقط',en:'Genetics only'}],c:1,x:{ar:'NIHL: التعرض للضوضاء فوق 85 dB لفترات طويلة يسبب تلف غشاء القوقعة بشكل دائم.',en:'NIHL: exposure to noise above 85 dB for extended periods causes permanent damage to the cochlear membrane.'}, d:2, type:'mcq'},
    {t:{ar:'ما الفرق بين المرض المهني والإصابة المهنية؟',en:'What is the difference between occupational disease and occupational injury?'},o:[{ar:'لا فرق',en:'No difference'},{ar:'مرض: نتيجة تراكم التعرض. إصابة: نتيجة حدث فوري',en:'Disease: from cumulative exposure. Injury: from an immediate event'},{ar:'المرض أبسط',en:'Disease is simpler'},{ar:'الإصابة أصعب',en:'Injury is harder'}],c:1,x:{ar:'إصابة مهنية: حدث مفاجئ (سقوط، انفجار). مرض مهني: تطور تدريجي بسبب التعرض المتكرر (ضوضاء، مواد كيميائية).',en:'Occupational injury: sudden event (fall, explosion). Occupational disease: gradual development from repeated exposure (noise, chemicals).'}, d:2, type:'mcq'},
    {t:{ar:'الحد المسموح به للضوضاء في بيئة العمل لـ 8 ساعات هو',en:'The permitted noise exposure limit for 8 hours is'}, a:{ar:['85 ديسיבל (dB)'], en:['85 decibels (dB)']}, x:{ar:'الحد القانوني: 85 dB(A) لمتوسط 8 ساعات. فوق هذا المستوى يجب توفير معدات حماية سمعية.',en:'The legal limit: 85 dB(A) for an 8-hour average. Above this, hearing protection must be provided.'}, d:1, type:'fill'}
  ]},
  {id:'bc7',e:'off',n:{ar:'إدارة سلامة البرامج',en:'Safety Program Management'},i:'📋',x:120,q:[
    {t:{ar:'العنصر الأهم في برنامج السلامة؟',en:'What is the most important element of a safety program?'},o:[{ar:'تجهيزات غالية',en:'Expensive equipment'},{ar:'التزام الإدارة العلوية (Management Commitment)',en:'Top management commitment'},{ar:'عدد موظفين فقط',en:'Number of employees only'},{ar:'العقوبات',en:'Penalties'}],c:1,x:{ar:'بدون التزام الإدارة العليا، أي برنامج سلامة سيفشل.',en:'Without top management commitment, any safety program will fail.'}, d:1, type:'mcq'},
    {t:{ar:'كيف تُقاس فعالية البرنامج؟',en:'How is program effectiveness measured?'},o:[{ar:'بالتكلفة فقط',en:'By cost only'},{ar:'معدل حوادث، تقييمات مخاطر، استبيانات رضا',en:'Incident rates, hazard assessments, satisfaction surveys'},{ar:'بعدد موظفين',en:'By number of employees'},{ar:'بالصورة فقط',en:'By image only'}],c:1,x:{ar:'قياس: معدل حوادث، تقييمات، استبيانات، ملاحظات ميدانية.',en:'Measurement: incident rates, assessments, surveys, field observations.'}, d:2, type:'mcq'},
    {t:{ar:'ما الفرق بين مؤشرات الأمان التقدامية والتأخرية؟',en:'What is the difference between leading and lagging safety indicators?'},o:[{ar:'لا فرق',en:'No difference'},{ar:'تقدامية: تقيّم الأنشطة الوقائية. تأخرية: تقيّم النتائج بعد وقوع الحوادث',en:'Leading: evaluate preventive activities. Lagging: evaluate outcomes after incidents occur'},{ar:'تقدامية أقل أهمية',en:'Leading is less important'},{ar:'تأخرية وقائية',en:'Lagging is preventive'}],c:1,x:{ar:'تقدامية (PROACTIVE): تقييمات، تدريب، فحوصات. تأخرية (REACTIVE): معدل الحوادث، عدد الإصابات.',en:'Leading (proactive): assessments, training, inspections. Lagging (reactive): incident rates, injury counts.'}, d:2, type:'mcq'},
    {t:{ar:'كيف تُبنى ثقافة السلامة الإيجابية في المنظمة؟',en:'How is a positive safety culture built in an organisation?'},o:[{ar:'بالعقوبات فقط',en:'Penalties only'},{ar:'بمشاركة الإدارة والعمال في اتخاذ قرارات السلامة وتشجيع الإبلاغ',en:'By involving management and workers in safety decisions and encouraging reporting'},{ar:'بوضع قوانين فقط',en:'Rules only'},{ar:'بالمراقبة فقط',en:'Surveillance only'}],c:1,x:{ar:'ثقافة إيجابية: مشاركة، ثقة، تعلم من الأخطاء، دعم الإدارة، تشجيع الإبلاغ الحر.',en:'Positive culture: involvement, trust, learning from errors, management support, open reporting.'}, d:2, type:'mcq'},
    {t:{ar:'معدل الإصابات المعدّل (TRIR) يُحسب بـ',en:'The Total Recordable Incident Rate (TRIR) is calculated by'}, a:{ar:['عدد الإصابات القابلة للتوثيق × 200,000 مقسوماً على إجمالي ساعات العمل'], en:['number of recordable injuries multiplied by 200,000 divided by total hours worked']}, x:{ar:'TRIR = (عدد الإصابات القابلة للتوثيق × 200,000) ÷ إجمالي ساعات العمل. يُستخدم كمعيار مقارنة.',en:'TRIR = (number of recordable injuries × 200,000) ÷ total hours worked. Used as a benchmarking metric.'}, d:3, type:'fill'}
  ]},
  {id:'bc8',e:'off',n:{ar:'النظافة الصناعية',en:'Industrial Hygiene'},i:'🔬',x:230,q:[
    {t:{ar:'التقييم النوعي في النظافة الصناعية؟',en:'What is qualitative assessment in industrial hygiene?'},o:[{ar:'استخدام أجهزة فقط',en:'Using instruments only'},{ar:'تقييم بالخبرة والحواس بدون أرقام دقيقة',en:'Assessment by experience and senses without precise numbers'},{ar:'عدم التقييم',en:'No assessment'},{ar:'القياس الكمي فقط',en:'Quantitative measurement only'}],c:1,x:{ar:'نوعي: ملاحظات ميدانية وخبرة، بدون قياس كمي دقيق.',en:'Qualitative: field observations and experience, without precise quantitative measurement.'}, d:2, type:'mcq'},
    {t:{ar:'خطوات التقييم الكمي؟',en:'What are the steps of quantitative assessment?'},o:[{ar:'عدم القياس',en:'No measurement'},{ar:'جمع عينات، قياس، مقارنة بالمعايير، تقرير',en:'Sample collection, measurement, comparison with standards, reporting'},{ar:'النظر فقط',en:'Visual inspection only'},{ar:'الشم فقط',en:'Smell only'}],c:1,x:{ar:'خطوات: جمع عينات، قياس، مقارنة بـ TLVs، تقرير.',en:'Steps: sample collection, measurement, comparison with TLVs, reporting.'}, d:2, type:'mcq'},
    {t:{ar:'ما أداة القياس الأساسية للضوضاء في بيئة العمل؟',en:'What is the primary instrument for measuring workplace noise?'},o:[{ar:'ميزان حرارة فقط',en:'Thermometer only'},{ar:'مقياس صوت عادي',en:'Regular sound meter'},{ar:'مقياس مستوى الصوت الموزون (dosimeter أو مقياس dB)',en:'Sound level meter or dosimeter measuring dB(A)'},{ar:'السمع فقط',en:'By ear only'}],c:2,x:{ar:'مقياس الصوت الموزون يقيس مستوى الضوضاء بالمدينتين dB(A) ويُستخدم لحساب التعرض اليومي.',en:'A dosimeter or sound level meter measures noise in dB(A) and is used to calculate daily noise exposure.'}, d:2, type:'mcq'},
    {t:{ar:'التهوية المحلية عند المصدر (LEV) تعمل كيف؟',en:'How does Local Exhaust Ventilation (LEV) at source work?'},o:[{ar:'تهوية عامة فقط',en:'General ventilation only'},{ar:'تمتص الملوثات من نقطة الإصدار قبل وصولها لتنفس العامل',en:'Extracts contaminants at the emission point before reaching the worker\'s breathing zone'},{ar:'تبريد الغرفة فقط',en:'Room cooling only'},{ar:'لا تعمل',en:'Does not work'}],c:1,x:{ar:'LEV: يُوضع بالقرب من مصدر التلوث (هود، خزان) لامتصاص الملوثات قبل تشتتها في الهواء.',en:'LEV: positioned near the contaminant source (hood, tank) to capture pollutants before they disperse in the air.'}, d:2, type:'mcq'},
    {t:{ar:'مؤشر أداء النظافة الصناعية (IHY) يُستخدم لتقييم',en:'The Industrial Hygiene (IHY) scoring index is used to evaluate'}, a:{ar:['مستوى التعرض للمخاطر الكيميائية والفيزيائية في بيئة العمل'], en:['the level of chemical and physical hazard exposure in the workplace']}, x:{ar:'IHY: نظام تقييم يُعطي درجة لكل خطر (كيميائي، فيزيائي) ويساعد في تحديد الأولويات للتحكم.',en:'IHY: a scoring system assigning ratings for each hazard (chemical, physical) to help prioritise controls.'}, d:3, type:'fill'}
  ]},
  {id:'bc9',e:'off',n:{ar:'سلامة العمليات',en:'Operational Safety'},i:'⚙️',x:350,q:[
    {t:{ar:'الفرق بين سلامة العمليات والأفراد؟',en:'What is the difference between operational and personal safety?'},o:[{ar:'لا فرق',en:'No difference'},{ar:'عمليات: منع حوادج كبرى. أفراد: حماية من إصابات',en:'Operations: prevent major incidents. Personal: protect from injuries'},{ar:'عمليات أقل أهمية',en:'Operations is less important'},{ar:'أفراد فقط',en:'Personal only'}],c:1,x:{ar:'عمليات تمنع انفجارات وحرائق كبرى. أفراد تحمي من إصابات يومية.',en:'Operations prevents major explosions and fires. Personal protects from daily injuries.'}, d:1, type:'mcq'},
    {t:{ar:'أنظمة إدارة التغيير (MOC)؟',en:'What is Management of Change (MOC)?'},o:[{ar:'تغيير ألوان فقط',en:'Change colors only'},{ar:'نظام يضمن تقييم مخاطر أي تغيير قبل تنفيذه',en:'A system to assess hazards of any change before implementation'},{ar:'عدم التغيير',en:'No change'},{ar:'التغيير فقط',en:'Change only'}],c:1,x:{ar:'MOC: تقييم مخاطر التغييرات قبل التنفيذ لمنع الحوادث.',en:'MOC: assess hazards of changes before implementation to prevent incidents.'}, d:2, type:'mcq'},
    {t:{ar:'ما هو نظام تصاريح العمل (Permit to Work)؟',en:'What is the Permit to Work (PTW) system?'},o:[{ar:'تصريح دخول المبنى فقط',en:'Building entry permit only'},{ar:'نظام كتابي يُحدد شروط العمل الخطير ويضمن اتخاذ تدابير السلامة',en:'A written system that specifies conditions for high-risk work and ensures safety measures are in place'},{ar:'رخصة قيادة فقط',en:'Driving licence only'},{ar:'إذن مغادرة فقط',en:'Exit permit only'}],c:1,x:{ar:'PTW: نظام يُصدر قبل أعمال خطيرة (الحرق، الصيانة، العمل المرتفع) ويحدد الشروط والمسؤوليات.',en:'PTW: a system issued before high-risk work (hot work, maintenance, working at height) specifying conditions and responsibilities.'}, d:2, type:'mcq'},
    {t:{ar:'متى يجب تطبيق إجراءات سلامة الأماكن المغلقة (Confined Space)؟',en:'When must confined space safety procedures be applied?'},o:[{ar:'عندما يكون المكان صغيراً فقط',en:'When the space is small only'},{ar:'في أي مساحة محدودة التهوية قد تتراكم فيها مواد خطرة',en:'In any poorly ventilated space where hazardous substances may accumulate'},{ar:'خارج المبنى فقط',en:'Outside the building only'},{ar:'لا حاجة لها',en:'Not needed'}],c:1,x:{ar:'أي مساحة محدودة الدخول والخروج وتفتقر للتهوية الكافية أو بها مواد خطرة تتطلب إجراءات خاصة.',en:'Any space with limited entry/exit and inadequate ventilation or hazardous substances requires special procedures.'}, d:2, type:'mcq'},
    {t:{ar:'إدارة تغيير العمليات (PSM) تغطي',en:'Process Safety Management (PSM) covers'}, a:{ar:['السيطرة على المخاطر الكيميائية الخطيرة في العمليات الصناعية'], en:['controlling highly hazardous chemicals in industrial processes']}, x:{ar:'PSM: نظام شامل يُعالج مخاطر المواد الكيميائية الخطيرة في التصنيع والمعالجة.',en:'PSM: a comprehensive system addressing risks of highly hazardous chemicals in manufacturing and processing.'}, d:1, type:'fill'}
  ]},
  {id:'bc10',e:'off',n:{ar:'الإشراف والمراجعة',en:'Supervision & Review'},i:'👁️',x:470,q:[
    {t:{ar:'الهدف من المراجعة الداخلية للسلامة؟',en:'What is the purpose of an internal safety audit?'},o:[{ar:'معاقبة المخالفين فقط',en:'Punish violators only'},{ar:'تقييم فعالية نظام إدارة السلامة وتحديد مجالات التحسين',en:'Assess effectiveness of the safety management system and identify improvement areas'},{ar:'الإبلاغ فقط',en:'Reporting only'},{ar:'التوظيف فقط',en:'Recruiting only'}],c:1,x:{ar:'مراجعة: تقييم فعالية، تحديد نقاط قوة وضعف، فرص تحسين.',en:'Audit: assess effectiveness, identify strengths and weaknesses, improvement opportunities.'}, d:1, type:'mcq'},
    {t:{ar:'معايير المراجعة الجيدة؟',en:'What are the criteria for a good audit?'},o:[{ar:'عدم المراجعة',en:'No audit'},{ar:'موضوعية، شاملة، موثقة، تتبع إجراءات تصحيحية',en:'Objective, comprehensive, documented, with corrective action tracking'},{ar:'مراجعة سريعة فقط',en:'Quick review only'},{ar:'بدون توثيق',en:'No documentation'}],c:1,x:{ar:'معايير: موضوعية، شمولية، توثيق، تتبع إجراءات تصحيحية.',en:'Criteria: objectivity, comprehensiveness, documentation, corrective action follow-up.'}, d:2, type:'mcq'},
    {t:{ar:'ما دور الإجراءات التصحيحية والوقائية (CAPA) في المراجعة؟',en:'What is the role of Corrective and Preventive Actions (CAPA) in an audit?'},o:[{ar:'توثيق فقط',en:'Documentation only'},{ar:'معالجة الأسباب الجذرية للمشاكل ومنع تكرارها',en:'Address root causes of issues and prevent recurrence'},{ar:'إغلاق التقرير فقط',en:'Closing the report only'},{ar:'العقوبات فقط',en:'Penalties only'}],c:1,x:{ar:'CAPA: الإجراء التصحيح يعالج المشكلة الحالية. الوقائي يمنع تكرارها في المستقبل.',en:'CAPA: corrective action addresses the current issue. Preventive action stops it from recurring in the future.'}, d:2, type:'mcq'},
    {t:{ar:'كم مرة يجب إجراء مراجعة الإدارة العليا لنظام السلامة عادةً؟',en:'How often should senior management review the safety management system?'},o:[{ar:'مرة كل 5 سنوات',en:'Once every 5 years'},{ar:'سنوياً على الأقل مع تقييم الأداء والتحسينات',en:'Annually at minimum, with performance review and improvements'},{ar:'لا حاجة لمراجعة',en:'No review needed'},{ar:'شهرياً فقط',en:'Monthly only'}],c:1,x:{ar:'مراجعة الإدارة: على الأقل سنوياً، تشمل تقييم الأداء، مراجعة الحوادث، وتحديد الأولويات.',en:'Management review: at least annually, covering performance evaluation, incident review, and priority setting.'}, d:2, type:'mcq'},
    {t:{ar:'متابعة الإجراءات التصحيحية تشمل',en:'Corrective action follow-up includes'}, a:{ar:['التحقق من تنفيذ الإجراءات وفعاليةها ومنع تكرار المشكلة'], en:['verifying the implementation and effectiveness of actions and preventing problem recurrence']}, x:{ar:'المتابعة: التحقق من التنفيذ الفعلي، قياس النتائج، وتوثيق فعالية الإجراء.',en:'Follow-up: verifying actual implementation, measuring outcomes, and documenting the effectiveness of the action.'}, d:1, type:'fill'}
  ]},
  {id:'bc11',e:'off',n:{ar:'تحليل أسباب الجذر',en:'Root Cause Analysis'},i:'📈',x:590,q:[
    {t:{ar:'أداة تحليل أسباب الجذر (RCA)؟',en:'What is Root Cause Analysis (RCA)?'},o:[{ar:'البحث عن المتسبب فقط',en:'Find the person responsible only'},{ar:'تحليل منهجي للكشف عن الأسباب الجذرية لا الأعراض',en:'Systematic analysis to identify root causes, not symptoms'},{ar:'عدم التحليل',en:'No analysis'},{ar:'تحليل سريع فقط',en:'Quick analysis only'}],c:1,x:{ar:'RCA يبحث عن الأسباب الجذرية (نظامية) لا الأعراض السطحية.',en:'RCA looks for systemic root causes, not surface-level symptoms.'}, d:2, type:'mcq'},
    {t:{ar:'شجرة الأخطاء (FTA)؟',en:'What is Fault Tree Analysis (FTA)?'},o:[{ar:'رسم شجرة فقط',en:'Draw a tree only'},{ar:'أداة تحليل نزلي تبدأ من الحادث وتعود للأسباب',en:'A top-down analytical tool starting from the incident and tracing back to causes'},{ar:'أداة إدارية فقط',en:'Management tool only'},{ar:'لا علاقة لها',en:'Not related'}],c:1,x:{ar:'FTA: تبدأ من الحادث (القمة) وتنزل للأسباب عبر بوابات منطقية.',en:'FTA: starts from the top event (incident) and works down to causes through logic gates.'}, d:2, type:'mcq'},
    {t:{ar:'ما تحليل "لماذا؟" الخمسة (5-Why)؟',en:'What is the 5-Why analysis?'},o:[{ar:'سؤال واحد فقط',en:'One question only'},{ar:'أداة بسيطة تطرح "لماذا؟" عدة مرات للوصول للسبب الجذري',en:'A simple tool asking "why?" multiple times to reach the root cause'},{ar:'تحليل إحصائي فقط',en:'Statistical analysis only'},{ar:'سؤال 5 أشخاص فقط',en:'Ask 5 people only'}],c:1,x:{ar:'5-Why: أداة بسيطة وفعّالة تطرح "لماذا" عدة مرات (عادة 5) للوصول للسبب الجذري.',en:'5-Why: a simple, effective tool asking "why" multiple times (usually 5) to reach the root cause.'}, d:1, type:'mcq'},
    {t:{ar:'شجرة الأسباب (Ishikawa/Fishbone) تجمع العوامل في فئات تشمل',en:'The Ishikawa (Fishbone) diagram groups factors into categories including'}, o:[{ar:'الإنسان والمعدات فقط',en:'People and equipment only'},{ar:'الإنسان، المعدات، المواد، الطريقة، البيئة، القياس',en:'People, equipment, materials, method, environment, measurement'},{ar:'الميزانية والوقت فقط',en:'Budget and time only'},{ar:'المخاطر والفرص فقط',en:'Risks and opportunities only'}],c:1,x:{ar:'Ishikawa: 6M — Man, Machine, Material, Method, Measurement, Mother Nature (Environment).',en:'Ishikawa: 6M — Man, Machine, Material, Method, Measurement, Mother Nature (Environment).'}, d:2, type:'mcq'},
    {t:{ar:'تحليل البوب-تي (Bow-Tie) يربط بين',en:'The Bow-Tie analysis links'}, a:{ar:['المخاطر والتدابير الوقائية والتصحيحية في رسم بياني واحد'], en:['hazards with preventive and corrective measures in a single diagram']}, x:{ar:'Bow-Tie: يربط الخطر (القمة) بالتدابير الوقائية (يسار) والتدابير التصحيحية (يمين) والنتائج السلبية.',en:'Bow-Tie: links the hazard (top) with preventive controls (left) and corrective controls (right) and negative outcomes.'}, d:2, type:'fill'}
  ]},
  {id:'bc12',e:'off',n:{ar:'الاستجابة للطوارئ',en:'Emergency Response'},i:'🚑',x:710,q:[
    {t:{ar:'العنصر الأساسي في تخطيط الطوارئ؟',en:'What is the essential element of emergency planning?'},o:[{ar:'أرقام هواتف فقط',en:'Phone numbers only'},{ar:'هيكل استجابة واضح يحدد الأدوار والمسؤوليات',en:'A clear response structure defining roles and responsibilities'},{ar:'عدد إسعافات فقط',en:'Number of first aiders only'},{ar:'هاتف فقط',en:'Phone only'}],c:1,x:{ar:'بدون تحديد واضح للأدوار، الاستجابة ستكون فوضوية.',en:'Without clear role assignment, the response will be chaotic.'}, d:1, type:'mcq'},
    {t:{ar:'كيف يُقيّم الاستجابة بعد الحادث؟',en:'How is the response evaluated after an incident?'},o:[{ar:'عدم التقييم',en:'No evaluation'},{ar:'تحليل ما تم، تحديد فجوات، تحديث الخطة، إعادة التدريب',en:'Analyze what happened, identify gaps, update the plan, retrain'},{ar:'توظيف فقط',en:'Recruit only'},{ar:'عدم تحديث',en:'Do not update'}],c:1,x:{ar:'تقييم: تحليل، تحديد فجوات، تحديث خطة، إعادة تدريب.',en:'Evaluation: analysis, gap identification, plan updates, retraining.'}, d:2, type:'mcq'},
    {t:{ar:'ما الفرق بين الإخلاء والإجلاء في الطوارئ؟',en:'What is the difference between evacuation and rescue in emergencies?'},o:[{ar:'لا فرق',en:'No difference'},{ar:'إخلاء: إبعاد الجميع. إجلاء: إنقاذ الأشخاص العالقين',en:'Evacuation: moving everyone out. Rescue: extracting trapped persons'},{ar:'إجلاء أبسط',en:'Rescue is simpler'},{ar:'إخلاء للخارج فقط',en:'Evacuation is outside only'}],c:1,x:{ar:'إخلاء (Evacuation): خروج آمن من المبنى. إجلاء (Rescue): إنقاذ من خطر وشيك.',en:'Evacuation: safe exit from the premises. Rescue: extraction from imminent danger.'}, d:2, type:'mcq'},
    {t:{ar:'أنواع الطوارئ الخمسة هي',en:'The five types of emergencies are'}, o:[{ar:'حريق فقط',en:'Fire only'},{ar:'حرائق، انفجارات، تسرب كيميائي، طبي، كوارث طبيعية',en:'Fires, explosions, chemical spills, medical, natural disasters'},{ar:'حرب فقط',en:'War only'},{ar:'فقط الحريق والطبي',en:'Only fire and medical'}],c:1,x:{ar:'خمسة أنواع: حريق، انفجار، تسرب كيميائي، طبي، كوارث طبيعية (فيضان، زلزال).',en:'Five types: fire, explosion, chemical spill, medical, natural disasters (flood, earthquake).'}, d:1, type:'mcq'},
    {t:{ar:'الإسعافات الأولية الأساسية في مكان العمل تتطلب',en:'Basic workplace first aid requires'}, a:{ar:['أدوية وملحقات مناسبة ومدربين معتمدين'], en:['appropriate supplies and equipment and trained personnel']}, x:{ar:'مكمن الإسعافات: معدات كافية (دُلاء، بطانيات، أدوية) ومدربين معتمدين في كل منشأة.',en:'First aid provision: adequate supplies (kits, blankets, medicines) and trained personnel at every workplace.'}, d:1, type:'fill'}
  ]},
  {id:'bc13',e:'off',n:{ar:'إدارة الأزمات',en:'Crisis Management'},i:'🌪️',x:120,q:[
    {t:{ar:'مراحل إدارة الأزمة؟',en:'What are the phases of crisis management?'},o:[{ar:'الهروب فقط',en:'Evacuate only'},{ar:'مراقبة، استجابة، تعافي، تعلم',en:'Monitoring, response, recovery, learning'},{ar:'عدم استجابة',en:'No response'},{ar:'توظيف فقط',en:'Recruit only'}],c:1,x:{ar:'مراحل: مراقبة (Size-up)، استجابة، تعافي، تعلم وتحسين.',en:'Phases: monitoring (size-up), response, recovery, learning and improvement.'}, d:1, type:'mcq'},
    {t:{ar:'أهمية التدريب على الأزمات؟',en:'Why is crisis drill training important?'},o:[{ar:'ليس مهماً',en:'Not important'},{ar:'يُنشّط الذاكرة العضلية ويضمن استجابة سريعة',en:'Builds muscle memory and ensures rapid response'},{ar:'يقلل تكلفة فقط',en:'Only reduces cost'},{ar:'يحسن صورة فقط',en:'Only improves image'}],c:1,x:{ar:'التدريب يُنشّط الاستجابة اللاواعية السريعة عند الأزمات الحقيقية.',en:'Training activates fast subconscious response during real crises.'}, d:2, type:'mcq'},
    {t:{ar:'ما دور الاتصال أثناء الأزمات؟',en:'What is the role of communication during a crisis?'},o:[{ar:'إخفاء المعلومات فقط',en:'Withhold information only'},{ar:'تنسيق الاستجابة وإدارة المعلومات والحد من الذعر',en:'Coordinate response, manage information, and minimise panic'},{ar:'السماح بالشائعات',en:'Allow rumours'},{ar:'عدم التواصل',en:'No communication'}],c:1,x:{ar:'التواصل: تنسيق الفرق، إعلام الجهات المعنية، تحديث הציבור، منع انتشار الشائعات.',en:'Communication: coordinate teams, inform authorities, update public, prevent spread of rumours.'}, d:2, type:'mcq'},
    {t:{ar:'مبدأ BCP يهدف إلى',en:'The BCP principle aims to'}, o:[{ar:'إغلاق المنظمة نهائياً',en:'Permanently close the organisation'},{ar:'ضمان استمرارية الأعمال خلال الأزمات والتعافي منها',en:'Ensure business continuity during crises and recovery from them'},{ar:'زيادة الأزمات',en:'Increase crises'},{ar:'تقليل عدد الموظفين',en:'Reduce employee count'}],c:1,x:{ar:'BCP (خطة استمرارية الأعمال): ضمان استمرار العمليات الحيوية أثناء الأزمات والتعافي السريع.',en:'BCP (Business Continuity Plan): ensure vital operations continue during crises and rapid recovery.'}, d:2, type:'mcq'},
    {t:{ar:'قيادة الأزمة تتطلب',en:'Crisis leadership requires'}, a:{ar:['اتخاذ قرارات سريعة تحت الضغط مع التفويض الواضح'], en:['making rapid decisions under pressure with clear delegation']}, x:{ar:'قائد الأزمة: قرارات سريعة، تفويض واضح، تواصل فعّال، صبر، ومرونة في التكيف.',en:'Crisis leader: rapid decisions, clear delegation, effective communication, patience, and adaptive flexibility.'}, d:3, type:'fill'}
  ]},
  {id:'bc14',e:'off',n:{ar:'صحة وسلامة البيئة',en:'HSE & Environment'},i:'🌍',x:230,q:[
    {t:{ar:'مبادئ HSE الثلاثة؟',en:'What are the three pillars of HSE?'},o:[{ar:'ربح وإنتاجية وجودة',en:'Profit, productivity, and quality'},{ar:'صحة العمال، سلامة العمليات، حماية البيئة',en:'Worker health, operational safety, environmental protection'},{ar:'تسويق ومبيعات فقط',en:'Marketing and sales only'},{ar:'تدريب فقط',en:'Training only'}],c:1,x:{ar:'HSE: Health (صحة)، Safety (سلامة)، Environment (بيئة).',en:'HSE: Health, Safety, and Environment.'}, d:1, type:'mcq'},
    {t:{ar:'أهمية إدارة النفايات؟',en:'Why is waste management important?'},o:[{ar:'ديكور فقط',en:'Decoration only'},{ar:'منع تلوث ومخاطر صحية وبيئية من نفايات صناعية',en:'Prevent pollution and health/environmental hazards from industrial waste'},{ar:'زيادة تكلفة فقط',en:'Only increases cost'},{ar:'تحسين مظهر فقط',en:'Only improves appearance'}],c:1,x:{ar:'إدارة نفايات: فصل، تصنيف، تخزين، نقل، تخلص آمن.',en:'Waste management: segregation, classification, storage, transport, safe disposal.'}, d:2, type:'mcq'},
    {t:{ar:'ما هي التقييم البيئي للتأثير (EIA)؟',en:'What is an Environmental Impact Assessment (EIA)?'},o:[{ar:'تقييم مالي فقط',en:'Financial assessment only'},{ar:'دراسة منهجية لتأثير المشروع على البيئة قبل البدء',en:'A systematic study of a project\'s environmental effects before commencement'},{ar:'تقييم الإنتاج فقط',en:'Production assessment only'},{ar:'لا وجود لها',en:'Does not exist'}],c:1,x:{ar:'EIA: دراسة شاملة تُقيّم الأثر البيئي للمشروع وتقترح تدابير تخفيف.',en:'EIA: a comprehensive study assessing the environmental impact of a project and proposing mitigation measures.'}, d:2, type:'mcq'},
    {t:{ar:'مبدأ المتلوّث يدفع (Polluter Pays Principle) يعني',en:'The Polluter Pays Principle means'}, o:[{ar:'الحكومة تدفع فقط',en:'The government pays only'},{ar:'المسؤول عن التلوث يتحمل تكاليف التنظيف والتعويض',en:'The polluter bears the costs of cleanup and compensation'},{ar:'العمال يدفعون',en:'Workers pay'},{ar:'المتضررون فقط',en:'Victims only'}],c:1,x:{ar:'المتلوّث يدفع: من يسبب التلوث يتحمل تكاليف إصلاح الضرر البيئي.',en:'The polluter pays: whoever causes pollution bears the cost of environmental remediation.'}, d:2, type:'mcq'},
    {t:{ar:'إدارة الطاقة في المنشآت الصناعية تشمل',en:'Energy management in industrial facilities includes'}, a:{ar:['مراقبة الاستهلاك وتحسين الكفاءة وتقليل الانبعاثات'], en:['monitoring consumption, improving efficiency, and reducing emissions']}, x:{ar:'إدارة الطاقة: مراقبة، تحسين كفاءة استخدام الطاقة، تقليل الانبعاثات، إعادة التدوير الحراري.',en:'Energy management: monitoring, improving energy efficiency, reducing emissions, heat recovery.'}, d:1, type:'fill'}
  ]},
  {id:'bc15',e:'off',n:{ar:'المهنية والأخلاقيات',en:'Professionalism & Ethics'},i:'⚖️',x:350,q:[
    {t:{ar:'اكتشفت مخاطرة خطيرة لكن الإدارة ترفض معالجتها. ماذا تفعل؟',en:'You discovered a serious hazard but management refuses to address it. What do you do?'},o:[{ar:'الصمت',en:'Stay silent'},{ar:'توثيق، تحذير كتابي، إبلاغ جهات رقابية إن لزم',en:'Document, issue written warning, report to regulatory authorities if necessary'},{ar:'ترك العمل فقط',en:'Quit the job only'},{ar:'التحدث مع الإعلام فقط',en:'Speak to the media only'}],c:1,x:{ar:'توثيق + تحذير كتابي + إبلاغ جهات رقابية. الصمت يخضع للمسؤولية.',en:'Document + written warning + report to regulatory authorities. Silence constitutes negligence.'}, d:2, type:'mcq'},
    {t:{ar:'الدور الأخلاقي لمتخصص السلامة؟',en:'What is the ethical role of a safety professional?'},o:[{ar:'تنفيذ أوامر فقط',en:'Follow orders only'},{ar:'حماية الأرواح والصحة مع الصدق والنزاهة والاستقلالية',en:'Protect lives and health with integrity, honesty, and independence'},{ar:'تحسين صورة فقط',en:'Improve image only'},{ar:'زيادة رواتب فقط',en:'Increase salary only'}],c:1,x:{ar:'حماية أرواح، صدق، نزاهة، استقلالية عن ضغوط الإدارة.',en:'Protect lives, honesty, integrity, independence from management pressures.'}, d:2, type:'mcq'},
    {t:{ar:'ما هو تضارب المصالح (Conflict of Interest) في مهنية السلامة؟',en:'What is a conflict of interest in safety practice?'},o:[{ar:'نزاع شخصي فقط',en:'Personal dispute only'},{ar:'عندما تتعارض المصلحة الشخصية مع الالتزام المهني بالسلامة',en:'When personal interests conflict with professional safety obligations'},{ar:'لا يوجد',en:'Does not exist'},{ar:'مهمة فقط',en:'Mission only'}],c:1,x:{ar:'تضارب المصالح: يجب الإفصاح عنه ومعالجته حتى تبقى القرارات محايدة ومبنية على الأدلة.',en:'Conflict of interest: must be disclosed and managed to keep decisions neutral and evidence-based.'}, d:2, type:'mcq'},
    {t:{ar:'ماذا يعني الإبلاغ عن المخالفات (Whistleblowing) في السلامة؟',en:'What does whistleblowing in safety mean?'},o:[{ar:'الإبلاغ عن زميل فقط',en:'Reporting a colleague only'},{ar:'إبلاغ جهة خارجية عن مخاطر أو مخالفات تم إهمالها داخلياً',en:'Reporting hazards or violations externally when they have been ignored internally'},{ar:'الشائعات',en:'Spreading rumours'},{ar:'الإبلاغ عن كل شيء',en:'Report everything'}],c:1,x:{ar:'الإبلاغ: حق وواجب إخبار الجهات الرقابية عند فشل الإدارة في معالجة مخاطر خطيرة.',en:'Whistleblowing: a right and duty to inform authorities when management fails to address serious hazards.'}, d:2, type:'mcq'},
    {t:{ar:'المؤهلات المهنية لسلامة المهنة تشمل',en:'Professional safety qualifications include'}, a:{ar:['BCSP وNEBOSH وIOSH والشهادات المعتمدة الأخرى'], en:['BCSP, NEBOSH, IOSH, and other recognised certifications']}, x:{ar:'شهادات: BCSP (Board of Certified Safety Professionals)، NEBOSH، IOSH، CSP، ASP.',en:'Certifications: BCSP, NEBOSH, IOSH, CSP (Certified Safety Professional), ASP.'}, d:1, type:'fill'}
  ]}
];

// --- Equipment Drawing Functions ---
function drawValve(x, y, s = 1) {
  X.save(); X.translate(x, y); X.scale(s, s);
  X.fillStyle = '#5d6d7e'; X.fillRect(-25, -3, 50, 6);
  X.fillStyle = '#7f8c8d'; X.fillRect(-7, -10, 14, 14);
  X.strokeStyle = '#e74c3c'; X.lineWidth = 2.5;
  X.beginPath(); X.arc(0, -16, 7, 0, Math.PI * 2); X.stroke();
  X.beginPath(); X.moveTo(-5, -16); X.lineTo(5, -16); X.moveTo(0, -22); X.lineTo(0, -10); X.stroke();
  X.fillStyle = '#c0392b'; X.fillRect(-1.5, -24, 3, 3);
  X.restore();
}

function drawTank(x, y, w, h) {
  X.save(); X.translate(x, y);
  X.fillStyle = 'rgba(0,0,0,0.15)';
  X.beginPath(); X.ellipse(w/2+3, h+3, w/2+4, 6, 0, 0, Math.PI*2); X.fill();
  const g = X.createLinearGradient(0, 0, w, 0);
  g.addColorStop(0, '#4a5568'); g.addColorStop(0.35, '#718096'); g.addColorStop(0.65, '#718096'); g.addColorStop(1, '#4a5568');
  X.fillStyle = g;
  X.beginPath(); X.moveTo(0, 16); X.lineTo(0, h-8); X.arc(w/2, h-8, w/2, Math.PI, 0); X.lineTo(w, 16); X.arc(w/2, 16, w/2, 0, Math.PI); X.closePath(); X.fill();
  X.fillStyle = '#718096'; X.beginPath(); X.ellipse(w/2, 16, w/2, 10, 0, 0, Math.PI*2); X.fill();
  X.strokeStyle = '#2d3748'; X.lineWidth = 1.5;
  X.beginPath(); X.moveTo(-3, 28); X.lineTo(-10, 28); X.moveTo(-3, 40); X.lineTo(-10, 40); X.moveTo(-3, 52); X.lineTo(-10, 52); X.stroke();
  X.strokeStyle = '#2d3748'; X.lineWidth = 1; X.beginPath(); X.moveTo(-6, 25); X.lineTo(-6, h-12); X.stroke();
  X.restore();
}

function drawHeatExchanger(x, y) {
  X.save(); X.translate(x, y);
  X.fillStyle = '#4a5568'; X.beginPath(); X.roundRect(-35, -12, 70, 24, 5); X.fill();
  X.strokeStyle = '#718096'; X.lineWidth = 2;
  for (let i = -2; i <= 2; i++) { X.beginPath(); X.moveTo(-35, i*6); X.lineTo(35, i*6); X.stroke(); }
  X.fillStyle = '#e74c3c'; X.beginPath(); X.arc(-40, -6, 5, 0, Math.PI*2); X.arc(40, -6, 5, 0, Math.PI*2); X.fill();
  X.fillStyle = '#f1c40f'; X.font = '9px Rajdhani'; X.fillText('IN', -55, -3); X.fillText('OUT', 42, -3);
  X.restore();
}

function drawBoiler(x, y) {
  X.save(); X.translate(x, y);
  const g = X.createLinearGradient(0, 0, 0, 50);
  g.addColorStop(0, '#4a5568'); g.addColorStop(1, '#2d3748');
  X.fillStyle = g; X.beginPath(); X.roundRect(-25, 0, 50, 50, 6); X.fill();
  X.fillStyle = '#e74c3c'; X.beginPath(); X.arc(0, 32, 10, 0, Math.PI*2); X.fill();
  X.fillStyle = '#f39c12'; X.beginPath(); X.arc(0, 32, 6, 0, Math.PI*2); X.fill();
  X.fillStyle = '#2d3748'; X.fillRect(-6, -25, 12, 25);
  X.fillStyle = 'rgba(150,150,150,0.25)';
  for (let i = 0; i < 3; i++) { X.beginPath(); X.arc(Math.sin(G.frame*0.02+i)*4, -30-i*8, 5+i*2, 0, Math.PI*2); X.fill(); }
  X.fillStyle = '#4a5568'; X.fillRect(25, 12, 35, 6); X.fillRect(-60, 12, 35, 6);
  X.restore();
}

function drawFan(x, y) {
  X.save(); X.translate(x, y);
  X.strokeStyle = '#4a5568'; X.lineWidth = 2.5; X.beginPath(); X.arc(0, 0, 20, 0, Math.PI*2); X.stroke();
  X.fillStyle = '#718096';
  for (let i = 0; i < 4; i++) { X.save(); X.rotate(G.frame*0.04 + i*Math.PI/2); X.beginPath(); X.ellipse(10, 0, 10, 3.5, 0, 0, Math.PI*2); X.fill(); X.restore(); }
  X.fillStyle = '#2d3748'; X.beginPath(); X.arc(0, 0, 4, 0, Math.PI*2); X.fill();
  X.restore();
}

function drawDrum(x, y) {
  X.save(); X.translate(x, y);
  const g = X.createLinearGradient(-12, 0, 12, 0);
  g.addColorStop(0, '#2d3748'); g.addColorStop(0.5, '#4a5568'); g.addColorStop(1, '#2d3748');
  X.fillStyle = g; X.beginPath(); X.roundRect(-12, -20, 24, 40, 3); X.fill();
  X.strokeStyle = '#1a202c'; X.lineWidth = 1;
  [-10, 0, 10].forEach(yo => { X.beginPath(); X.moveTo(-12, yo); X.lineTo(12, yo); X.stroke(); });
  X.fillStyle = '#f39c12'; X.fillRect(-6, -6, 12, 12);
  X.fillStyle = '#000'; X.font = 'bold 9px sans-serif'; X.fillText('!', -2.5, 2.5);
  X.restore();
}

function drawPlatform(x, y) {
  X.save(); X.translate(x, y);
  X.fillStyle = '#2d3748'; X.fillRect(-70, -4, 140, 8);
  X.fillStyle = '#1a202c'; X.fillRect(-60, 4, 6, 35); X.fillRect(54, 4, 6, 35);
  X.strokeStyle = '#2d3748'; X.lineWidth = 2.5;
  X.beginPath(); X.moveTo(-57, 8); X.lineTo(57, 30); X.moveTo(57, 8); X.lineTo(-57, 30); X.stroke();
  X.strokeStyle = '#f1c40f'; X.lineWidth = 1.5; X.beginPath(); X.arc(0, -12, 16, 0, Math.PI*2); X.stroke();
  X.font = 'bold 12px Rajdhani'; X.fillStyle = '#f1c40f'; X.fillText('H', -4, -8);
  X.restore();
}

// --- Character Drawing ---
function drawChar(cx, cy, frame, facing, state) {
  X.save(); X.translate(cx, cy); X.scale(facing, 1);
  
  // Shadow
  X.fillStyle = 'rgba(0,0,0,0.25)';
  X.beginPath(); X.ellipse(0, 0, 16, 4, 0, 0, Math.PI*2); X.fill();
  
  const legSwing = state === 'walk' ? Math.sin(frame*0.15)*7 : 0;
  const armSwing = state === 'walk' ? Math.sin(frame*0.15)*10 : 0;
  const breathe = Math.sin(frame*0.05)*1.5;
  const headBob = state === 'walk' ? Math.abs(Math.sin(frame*0.15))*2 : 0;
  
  // Legs
  X.strokeStyle = '#2c3e50'; X.lineWidth = 3.5; X.lineCap = 'round';
  X.beginPath(); X.moveTo(-5, -22); X.lineTo(-5-legSwing, -3); X.stroke();
  X.beginPath(); X.moveTo(5, -22); X.lineTo(5+legSwing, -3); X.stroke();
  
  // Boots
  X.fillStyle = '#1a1a1a';
  X.beginPath(); X.roundRect(-9-legSwing, -5, 9, 4, 1); X.fill();
  X.beginPath(); X.roundRect(legSwing-1, -5, 9, 4, 1); X.fill();
  
  // Body (coverall)
  X.fillStyle = '#3498db';
  X.beginPath(); X.roundRect(-10, -46+breathe, 20, 25, 3); X.fill();
  
  // Safety vest
  X.fillStyle = '#f39c12';
  X.beginPath(); X.roundRect(-9, -44+breathe, 18, 18, 2); X.fill();
  
  // Reflective stripes
  X.strokeStyle = '#fff'; X.lineWidth = 1.5;
  X.beginPath(); X.moveTo(-7, -38+breathe); X.lineTo(7, -38+breathe); X.moveTo(-7, -33+breathe); X.lineTo(7, -33+breathe); X.stroke();
  
  // Arms
  X.strokeStyle = '#f39c12'; X.lineWidth = 4; X.lineCap = 'round';
  X.beginPath(); X.moveTo(-10, -42+breathe); X.lineTo(-15-armSwing, -28+breathe); X.stroke();
  X.beginPath(); X.moveTo(10, -42+breathe); X.lineTo(15+armSwing, -28+breathe); X.stroke();
  
  // Hands
  X.fillStyle = '#f5c6a0';
  X.beginPath(); X.arc(-15-armSwing, -27+breathe, 2.5, 0, Math.PI*2); X.fill();
  X.beginPath(); X.arc(15+armSwing, -27+breathe, 2.5, 0, Math.PI*2); X.fill();
  
  // Clipboard
  X.fillStyle = '#8B4513'; X.fillRect(17+armSwing, -38+breathe, 7, 10);
  X.fillStyle = '#fff'; X.fillRect(18.5+armSwing, -36+breathe, 4, 6);
  
  // Head
  X.fillStyle = '#f5c6a0';
  X.beginPath(); X.arc(0, -54-headBob+breathe, 9, 0, Math.PI*2); X.fill();
  
  // Hard hat
  X.fillStyle = '#f1c40f';
  X.beginPath(); X.arc(0, -58-headBob+breathe, 10, Math.PI, 0); X.fill();
  X.fillRect(-12, -58-headBob+breathe, 24, 3);
  
  // Helmet light
  X.fillStyle = '#fff';
  X.beginPath(); X.arc(0, -62-headBob+breathe, 2.5, 0, Math.PI*2); X.fill();
  
  // Eyes
  X.fillStyle = '#2c3e50';
  X.beginPath(); X.arc(-3, -53-headBob+breathe, 1.5, 0, Math.PI*2); X.fill();
  X.beginPath(); X.arc(3, -53-headBob+breathe, 1.5, 0, Math.PI*2); X.fill();
  
  // Smile
  X.strokeStyle = '#2c3e50'; X.lineWidth = 1.2;
  X.beginPath(); X.arc(0, -50-headBob+breathe, 3, 0.1, Math.PI-0.1); X.stroke();
  
  // Interaction animation
  if (state === 'interact') {
    X.strokeStyle = 'rgba(240,165,0,0.6)'; X.lineWidth = 1.5;
    for (let i = 0; i < 3; i++) {
      const r = 20 + i*8 + Math.sin(frame*0.1)*3;
      const alpha = 0.4 - i*0.12;
      X.globalAlpha = alpha;
      X.beginPath(); X.arc(0, -30, r, -Math.PI*0.3, Math.PI*0.3); X.stroke();
    }
    X.globalAlpha = 1;
  }
  
  X.restore();
}

// --- Background Drawing ---
function drawBg() {
  const env = G.env;
  
  // Sky
  const skyG = X.createLinearGradient(0, 0, 0, GY);
  const skyColors = {
    gas: ['#0a1628','#152238'], oil: ['#0d1b2a','#1a3050'],
    sea: ['#0a1628','#0d2137'], off: ['#0d1b2a','#16283b']
  };
  skyG.addColorStop(0, skyColors[env][0]); skyG.addColorStop(1, skyColors[env][1]);
  X.fillStyle = skyG; X.fillRect(0, 0, W, GY);
  
  // Stars
  if (env !== 'off') {
    X.fillStyle = 'rgba(255,255,255,0.4)';
    for (let i = 0; i < 40; i++) {
      X.beginPath(); X.arc((i*97)%W, (i*53)%(GY*0.5), 0.8, 0, Math.PI*2); X.fill();
    }
  }
  
  // Ground
  const gndColors = {gas:'#1a2a3a', oil:'#1c2c3c', sea:'#0a1e30', off:'#1a2a3a'};
  X.fillStyle = gndColors[env]; X.fillRect(0, GY, W, H-GY);
  
  // Ground line
  X.strokeStyle = '#2a3a4a'; X.lineWidth = 1.5;
  X.beginPath(); X.moveTo(0, GY); X.lineTo(W, GY); X.stroke();
  
  // Ground pipe
  X.strokeStyle = '#253545'; X.lineWidth = 5;
  X.beginPath(); X.moveTo(0, GY+15); X.lineTo(W, GY+15); X.stroke();
  
  // Pipe supports
  X.fillStyle = '#1e2e3e';
  for (let px = 40; px < W; px += 100) { X.fillRect(px-2, GY+10, 4, 12); }
  
  // Environment-specific background
  const cam = G.camX;
  
  if (env === 'gas') {
    drawTank(80-cam*0.2, GY-70, 50, 70);
    drawTank(300-cam*0.2, GY-90, 45, 90);
    drawTank(550-cam*0.2, GY-60, 40, 60);
    // Flare stack
    X.fillStyle = '#4a5568'; X.fillRect(W-80-cam*0.15, GY-130, 8, 130);
    X.fillStyle = '#e74c3c'; X.beginPath(); X.arc(W-76-cam*0.15, GY-135, 6+Math.sin(G.frame*0.08)*2, 0, Math.PI*2); X.fill();
    X.fillStyle = '#f39c12'; X.beginPath(); X.arc(W-76-cam*0.15, GY-135, 3+Math.sin(G.frame*0.12)*1.5, 0, Math.PI*2); X.fill();
  } else if (env === 'oil') {
    for (let i = 0; i < 3; i++) {
      const cx = 120+i*180-cam*0.2;
      X.fillStyle = '#4a5568'; X.fillRect(cx-10, GY-100, 20, 100);
      for (let j = 0; j < 5; j++) { X.fillStyle = '#374151'; X.fillRect(cx-15, GY-15-j*16, 30, 2.5); }
      X.fillStyle = '#718096'; X.beginPath(); X.arc(cx, GY-100, 10, 0, Math.PI*2); X.fill();
    }
    // Cooling tower
    X.fillStyle = '#374151';
    X.beginPath(); X.moveTo(450-cam*0.15, GY); X.lineTo(468-cam*0.15, GY-65); X.lineTo(505-cam*0.15, GY-65); X.lineTo(523-cam*0.15, GY); X.closePath(); X.fill();
    X.fillStyle = 'rgba(180,180,180,0.15)';
    for (let i = 0; i < 3; i++) { X.beginPath(); X.arc(486-cam*0.15+Math.sin(G.frame*0.015+i)*8, GY-70-i*12, 10+i*2, 0, Math.PI*2); X.fill(); }
  } else if (env === 'sea') {
    X.fillStyle = '#0a2a40'; X.fillRect(0, GY+15, W, H-GY-15);
    X.strokeStyle = '#1a4a60'; X.lineWidth = 1.5;
    for (let w = 0; w < 3; w++) {
      X.beginPath();
      for (let x = 0; x < W; x += 4) {
        const wy = GY+22+w*12+Math.sin((x+G.frame*1.5)*0.018)*4;
        x===0 ? X.moveTo(x, wy) : X.lineTo(x, wy);
      }
      X.stroke();
    }
    drawPlatform(250-cam*0.15, GY-40);
    X.fillStyle = '#f1c40f'; X.fillRect(310-cam*0.15, GY-85, 4, 70);
    X.strokeStyle = '#f1c40f'; X.lineWidth = 1.5;
    X.beginPath(); X.moveTo(312-cam*0.15, GY-85); X.lineTo(350-cam*0.15, GY-78); X.stroke();
  } else if (env === 'off') {
    X.fillStyle = '#152030'; X.fillRect(80-cam*0.2, GY-170, 170, 170);
    X.fillStyle = '#1e3040';
    for (let i = 0; i < 4; i++) for (let j = 0; j < 5; j++) {
      X.fillRect(90+i*38-cam*0.2, GY-160+j*32, 26, 20);
      X.fillStyle = 'rgba(240,165,0,0.06)'; X.fillRect(90+i*38-cam*0.2, GY-160+j*32, 26, 20);
      X.fillStyle = '#1e3040';
    }
    X.fillStyle = '#182838'; X.fillRect(350-cam*0.2, GY-130, 130, 130);
    for (let i = 0; i < 3; i++) for (let j = 0; j < 4; j++) {
      X.fillStyle = '#1e3040'; X.fillRect(360+i*38-cam*0.2, GY-120+j*28, 26, 18);
    }
  }
  
  // Foreground equipment
  drawValve(180-cam, GY-4, 1.1);
  drawValve(450-cam, GY-4, 0.95);
  drawValve(720-cam, GY-4, 1.05);
  drawDrum(320-cam*1.15, GY-20);
  drawDrum(620-cam*1.15, GY-20);
  drawBoiler(80-cam*1.1, GY-50);
  drawFan(680-cam*1.1, GY-25);
  drawHeatExchanger(400-cam*1.1, GY-12);
}

// --- Station Drawing ---
function drawStations() {
  const envSt = ST.filter(s => s.e === G.env);
  envSt.forEach((st, idx) => {
    const sx = st.x - G.camX * 0.75;
    const sy = GY - 30;
    if (sx < -60 || sx > W + 60) return;
    
    const done = G.completed[st.id];
    const avail = idx === 0 || G.completed[envSt[idx-1]?.id];
    
    X.save(); X.translate(sx, sy);
    
    if (avail && !done) { X.shadowColor = '#f0a500'; X.shadowBlur = 12 + Math.sin(G.frame*0.04)*4; }
    
    X.beginPath(); X.arc(0, 0, 14, 0, Math.PI*2);
    X.fillStyle = done ? 'rgba(46,125,50,0.9)' : avail ? 'rgba(240,165,0,0.25)' : 'rgba(80,80,80,0.25)';
    X.fill();
    X.strokeStyle = done ? '#2e7d32' : avail ? '#f0a500' : '#555';
    X.lineWidth = 2; X.stroke();
    X.shadowBlur = 0;
    
    X.font = '12px sans-serif'; X.textAlign = 'center'; X.textBaseline = 'middle';
    X.fillText(st.i, 0, 0);
    
    X.font = `9px ${G.lang==='ar'?'Cairo':'Rajdhani'}`;
    X.fillStyle = done ? '#2e7d32' : avail ? '#f0a500' : '#555';
    X.fillText(L(st.n), 0, 24);
    
    if (done) { X.font = '8px sans-serif'; X.fillText('✓', 0, 0); }
    
    X.restore();
  });
}

// --- Particle System ---
function drawParticles() {
  G.particles = G.particles.filter(p => {
    p.life--;
    if (p.type === 'click') {
      X.strokeStyle = `rgba(240,165,0,${p.life/25})`;
      X.lineWidth = 1.5;
      X.beginPath(); X.arc(p.x, p.y, (25-p.life)*0.7, 0, Math.PI*2); X.stroke();
    } else if (p.type === 'spark') {
      X.fillStyle = `rgba(240,165,0,${p.life/p.maxLife})`;
      X.beginPath(); X.arc(p.x, p.y, 2, 0, Math.PI*2); X.fill();
      p.x += p.vx; p.y += p.vy; p.vy += 0.1;
    } else if (p.type === 'dust') {
      X.fillStyle = `rgba(200,200,200,${p.life/p.maxLife*0.3})`;
      X.beginPath(); X.arc(p.x, p.y, 1.5, 0, Math.PI*2); X.fill();
      p.x += p.vx; p.y += p.vy;
    }
    return p.life > 0;
  });
}

// --- Minimap ---
function drawMinimap() {
  if (!G.showMap) return;
  X.fillStyle = 'rgba(10,14,23,0.85)';
  X.fillRect(W-152, 48, 140, 70);
  X.strokeStyle = 'rgba(255,255,255,0.08)';
  X.strokeRect(W-152, 48, 140, 70);
  
  const envSt = ST.filter(s => s.e === G.env);
  envSt.forEach(st => {
    const mx = W-152+(st.x/800)*140;
    X.fillStyle = G.completed[st.id] ? '#2e7d32' : '#f0a500';
    X.beginPath(); X.arc(mx, 95, 2.5, 0, Math.PI*2); X.fill();
  });
  
  const charMx = W-152+(G.cx/W)*140;
  X.fillStyle = '#3498db';
  X.beginPath(); X.arc(charMx, 90, 3.5, 0, Math.PI*2); X.fill();
}

// --- Click Handler ---
C.addEventListener('click', (e) => {
  initAudio();
  const rect = C.getBoundingClientRect();
  const mx = (e.clientX - rect.left) * (W / rect.width);
  const my = (e.clientY - rect.top) * (H / rect.height);
  
  const envSt = ST.filter(s => s.e === G.env);
  
  for (let i = 0; i < envSt.length; i++) {
    const st = envSt[i];
    const sx = st.x - G.camX * 0.75;
    const sy = GY - 30;
    const dx = mx - sx, dy = my - sy;
    
    if (Math.sqrt(dx*dx+dy*dy) < 28) {
      const avail = i === 0 || G.completed[envSt[i-1]?.id];
      if (avail || G.completed[st.id]) {
        G.tx = sx;
        sfx('click');
        // Move character then start quiz
        const moveToStation = () => {
          if (Math.abs(G.cx - G.tx) > 8) {
            requestAnimationFrame(moveToStation);
          } else {
            G.interactAnim = 30;
            sfx('unlock');
            setTimeout(() => startQuiz(st), 300);
          }
        };
        moveToStation();
      } else {
        showSpeech(UI[G.lang].speech.locked);
        sfx('wrong');
      }
      return;
    }
  }
  
  // Move to click position
  G.tx = Math.max(30, Math.min(mx, W-30));
  sfx('click');
  G.particles.push({x:mx, y:my, life:25, type:'click'});
});

// --- Tooltip ---
C.addEventListener('mousemove', (e) => {
  const rect = C.getBoundingClientRect();
  const mx = (e.clientX - rect.left) * (W / rect.width);
  const my = (e.clientY - rect.top) * (H / rect.height);
  const tip = document.getElementById('tip');
  let found = false;
  
  const envSt = ST.filter(s => s.e === G.env);
  for (let i = 0; i < envSt.length; i++) {
    const st = envSt[i];
    const sx = st.x - G.camX * 0.75;
    const sy = GY - 30;
    if (Math.sqrt((mx-sx)**2+(my-sy)**2) < 28) {
      const done = G.completed[st.id];
      const avail = i === 0 || G.completed[envSt[i-1]?.id];
      tip.style.display = 'block';
      tip.style.left = (e.clientX+12)+'px'; tip.style.top = (e.clientY-8)+'px';
      const u = UI[G.lang].tooltip;
      tip.innerHTML = `<b>${st.i} ${L(st.n)}</b><br><span style="color:${done?'#2e7d32':avail?'#f0a500':'#666'}">${done?u.done:avail?u.avail:u.locked}</span>`;
      found = true; C.style.cursor = 'pointer';
      break;
    }
  }
  if (!found) { tip.style.display = 'none'; C.style.cursor = 'crosshair'; }
});

// --- Touch support for mobile ---
C.addEventListener('touchstart', (e) => {
  e.preventDefault();
  const touch = e.touches[0];
  const rect = C.getBoundingClientRect();
  const mx = (touch.clientX - rect.left) * (W / rect.width);
  const my = (touch.clientY - rect.top) * (H / rect.height);
  
  // Simulate click
  C.dispatchEvent(new MouseEvent('click', {
    clientX: touch.clientX, clientY: touch.clientY
  }));
}, {passive: false});

// --- D-Pad ---
document.querySelectorAll('.dpad-btn').forEach(btn => {
  const dir = btn.dataset.dir;
  let interval;
  
  btn.addEventListener('touchstart', (e) => {
    e.preventDefault();
    interval = setInterval(() => {
      if (dir === 'left') G.tx = Math.max(30, G.tx - 20);
      else if (dir === 'right') G.tx = Math.min(W-30, G.tx + 20);
    }, 50);
  }, {passive: false});
  
  btn.addEventListener('touchend', () => clearInterval(interval));
  btn.addEventListener('touchcancel', () => clearInterval(interval));
});

// --- Keyboard ---
document.addEventListener('keydown', (e) => {
  if (e.key === 'ArrowRight' || e.key === 'd') G.tx = Math.min(W-30, G.tx+25);
  else if (e.key === 'ArrowLeft' || e.key === 'a') G.tx = Math.max(30, G.tx-25);
  else if (e.key === 'Escape') closeQuiz();
});

// --- Quiz System ---
function startQuiz(st) {
  // Use adaptive selection to pick 2 questions from pool
  const selected = selectQuestions(st);
  G.quiz = { ...st, q: selected };
  G.qIdx = 0; G.qAnswered = false; G.qSelected = null; G.qScore = 0;
  renderQuiz();
}

function renderQuiz() {
  if (!G.quiz) return;
  const q = G.quiz.q[G.qIdx];
  const total = G.quiz.q.length;
  const u = UI[G.lang];
  
  const ov = document.createElement('div');
  ov.className = 'qz'; ov.id = 'qz';
  ov.onclick = (e) => { if (e.target === ov) closeQuiz(); };
  
  const isLast = G.qIdx === total - 1;
  const letters = u.quiz.letters;
  const qName = L(G.quiz.n);
  
  ov.innerHTML = `
    <div class="qz-card">
      <div class="qz-head">
        <h3>${G.quiz.i} ${qName}</h3>
        <button class="qz-x" onclick="closeQuiz()">✕</button>
      </div>
      <div class="qz-body">
        <div class="qz-prog">${G.quiz.q.map((_,i) => `<span class="${i<G.qIdx?'done':i===G.qIdx?'current':''}"></span>`).join('')}</div>
        <div style="font-size:11px;color:#667;text-align:center;margin-bottom:10px">${u.quiz.questionOf(G.qIdx+1, total)}</div>
        <div class="qz-q">${L(q.t)}</div>
        ${q.type !== 'fill' ? `
        <div class="qz-opts">
          ${q.o.map((opt,i) => {
            let cls = 'qz-opt';
            if (G.qAnswered) {
              cls += ' dis';
              if (i === q.c) cls += ' ok';
              else if (i === G.qSelected) cls += ' no';
            }
            return `<button class="${cls}" onclick="selAns(${i})"><span class="l">${letters[i]}</span><span>${L(opt)}</span></button>`;
          }).join('')}
        </div>
        ` : ''}
        ${q.type === 'fill' ? `
  <div class="qz-fill" id="qzFill">
    <input type="text" class="qz-input" id="qzInput" placeholder="${u.quiz.fillPlaceholder}" onkeydown="if(event.key==='Enter')checkFill()">
    <button class="qz-check" onclick="checkFill()">${u.quiz.fillCheck}</button>
  </div>
` : ''}
        ${G.qAnswered ? `
          <div class="qz-exp ${G.qSelected===q.c?'ok':'no'}">
            ${G.qSelected===q.c ? u.quiz.correct : u.quiz.wrong}<br>${L(q.x)}
          </div>
          <button class="qz-next" onclick="${isLast?'finQuiz()':'nextQ()'}">${isLast?u.quiz.results:u.quiz.next}</button>
        ` : ''}
      </div>
    </div>`;
  
  document.body.appendChild(ov);
}

window.selAns = function(i) {
  if (G.qAnswered) return;
  if (G.quiz.q[G.qIdx].type === 'fill') return;
  G.qSelected = i; G.qAnswered = true;
  const q = G.quiz.q[G.qIdx];
  if (i === q.c) { G.qScore++; sfx('correct'); recordAnswer(G.quiz.id, G.qIdx, true); G.particles.push({x:W/2,y:H/2,life:30,type:'spark',vx:(Math.random()-0.5)*4,vy:-3,maxLife:30}); }
  else { sfx('wrong'); recordAnswer(G.quiz.id, G.qIdx, false); }
  renderQuiz();
};

function normalizeAr(text) {
  return text.trim().toLowerCase()
    .replace(/[إأآا]/g, 'ا')
    .replace(/ة/g, 'ه')
    .replace(/ى/g, 'ي')
    .replace(/[\u064B-\u065F]/g, '')
    .replace(/\s+/g, ' ');
}

function checkFill() {
  if (G.qAnswered) return;
  const input = document.getElementById('qzInput');
  const userAnswer = input.value.trim();
  if (!userAnswer) return;
  
  const q = G.quiz.q[G.qIdx];
  const accepted = L(q.a); // array of accepted answers
  let correct = false;
  
  for (const ans of accepted) {
    if (normalizeAr(userAnswer) === normalizeAr(ans)) {
      correct = true; break;
    }
    // Also check if user entered just the number for numeric answers
    if (/^\d+/.test(ans) && userAnswer.match(/\d+/)) {
      if (userAnswer.match(/\d+/)[0] === ans.match(/\d+/)[0]) {
        correct = true; break;
      }
    }
  }
  
  input.classList.add(correct ? 'correct' : 'wrong');
  input.disabled = true;
  
  G.qAnswered = true;
  G.qSelected = correct ? 0 : -1;
  if (correct) { G.qScore++; sfx('correct'); }
  else { sfx('wrong'); }
  
  recordAnswer(G.quiz.id, G.qIdx, correct);
  
  // Show explanation and next button
  const expDiv = document.createElement('div');
  expDiv.className = `qz-exp ${correct ? 'ok' : 'no'}`;
  expDiv.innerHTML = `${correct ? UI[G.lang].quiz.correct : UI[G.lang].quiz.wrong}<br>${L(q.x)}`;
  document.querySelector('.qz-fill').after(expDiv);
  
  const nextBtn = document.createElement('button');
  nextBtn.className = 'qz-next';
  nextBtn.textContent = G.qIdx === G.quiz.q.length - 1 ? UI[G.lang].quiz.results : UI[G.lang].quiz.next;
  nextBtn.onclick = G.qIdx === G.quiz.q.length - 1 ? window.finQuiz : window.nextQ;
  expDiv.after(nextBtn);
}

window.nextQ = function() { G.qIdx++; G.qAnswered = false; G.qSelected = null; renderQuiz(); };

window.finQuiz = function() {
  const pct = Math.round((G.qScore / G.quiz.q.length) * 100);
  if (pct >= 50) { G.completed[G.quiz.id] = true; G.score += G.qScore; sfx('complete'); }
  closeQuiz(); updateHUD();
  showSpeech(pct >= 70 ? UI[G.lang].speech.excellent : pct >= 50 ? UI[G.lang].speech.good : UI[G.lang].speech.retry);
  saveProgress();
};

window.closeQuiz = function() {
  const ov = document.getElementById('qz');
  if (ov) ov.remove();
  G.quiz = null;
};

// --- UI Functions ---
function updateHUD() {
  const total = ST.length;
  const done = Object.keys(G.completed).length;
  const pct = Math.round((done/total)*100);
  
  document.getElementById('barFill').style.width = pct+'%';
  document.getElementById('barTxt').textContent = `${done}/${total}`;
  
  const ranks = UI[G.lang].ranks;
  let rankInfo = ranks[0];
  for (let i = ranks.length - 1; i >= 0; i--) {
    if (done >= ranks[i].min) { rankInfo = ranks[i]; break; }
  }
  document.getElementById('rank').textContent = rankInfo.icon + ' ' + rankInfo.name;
  
  ['gas','oil','sea','off'].forEach(e => {
    const tot = ST.filter(s => s.e===e).length;
    const dn = ST.filter(s => s.e===e && G.completed[s.id]).length;
    const ids = {gas:'cGas',oil:'cOil',sea:'cSea',off:'cOff'};
    document.getElementById(ids[e]).textContent = `${dn}/${tot}`;
  });
}

function showSpeech(txt) {
  const el = document.getElementById('speech');
  el.textContent = txt; el.style.display = 'block';
  clearTimeout(G.speechTimer);
  G.speechTimer = setTimeout(() => el.style.display = 'none', 3500);
}

function showToast(txt) {
  const el = document.getElementById('toast');
  el.textContent = txt; el.style.display = 'block';
  setTimeout(() => el.style.display = 'none', 3000);
}

// --- Save/Load ---
function saveProgress() {
  try {
    localStorage.setItem('hse_save', JSON.stringify({
      c: G.completed,
      s: G.score,
      p: G.perf,
      l: G.lang
    }));
  } catch(e) {}
}

function loadProgress() {
  try {
    const d = JSON.parse(localStorage.getItem('hse_save'));
    if (d) {
      G.completed = d.c || {};
      G.score = d.s || 0;
      G.perf = d.p || {};
      if (d.l && UI[d.l]) G.lang = d.l;
    }
  } catch(e) {}
}

// --- Env Switch ---
document.querySelectorAll('.env-tab').forEach(tab => {
  tab.addEventListener('click', () => {
    G.env = tab.dataset.e;
    G.camX = 0; G.cx = W/2; G.tx = W/2;
    document.querySelectorAll('.env-tab').forEach(t => t.classList.toggle('on', t.dataset.e === G.env));
    updateHUD();
    showSpeech(UI[G.lang].speech.envSwitch(UI[G.lang].envFull[G.env]));
    sfx('click');
  });
});

// --- HUD Buttons ---
document.getElementById('btnSave').addEventListener('click', () => { saveProgress(); showToast(t('toast.saved')); sfx('unlock'); });
document.getElementById('btnMap').addEventListener('click', () => { G.showMap = !G.showMap; document.getElementById('btnMap').classList.toggle('on', G.showMap); });
document.getElementById('btnSnd').addEventListener('click', () => { G.soundOn = !G.soundOn; document.getElementById('btnSnd').textContent = G.soundOn ? '🔊' : '🔇'; });
document.getElementById('btnLang').addEventListener('click', () => {
  G.lang = G.lang === 'ar' ? 'en' : 'ar';
  localStorage.setItem('hse_lang', G.lang);
  applyLang();
  sfx('click');
});

function applyLang() {
  const u = UI[G.lang];
  document.documentElement.dir = u.dir;
  document.documentElement.lang = u.lang;
  document.body.className = 'lang-' + u.lang;
  document.title = u.title;
  document.getElementById('btnSave').title = u.hud.save;
  document.getElementById('btnMap').title = u.hud.map;
  document.getElementById('btnSnd').title = u.hud.sound;
  document.getElementById('btnLang').title = u.hud.lang;
  // Update env tabs
  document.querySelectorAll('.env-tab').forEach(tab => {
    const e = tab.dataset.e;
    tab.childNodes[1].textContent = u.envs[e];
  });
  updateHUD();
}

// --- Resize ---
function resize() {
  W = window.innerWidth; H = window.innerHeight;
  GY = H * 0.65;
  C.width = W; C.height = H;
}
window.addEventListener('resize', resize);
resize();

// --- Game Loop ---
let lastStep = 0;

function loop(ts) {
  G.frame++;
  
  X.clearRect(0, 0, W, H);
  
  drawBg();
  drawStations();
  
  // Character movement
  const dx = G.tx - G.cx;
  G.walking = Math.abs(dx) > 4;
  
  if (G.interactAnim > 0) {
    G.interactAnim--;
    drawChar(G.cx, GY-5, G.frame, G.facing, 'interact');
  } else if (G.walking) {
    G.cx += dx * 0.06;
    G.frame++;
    G.facing = dx > 0 ? 1 : -1;
    drawChar(G.cx, GY-5, G.frame, G.facing, 'walk');
    
    if (ts - lastStep > 280) { sfx('step'); lastStep = ts; }
    
    // Dust particles while walking
    if (G.frame % 8 === 0) {
      G.particles.push({x:G.cx+(Math.random()-0.5)*10, y:GY-2, life:20, type:'dust', vx:(Math.random()-0.5)*0.5, vy:-0.3, maxLife:20});
    }
  } else {
    drawChar(G.cx, GY-5, G.frame, G.facing, 'idle');
  }
  
  drawParticles();
  drawMinimap();
  
  requestAnimationFrame(loop);
}

// --- Init ---
// Load language preference
try {
  const savedLang = localStorage.getItem('hse_lang');
  if (savedLang && UI[savedLang]) G.lang = savedLang;
} catch(e) {}
applyLang();
loadProgress();
updateHUD();
showSpeech(UI[G.lang].speech.welcome);
requestAnimationFrame(loop);

</script>
</body>
</html>
